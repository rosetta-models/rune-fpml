namespace fpml.consolidated.ird : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*
import fpml.consolidated.asset.*
import fpml.consolidated.fpmlenum.*
import fpml.consolidated.shared.*

type BulletPayment extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A product to represent a single cashflow."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A product to represent a single cashflow."]

    payment Payment (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A known payment between two parties."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A known payment between two parties."]

type CapFloor extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining an interest rate cap, floor, or cap/floor strategy (e.g. collar) product."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining an interest rate cap, floor, or cap/floor strategy (e.g. collar) product."]

    capFloorStream InterestRateStream (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to the leg, where date adjustments may apply."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to the leg, where date adjustments may apply."]
    premium Payment (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The option premium amount payable by buyer to seller on the specified payment date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The option premium amount payable by buyer to seller on the specified payment date."]
    additionalPayment Payment (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Additional payments between the principal parties."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Additional payments between the principal parties."]
    earlyTerminationProvision EarlyTerminationProvision (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Parameters specifying provisions relating to the optional and mandatory early terminarion of a CapFloor transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Parameters specifying provisions relating to the optional and mandatory early terminarion of a CapFloor transaction."]

type FloatingRateCalculation extends FloatingRate:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining the floating rate and definitions relating to the calculation of floating rate amounts."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining the floating rate and definitions relating to the calculation of floating rate amounts."]

    initialRate number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The initial floating rate reset agreed between the principal parties involved in the trade. This is assumed to be the first required reset rate for the first regular calculation period. It should only be included when the rate is not equal to the rate published on the source implied by the floating rate index. An initial rate of 5% would be represented as 0.05."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The initial floating rate reset agreed between the principal parties involved in the trade. This is assumed to be the first required reset rate for the first regular calculation period. It should only be included when the rate is not equal to the rate published on the source implied by the floating rate index. An initial rate of 5% would be represented as 0.05."]
    finalRateRounding Rounding (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The rounding convention to apply to the final rate used in determination of a calculation period amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The rounding convention to apply to the final rate used in determination of a calculation period amount."]
    averagingMethod AveragingMethodEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If averaging is applicable, this component specifies whether a weighted or unweighted average method of calculation is to be used. The component must only be included when averaging applies."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If averaging is applicable, this component specifies whether a weighted or unweighted average method of calculation is to be used. The component must only be included when averaging applies."]
    negativeInterestRateTreatment NegativeInterestRateTreatmentEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The specification of any provisions for calculating payment obligations when a floating rate is negative (either due to a quoted negative floating rate or by operation of a spread that is subtracted from the floating rate)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The specification of any provisions for calculating payment obligations when a floating rate is negative (either due to a quoted negative floating rate or by operation of a spread that is subtracted from the floating rate)."]

type Fra extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining a Forward Rate Agreement (FRA) product."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining a Forward Rate Agreement (FRA) product."]

    buyerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
    buyerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that buys this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that buys this instrument."]
    sellerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
    sellerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that sells this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that sells this instrument."]
    adjustedEffectiveDate RequiredIdentifierDate (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The start date of the calculation period. This date should already be adjusted for any applicable business day convention. This is also the date when the observed rate is applied, the reset date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The start date of the calculation period. This date should already be adjusted for any applicable business day convention. This is also the date when the observed rate is applied, the reset date."]
    adjustedTerminationDate zonedDateTime (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The end date of the calculation period. This date should already be adjusted for any applicable business day convention."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The end date of the calculation period. This date should already be adjusted for any applicable business day convention."]
    paymentDate AdjustableDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The payment date. This date is subject to adjustment in accordance with any applicable business day convention."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The payment date. This date is subject to adjustment in accordance with any applicable business day convention."]
    fixingDateOffset RelativeDateOffset (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixing date relative to the reset date in terms of a business days offset and an associated set of financial business centers. Normally these offset calculation rules will be those specified in the ISDA definition for the relevant floating rate index (ISDA\'s Floating Rate Option). However, non-standard offset calculation rules may apply for a trade if mutually agreed by the principal parties to the transaction. The href attribute on the dateRelativeTo element should reference the id attribute on the adjustedEffectiveDate element."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixing date relative to the reset date in terms of a business days offset and an associated set of financial business centers. Normally these offset calculation rules will be those specified in the ISDA definition for the relevant floating rate index (ISDA\'s Floating Rate Option). However, non-standard offset calculation rules may apply for a trade if mutually agreed by the principal parties to the transaction. The href attribute on the dateRelativeTo element should reference the id attribute on the adjustedEffectiveDate element."]
    dayCountFraction DayCountFraction (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The day count fraction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The day count fraction."]
    calculationPeriodNumberOfDays int(min: 1) (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The number of days from the adjusted effective date to the adjusted termination date calculated in accordance with the applicable day count fraction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The number of days from the adjusted effective date to the adjusted termination date calculated in accordance with the applicable day count fraction."]
    notional Money (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The notional amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The notional amount."]
    fixedRate IdentifiedRate (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The calculation period fixed rate. A per annum rate, expressed as a decimal. A fixed rate of 5% would be represented as 0.05."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The calculation period fixed rate. A per annum rate, expressed as a decimal. A fixed rate of 5% would be represented as 0.05."]
    floatingRateIndex FloatingRateIndex (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    indexTenor Period (1..2)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The ISDA Designated Maturity, i.e. the tenor of the floating rate. A FRA can contain either one or two indexTenor instances."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The ISDA Designated Maturity, i.e. the tenor of the floating rate. A FRA can contain either one or two indexTenor instances."]
    fraDiscounting FraDiscountingEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies whether discounting applies and, if so, what type."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies whether discounting applies and, if so, what type."]
    additionalPayment Payment (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Additional payments between the principal parties (i.e. the parties referenced as the FRA buyer and seller)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Additional payments between the principal parties (i.e. the parties referenced as the FRA buyer and seller)."]

type InflationRateCalculation extends InflationRateCalculationBase:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining the components specifiying an Inflation Rate Calculation"]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining the components specifiying an Inflation Rate Calculation"]

    inflationLag Offset (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "an offsetting period from the payment date which determines the reference period for which the inflation index is onserved."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "an offsetting period from the payment date which determines the reference period for which the inflation index is onserved."]
    indexSource RateSourcePage (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The reference source such as Reuters or Bloomberg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The reference source such as Reuters or Bloomberg."]
    mainPublication MainPublication (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The current main publication source such as relevant web site or a government body."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The current main publication source such as relevant web site or a government body."]
    interpolationMethod InterpolationMethod (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The method used when calculating the Inflation Index Level from multiple points - the most common is Linear."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The method used when calculating the Inflation Index Level from multiple points - the most common is Linear."]
    initialIndexLevel number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "initial known index level for the first calculation period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "initial known index level for the first calculation period."]
    fallbackBondApplicable boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The applicability of a fallback bond as defined in the 2006 ISDA Inflation Derivatives Definitions, sections 1.3 and 1.8."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The applicability of a fallback bond as defined in the 2006 ISDA Inflation Derivatives Definitions, sections 1.3 and 1.8."]
    calculationMethod InflationCalculationMethodEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates how to use the inflation index to calculate the payment (e.g. Ratio, Return, Spread). Added for Inflation Asset Swap"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates how to use the inflation index to calculate the payment (e.g. Ratio, Return, Spread). Added for Inflation Asset Swap"]
    calculationStyle InflationCalculationStyleEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates the style of how the inflation index calculates the payment (e.g. YearOnYear, ZeroCoupon)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates the style of how the inflation index calculates the payment (e.g. YearOnYear, ZeroCoupon)."]
    finalPrincipalExchangeCalculation FinalPrincipalExchangeCalculation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "To be specified only for inflation products that embed a redemption payment, e.g. inflation linked asset swap."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "To be specified only for inflation products that embed a redemption payment, e.g. inflation linked asset swap."]

type ReturnCalculation extends Rate:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining the floating rate and definitions relating to the Return Calculation"]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining the floating rate and definitions relating to the Return Calculation"]

    underlyer Underlyer (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The underlyer"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The underlyer"]
    settlementType SettlementTypeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The settlement type"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The settlement type"]
    finalValuation QuotationCharacteristics (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The final valuation"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The final valuation"]
    inflationRate InflationRate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    initialPrice ActualPrice (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type Swap extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining swap streams and additional payments between the principal parties involved in the swap."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining swap streams and additional payments between the principal parties involved in the swap."]

    swapStream InterestRateStream (1..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The swap streams."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The swap streams."]
    earlyTerminationProvision EarlyTerminationProvision (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Parameters specifying provisions relating to the optional and mandatory early terminarion of a swap transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Parameters specifying provisions relating to the optional and mandatory early terminarion of a swap transaction."]
    cancelableProvision CancelableProvision (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A provision that allows the specification of an embedded option within a swap giving the buyer of the option the right to terminate the swap, in whole or in part, on the early termination date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A provision that allows the specification of an embedded option within a swap giving the buyer of the option the right to terminate the swap, in whole or in part, on the early termination date."]
    extendibleProvision ExtendibleProvision (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A provision that allows the specification of an embedded option with a swap giving the buyer of the option the right to extend the swap, in whole or in part, to the extended termination date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A provision that allows the specification of an embedded option with a swap giving the buyer of the option the right to extend the swap, in whole or in part, to the extended termination date."]
    additionalPayment Payment (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Additional payments between the principal parties."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Additional payments between the principal parties."]
    additionalTerms SwapAdditionalTerms (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Contains any additional terms to the swap contract."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Contains any additional terms to the swap contract."]

type Swaption extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type to define an option on a swap."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type to define an option on a swap."]

    buyerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
    buyerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that buys this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that buys this instrument."]
    sellerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
    sellerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that sells this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that sells this instrument."]
    premium Payment (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The option premium amount payable by buyer to seller on the specified payment date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The option premium amount payable by buyer to seller on the specified payment date."]
    optionType SwaptionTypeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The type of option transaction. From a usage standpoint, put/call is the default option type, while payer/receiver indicator is used for options index credit default swaps, consistently with the industry practice. Straddle is used for the case of straddle strategy, that combine a call and a put with the same strike. This element is needed for transparency reporting because the counterparties are not available, and is made available in other views for convenience; it is not intended to be used for confirmation processing. If the swaption straddle indicator is provided, this must not be in conflict with that indicator."]
    exercise Exercise (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseProcedure ExerciseProcedure (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A set of parameters defining procedures associated with the exercise."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A set of parameters defining procedures associated with the exercise."]
    calculationAgent CalculationAgent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The ISDA Calculation Agent responsible for performing duties associated with an optional early termination."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The ISDA Calculation Agent responsible for performing duties associated with an optional early termination."]
    cashSettlement CashSettlement (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If specified, this means that cash settlement is applicable to the transaction and defines the parameters associated with the cash settlement procedure. If not specified, then physical settlement is applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If specified, this means that cash settlement is applicable to the transaction and defines the parameters associated with the cash settlement procedure. If not specified, then physical settlement is applicable."]
    physicalSettlement SwaptionPhysicalSettlement (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If specified, this defines physical settlement terms which apply to the transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If specified, this defines physical settlement terms which apply to the transaction."]
    swaptionStraddle boolean (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Whether the option is a swaption or a swaption straddle."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Whether the option is a swaption or a swaption straddle."]
    earlyTerminationProvision EarlyTerminationProvision (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Parameters specifying provisions relating to the optional and mandatory early terminarion of a swap transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Parameters specifying provisions relating to the optional and mandatory early terminarion of a swap transaction."]
    swaptionAdjustedDates SwaptionAdjustedDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The adjusted dates associated with swaption exercise. These dates have been adjusted for any applicable business day convention."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The adjusted dates associated with swaption exercise. These dates have been adjusted for any applicable business day convention."]
    swap Swap (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

    condition Choice:
        optional choice cashSettlement, physicalSettlement

type BondReference:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type including a reference to a bond to support the representation of an asset swap or Condition Precedent Bond."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type including a reference to a bond to support the representation of an asset swap or Condition Precedent Bond."]

    bond Bond (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to a bond underlyer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to a bond underlyer."]
    conditionPrecedentBond boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "To indicate whether the Condition Precedent Bond is applicable. The swap contract is only valid if the bond is issued and if there is any dispute over the terms of fixed stream then the bond terms would be used."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "To indicate whether the Condition Precedent Bond is applicable. The swap contract is only valid if the bond is issued and if there is any dispute over the terms of fixed stream then the bond terms would be used."]
    discrepancyClause boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "To indicate whether the Discrepancy Clause is applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "To indicate whether the Discrepancy Clause is applicable."]

type Calculation:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type definining the parameters used in the calculation of fixed or floating calculation period amounts."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type definining the parameters used in the calculation of fixed or floating calculation period amounts."]

    notionalSchedule Notional (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The notional amount or notional amount schedule. Some reporting implementations may place the current notional in the \"initialValue\" element of the schedule for historical convenience. In the future the \"currentNotional\" element should be used for this purpose."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The notional amount or notional amount schedule."]
    fxLinkedNotionalSchedule FxLinkedNotionalSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A notional amount schedule where each notional that applied to a calculation period is calculated with reference to a notional amount or notional amount schedule in a different currency by means of a spot currency exchange rate which is normally observed at the beginning of each period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A notional amount schedule where each notional that applied to a calculation period is calculated with reference to a notional amount or notional amount schedule in a different currency by means of a spot currency exchange rate which is normally observed at the beginning of each period."]
    currentNotional Money (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The notional in effect on the as-of date."]
    fixedRateSchedule Schedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The fixed rate or fixed rate schedule expressed as explicit fixed rates and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The fixed rate or fixed rate schedule expressed as explicit fixed rates and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments."]
    futureValueNotional FutureValueAmount (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The future value notional is normally only required for BRL CDI Swaps. The value is calculated as follows: Future Value Notional = Notional Amount * (1 + Fixed Rate) ^ (Fixed Rate Day Count Fraction). The currency should always match that expressed in the notional schedule. The value date should match the adjusted termination date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The future value notional is normally only required for BRL CDI Swaps. The value is calculated as follows: Future Value Notional = Notional Amount * (1 + Fixed Rate) ^ (Fixed Rate Day Count Fraction). The currency should always match that expressed in the notional schedule. The value date should match the adjusted termination date."]
    rateCalculation Rate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This element is the head of a substitution group. It is substituted by the floatingRateCalculation element for standard Floating Rate legs, or the inflationRateCalculation element for inflation swaps."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This element is the head of a substitution group. It is substituted by the floatingRateCalculation element for standard Floating Rate legs, or the inflationRateCalculation element for inflation swaps."]
    dayCountFraction DayCountFraction (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The day count fraction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The day count fraction."]
    discounting Discounting (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The parameters specifying any discounting conventions that may apply. This element must only be included if discounting applies."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The parameters specifying any discounting conventions that may apply. This element must only be included if discounting applies."]
    compoundingMethod CompoundingMethodEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If more that one calculation period contributes to a single payment amount this element specifies whether compounding is applicable, and if so, what compounding method is to be used. This element must only be included when more that one calculation period contributes to a single payment amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If more that one calculation period contributes to a single payment amount this element specifies whether compounding is applicable, and if so, what compounding method is to be used. This element must only be included when more that one calculation period contributes to a single payment amount."]

    condition Choice:
        if fixedRateSchedule exists
        then rateCalculation is absent
        else fixedRateSchedule is absent and futureValueNotional is absent

type CalculationPeriod:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining the parameters used in the calculation of a fixed or floating rate calculation period amount. This type forms part of cashflows representation of a swap stream."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining the parameters used in the calculation of a fixed or floating rate calculation period amount. This type forms part of cashflows representation of a swap stream."]

    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    unadjustedStartDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    unadjustedEndDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    adjustedStartDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The calculation period start date, adjusted according to any relevant business day convention."]
        [docReference ISDA FPML version "confirmation-5.13"
