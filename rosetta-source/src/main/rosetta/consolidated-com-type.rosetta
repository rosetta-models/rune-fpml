    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining the Weather Index Level or Weather Index Strike Level."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining the Weather Index Level or Weather Index Strike Level."]

    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    quantity number (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This is the Reference Level. The CDD, HDD or HDD Reference Level is specified as the number of (amount of) Weather Index Units specified by the parties in the related Confirmation."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This is the Reference Level. The CDD, HDD or HDD Reference Level is specified as the number of (amount of) Weather Index Units specified by the parties in the related Confirmation."]
    unit QuantityUnit (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Weather Index Unit derived from one of the following variable methods of determination: Cooling Degree Day (CDD), Heating Degree Day (HDD), Critical Precipitation Day (CPD) as defined in Section 11.15 of the 2005 ISDA Commodity Definitions and User Guide."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Weather Index Unit derived from one of the following variable methods of determination: Cooling Degree Day (CDD), Heating Degree Day (HDD), Critical Precipitation Day (CPD) as defined in Section 11.15 of the 2005 ISDA Commodity Definitions and User Guide."]

type WeatherIndexData:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    referenceLevel ReferenceLevel (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference level is the number of degree-days (in the case of HDD and CDD) or inches/millimeters (in the case of CPD) on which the differential is calculated. In the case of HDD it is the number of degree-days below this reference level. In the case of CDD it is the number of degree days above this reference level. In the case of CPD it is number of inches/millimeters above this reference level."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference level is the number of degree-days (in the case of HDD and CDD) or inches/millimeters (in the case of CPD) on which the differential is calculated. In the case of HDD it is the number of degree-days below this reference level. In the case of CDD it is the number of degree days above this reference level. In the case of CPD it is number of inches/millimeters above this reference level."]
    dataProvider DataProvider (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The provider of either temperature data or precipitation data specified by the parties in the related Confirmation."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The provider of either temperature data or precipitation data specified by the parties in the related Confirmation."]
    finalEditedData boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If specified by the parties to apply in the related Confirmation, Final Edited Data means that the parties will have recourse to Primary Disruption Fallbacks even if relevant data is available from the Data Provider, so long as such data is not published in its final edited form. Otherwise the parties will have recourse to Primary Disruption Fallbacks only if relevant data is unavailable from the Data Provider on a relevant day."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If specified by the parties to apply in the related Confirmation, Final Edited Data means that the parties will have recourse to Primary Disruption Fallbacks even if relevant data is available from the Data Provider, so long as such data is not published in its final edited form. Otherwise the parties will have recourse to Primary Disruption Fallbacks only if relevant data is unavailable from the Data Provider on a relevant day."]
    weatherStation WeatherStation (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The source or sources of weather index data specified by the parties in the related Confirmation. Examples include: AU-CBM (the Commonwealth Bureau of Meteorology in Australia) and CM-SMI (the Swiss Meteorological Institute)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The source or sources of weather index data specified by the parties in the related Confirmation. Examples include: AU-CBM (the Commonwealth Bureau of Meteorology in Australia) and CM-SMI (the Swiss Meteorological Institute)."]
    weatherStationFallback WeatherStation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If weather index data is not available for the weather station specified by the parties in the related Confirmation, the first alternative Weather Index Station."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If weather index data is not available for the weather station specified by the parties in the related Confirmation, the first alternative Weather Index Station."]
    weatherStationSecondFallback WeatherStation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If weather index data is neither available for the weather station specified by the parties in the related Confirmation nor the first alternative Weather Index Station, the second alternative Weather Index Station."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If weather index data is neither available for the weather station specified by the parties in the related Confirmation nor the first alternative Weather Index Station, the second alternative Weather Index Station."]
    alternativeDataProvider boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A provider of either temperature data or precipitation data specified by the parties in the related Confirmation. If the parties fail to specify an Alternative Data Provider, the \"Fallback Data\" Disruption Fallback will not apply."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A provider of either temperature data or precipitation data specified by the parties in the related Confirmation. If the parties fail to specify an Alternative Data Provider, the \"Fallback Data\" Disruption Fallback will not apply."]
    synopticDataFallback boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If the parties specify \"Not Applicable\", the \"Synoptic Data\" Disruption Fallback will not apply. Synoptic Data means that maximum and/or minimum temperature or daily precipitation at the location for the Missing Data Day will be the maxium and/or minimum temperature or daily precipitation for that day at the Location (Weather Index Station) which has not been subject to ultimate quality control, integrity or verification process."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If the parties specify \"Not Applicable\", the \"Synoptic Data\" Disruption Fallback will not apply. Synoptic Data means that maximum and/or minimum temperature or daily precipitation at the location for the Missing Data Day will be the maxium and/or minimum temperature or daily precipitation for that day at the Location (Weather Index Station) which has not been subject to ultimate quality control, integrity or verification process."]
    adjustmentToFallbackWeatherStation boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Weather Index Station from which data with which to apply the \"Adjustement to Fallback Station Data\" terms. See Section 11.20 of the 2005 ISDA Commodity Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Weather Index Station from which data with which to apply the \"Adjustement to Fallback Station Data\" terms. See Section 11.20 of the 2005 ISDA Commodity Definitions."]
    primaryDisruptionFallbacks DisruptionFallback (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A list of actions available to the parties should a Primary Disruption Event occur. A Primary Disruption Event means if maximum or minimum temperature or precipitation data for a Missing Data Day is required to determine a Payment Amount then the maximum and/or minimum temperature or the daily precipitation for that day will be determined in accordance with the first applicable Primary Disruption Fallback."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A list of actions available to the parties should a Primary Disruption Event occur. A Primary Disruption Event means if maximum or minimum temperature or precipitation data for a Missing Data Day is required to determine a Payment Amount then the maximum and/or minimum temperature or the daily precipitation for that day will be determined in accordance with the first applicable Primary Disruption Fallback."]
    secondaryDisruptionFallbacks DisruptionFallback (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A list of actions available to the parties should a Secondary Disruption Event occur. A Primary Disruption Event means if maximum or minimum temperature or precipitation data for a Missing Data Day is required to determine a Payment Amount then the maximum and/or minimum temperature or the daily precipitation for that day will be determined in accordance with the first applicable Secondary Disruption Fallback."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A list of actions available to the parties should a Secondary Disruption Event occur. A Primary Disruption Event means if maximum or minimum temperature or precipitation data for a Missing Data Day is required to determine a Payment Amount then the maximum and/or minimum temperature or the daily precipitation for that day will be determined in accordance with the first applicable Secondary Disruption Fallback."]

type WeatherLeg extends FinancialSwapLeg:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A weather leg of a Commodity Swap defines Weather Index Swap transactions. Weather Index Swap transactions are OTC derivative transactions which settle financially based on an index calculated from observations of temperature, precipitation and other weather-related measurements at weather stations throughout the world. Sub-Annex C of the 2005 ISDA Commodity Definitions provides definitions and terms for a number of types of weather indices. These indices include: HDD (heating degree days), CDD (cooling degree days), CPD (critical precipitation days). Weather Index Swap transactions result in a cash flow to one of the two counterparties each Calculation Period depending on the relationship between the Settlement Level and the Weather Index Level. A Weather Index swap transaction always consists of a commodity swap element as a parent to two weatherLeg elements."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A weather leg of a Commodity Swap defines Weather Index Swap transactions. Weather Index Swap transactions are OTC derivative transactions which settle financially based on an index calculated from observations of temperature, precipitation and other weather-related measurements at weather stations throughout the world. Sub-Annex C of the 2005 ISDA Commodity Definitions provides definitions and terms for a number of types of weather indices. These indices include: HDD (heating degree days), CDD (cooling degree days), CPD (critical precipitation days). Weather Index Swap transactions result in a cash flow to one of the two counterparties each Calculation Period depending on the relationship between the Settlement Level and the Weather Index Level. A Weather Index swap transaction always consists of a commodity swap element as a parent to two weatherLeg elements."]

    weatherIndexLevel WeatherIndex (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defining the Weather Index Level or Weather Index Strike Level."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defining the Weather Index Level or Weather Index Strike Level."]
    weatherCalculationPeriods WeatherCalculationPeriods (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    weatherCalculationPeriodsReference CalculationPeriodsReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    weatherNotionalAmount NonNegativeMoney (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the price per weather index unit."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the price per weather index unit."]
    calculation WeatherLegCalculation (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines details relevant to the calculation of the aggregate weather index amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines details relevant to the calculation of the aggregate weather index amount."]
    paymentDates CommodityRelativePaymentDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Payment Dates of the trade relative to the Calculation Periods or Calculation Date"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Payment Dates of the trade relative to the Calculation Periods or Calculation Date"]
    weatherIndexData WeatherIndexData (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies where the data (e.g. CPD) have been collected, an actual physical reference point (weather station) and various fall back arrangements."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies where the data (e.g. CPD) have been collected, an actual physical reference point (weather station) and various fall back arrangements."]

    condition Choice:
        required choice weatherCalculationPeriods, weatherCalculationPeriodsReference

type WeatherLegCalculation:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type to capture details of the calculation of the Payment Amount on a Weather Index Transaction."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type to capture details of the calculation of the Payment Amount on a Weather Index Transaction."]

    settlementLevel WeatherSettlementLevelEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Settlement Level means either the cumulative number of Weather Index Units for each day in the Calculation Period (Cumulative) or the cumulative number of Weather Index Units for each day in the Calculation Period divided by the number of days in the Calculation Period (Average) or the maximum number of Weather Index Units for any day in the Calculation Period (Maximum) or the minimum number of Weather Index Units for any day in the Calculation Period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Settlement Level means either the cumulative number of Weather Index Units for each day in the Calculation Period (Cumulative) or the cumulative number of Weather Index Units for each day in the Calculation Period divided by the number of days in the Calculation Period (Average) or the maximum number of Weather Index Units for any day in the Calculation Period (Maximum) or the minimum number of Weather Index Units for any day in the Calculation Period."]
    referenceLevelEqualsZero boolean (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If Reference Level Equals Zero is specified to be applicable then CPD means, for any day during the Calculation Period, (A) 1 if the Daily Precipitation for that day is greater than or equal to the CPD Reference Level or (B) zero if the the Daily Precipitation for that day is less than the CPD Reference Level. If Reference Level Equals Zero is specified not to be applicable then CPD means, for any day during the Calculation Period, (A) 1 if the Daily Precipitation for that day is greater than the CPD Reference Level or 0 if the Daily Precipitation for that day is less than or equal to the CPD Reference Level."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If Reference Level Equals Zero is specified to be applicable then CPD means, for any day during the Calculation Period, (A) 1 if the Daily Precipitation for that day is greater than or equal to the CPD Reference Level or (B) zero if the the Daily Precipitation for that day is less than the CPD Reference Level. If Reference Level Equals Zero is specified not to be applicable then CPD means, for any day during the Calculation Period, (A) 1 if the Daily Precipitation for that day is greater than the CPD Reference Level or 0 if the Daily Precipitation for that day is less than or equal to the CPD Reference Level."]
    calculationDate Period (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The number of days following the final day of the Calculation Period specified in the Confirmation on which is is practicable to provide the notice that the Calculation Agent is required to give for that Settlement Date or Payment Date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The number of days following the final day of the Calculation Period specified in the Confirmation on which is is practicable to provide the notice that the Calculation Agent is required to give for that Settlement Date or Payment Date."]
    businessDays BusinessCenter (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A day on which commmercial banks settle payments and are open for general business in the place(s) specified in the Confirmation. See Section 1.3 of the ISDA 2005 Commodity Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A day on which commmercial banks settle payments and are open for general business in the place(s) specified in the Confirmation. See Section 1.3 of the ISDA 2005 Commodity Definitions."]
    dataCorrection boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date payment often revised after its publication, this indicates if the payment date could be recalculated."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date payment often revised after its publication, this indicates if the payment date could be recalculated."]
    correctionPeriod Period (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If \'dataCorrection\'=true, this indicates how long after the initial publication of the data corrections can be made."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If \'dataCorrection\'=true, this indicates how long after the initial publication of the data corrections can be made."]
    maximumPaymentAmount NonNegativeMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The maximum total payment amount that will be paid in any particular transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The maximum total payment amount that will be paid in any particular transaction."]
    maximumTransactionPaymentAmount NonNegativeMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The maximum payment amount that will be paid in any particular Calculation Period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The maximum payment amount that will be paid in any particular Calculation Period."]
    rounding Rounding (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Rounding direction and precision for price values."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Rounding direction and precision for price values."]

