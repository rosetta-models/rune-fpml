            provision "The Calculation Periods for this leg of the swap. This type is only intended to be used if the Calculation Periods differ on each leg. If Calculation Periods mirror another leg, then the calculationPeriodsReference element should be used to point to the Calculation Periods on the other leg - or the calculationPeriodsScheduleReference can be used to point to the Calculation Periods Schedule for that leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Calculation Periods for this leg of the swap. This type is only intended to be used if the Calculation Periods differ on each leg. If Calculation Periods mirror another leg, then the calculationPeriodsReference element should be used to point to the Calculation Periods on the other leg - or the calculationPeriodsScheduleReference can be used to point to the Calculation Periods Schedule for that leg."]
    calculationPeriodsReference CalculationPeriodsReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to the Calculation Periods defined on another leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to the Calculation Periods defined on another leg."]
    calculationPeriodsScheduleReference CalculationPeriodsScheduleReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to the Calculation Periods Schedule defined on another leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to the Calculation Periods Schedule defined on another leg."]
    calculationPeriodsDatesReference CalculationPeriodsDatesReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to single-day-duration Calculation Periods defined on another leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to single-day-duration Calculation Periods defined on another leg."]
    commodity Commodity (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the underlying instrument. Only underlyers of type Commodity are supported."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the underlying instrument. Only underlyers of type Commodity are supported."]
    notionalQuantitySchedule CommodityNotionalQuantitySchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Allows the documentation of a shaped notional trade where the notional changes over the life of the transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Allows the documentation of a shaped notional trade where the notional changes over the life of the transaction."]
    notionalQuantity CommodityNotionalQuantity (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Notional Quantity."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Notional Quantity."]
    settlementPeriodsNotionalQuantity CommoditySettlementPeriodsNotionalQuantity (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "For an electricity transaction, the Notional Quantity for a one or more groups of Settlement Periods to which the Notional Quantity is based. If the schedule differs for different groups of Settlement Periods, this element should be repeated."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "For an electricity transaction, the Notional Quantity for a one or more groups of Settlement Periods to which the Notional Quantity is based. If the schedule differs for different groups of Settlement Periods, this element should be repeated."]
    totalNotionalQuantity number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Total Notional Quantity."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Total Notional Quantity."]
    quantityReference QuantityReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to a quantity defined on another leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a quantity defined on another leg."]
    calculation FloatingLegCalculation (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines details relevant to the calculation of the floating price."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines details relevant to the calculation of the floating price."]
    relativePaymentDates CommodityRelativePaymentDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Payment Dates of the trade relative to the Calculation Periods."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Payment Dates of the trade relative to the Calculation Periods."]
    paymentDates AdjustableDatesOrRelativeDateOffset (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Dates on which payments will be made."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Dates on which payments will be made."]
    masterAgreementPaymentDates boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If present and true indicates that the Payment Date(s) are specified in the relevant master agreement."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If present and true indicates that the Payment Date(s) are specified in the relevant master agreement."]
    flatRate FlatRateEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Whether the Flat Rate is the New Worldwide Tanker Nominal Freight Scale for the Freight Index Route taken at the Trade Date of the transaction or taken on each Pricing Date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Whether the Flat Rate is the New Worldwide Tanker Nominal Freight Scale for the Freight Index Route taken at the Trade Date of the transaction or taken on each Pricing Date."]
    flatRateAmount NonNegativeMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If flatRate is set to \"Fixed\", the actual value of the Flat Rate."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If flatRate is set to \"Fixed\", the actual value of the Flat Rate."]

    condition Choice0:
        required choice relativePaymentDates, paymentDates, masterAgreementPaymentDates

    condition Choice1:
        optional choice calculationDates, calculationPeriods, calculationPeriodsSchedule, calculationPeriodsReference, calculationPeriodsScheduleReference, calculationPeriodsDatesReference

    condition Choice2:
        optional choice notionalQuantitySchedule, notionalQuantity, settlementPeriodsNotionalQuantity, quantityReference

    condition Choice3:
        if quantityReference exists
        then totalNotionalQuantity is absent

    condition Choice4:
        if notionalQuantitySchedule is absent
                and notionalQuantity is absent
                and settlementPeriodsNotionalQuantity is absent
                and quantityReference is absent
        then totalNotionalQuantity exists

    condition Choice5:
        if quantityReference is absent
                and totalNotionalQuantity is absent
                and required choice notionalQuantitySchedule, notionalQuantity, settlementPeriodsNotionalQuantity
        then calculationPeriods exists
                or calculationDates exists
                or calculationPeriodsSchedule exists
                or calculationPeriodsReference exists
                or calculationPeriodsScheduleReference exists
                or calculationPeriodsDatesReference exists

