namespace fpml.consolidated.com : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*
import fpml.consolidated.asset.*
import fpml.consolidated.fpmlenum.*
import fpml.consolidated.option.shared.*
import fpml.consolidated.shared.*

type BullionPhysicalLeg extends PhysicalForwardLeg:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Physically settled leg of a physically settled Bullion Transaction."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Physically settled leg of a physically settled Bullion Transaction."]

    bullionType BullionTypeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The type of Bullion underlying a Bullion Transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The type of Bullion underlying a Bullion Transaction."]
    deliveryLocation BullionDeliveryLocation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The physical delivery location for the transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The physical delivery location for the transaction."]
    physicalQuantity CommodityNotionalQuantity (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Quantity per Delivery Period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Quantity per Delivery Period."]
    physicalQuantitySchedule CommodityPhysicalQuantitySchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Allows the documentation of a shaped quantity trade where the quantity changes over the life of the transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Allows the documentation of a shaped quantity trade where the quantity changes over the life of the transaction."]
    totalPhysicalQuantity UnitQuantity (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Total Quantity of the commodity to be delivered."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Total Quantity of the commodity to be delivered."]
    settlementDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Date on which the bullion will settle."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which the bullion will settle."]

    condition Choice:
        optional choice physicalQuantity, physicalQuantitySchedule

type CoalPhysicalLeg extends PhysicalSwapLeg:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Physically settled leg of a physically settled coal transaction."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Physically settled leg of a physically settled coal transaction."]

    deliveryPeriods CommodityDeliveryPeriods (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The period during which delivery/deliveries of Coal Products may be scheduled. Equivalent to Nomination Period(s) for US Coal."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The period during which delivery/deliveries of Coal Products may be scheduled. Equivalent to Nomination Period(s) for US Coal."]
    coal CoalProduct (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The specification of the Coal Product to be delivered."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The specification of the Coal Product to be delivered."]
    deliveryConditions CoalDelivery (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The physical delivery conditions for the transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The physical delivery conditions for the transaction."]
    deliveryQuantity CommodityPhysicalQuantity (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The different options for specifying the quantity."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The different options for specifying the quantity."]

type CommodityBasketOption extends fpml.consolidated.option.shared.Option:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Defines a commodity basket option product."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Defines a commodity basket option product."]

    optionType PutCallEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The type of option transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The type of option transaction."]
    effectiveDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The effective date of the Commodity Option Transaction. Note that the Termination/Expiration Date should be specified in expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type, as applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The effective date of the Commodity Option Transaction. Note that the Termination/Expiration Date should be specified in expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type, as applicable."]
    terminationDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the termination date of the Commodity Option Transaction. In some confirmations this will be indicated as the second date in \"Option Term\" or \"Term\". Note: If provided, terminationDate should not be before specified expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the termination date of the Commodity Option Transaction. In some confirmations this will be indicated as the second date in \"Option Term\" or \"Term\". Note: If provided, terminationDate should not be before specified expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type."]
    calculationPeriodsSchedule CommodityCalculationPeriodsSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A parametric representation of the Calculation Periods of the Commodity Option Transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A parametric representation of the Calculation Periods of the Commodity Option Transaction."]
    calculationPeriods AdjustableDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "An absolute representation of the Calculation Period start dates of the Commodity Option Transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "An absolute representation of the Calculation Period start dates of the Commodity Option Transaction."]
    notionalQuantityBasket CommodityBasketByNotional (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    notionalAmountBasket CommodityBasketByPercentage (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    strikePriceUnderlyingReference StrikePriceUnderlyingReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    strikePriceBasketReference StrikePriceBasketReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    strikePricePerUnit NonNegativeMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The currency amount of the strike price per unit."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The currency amount of the strike price per unit."]
    strikePricePerUnitSchedule CommodityStrikeSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    floatingStrikePricePerUnit FloatingStrikePrice (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The currency amount of the strike price per unit."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The currency amount of the strike price per unit."]
    floatingStrikePricePerUnitSchedule CommodityCalculationPeriodsSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exercise CommodityExerciseBasket (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The parameters for defining how the commodity option can be exercised and how it is settled."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The parameters for defining how the commodity option can be exercised and how it is settled."]
    premium CommodityPremium (1..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The option premium payable by the buyer to the seller."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The option premium payable by the buyer to the seller."]
    commonPricing boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If Common Pricing is elected (“true”) for a Transaction with referencing more than one Commodity Reference Price then no date will be a Pricing Date unless such a date is a day on which all Commodity Reference Prices are scheduled to be published."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If Common Pricing is elected (“true”) for a Transaction with referencing more than one Commodity Reference Price then no date will be a Pricing Date unless such a date is a day on which all Commodity Reference Prices are scheduled to be published."]
    marketDisruption CommodityMarketDisruption (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Contains contract terms related to triggers and responses to market disruptions as defined in the 1993 or 2005 Commodity Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Contains contract terms related to triggers and responses to market disruptions as defined in the 1993 or 2005 Commodity Definitions."]
    settlementDisruption CommodityBullionSettlementDisruptionEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Describes contract terms related to the consequences of Bullion Settlement Disruption Events."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Describes contract terms related to the consequences of Bullion Settlement Disruption Events."]
    rounding Rounding (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Rounding direction and precision for amounts."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Rounding direction and precision for amounts."]

    condition Choice0:
        optional choice calculationPeriodsSchedule, calculationPeriods

    condition Choice1:
        required choice notionalQuantityBasket, notionalAmountBasket

    condition Choice2:
        required choice strikePricePerUnit, strikePricePerUnitSchedule, floatingStrikePricePerUnit, floatingStrikePricePerUnitSchedule

    condition Choice3:
        optional choice strikePriceUnderlyingReference, strikePriceBasketReference

type CommodityDigitalOption extends fpml.consolidated.option.shared.Option:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Defines the digital commodity option product type. Digital options exercise when a barrier is breached and are financially settled. The \'commodityDigitalOption\' type is an extension of the \'commodityOption\' product."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Defines the digital commodity option product type. Digital options exercise when a barrier is breached and are financially settled. The \'commodityDigitalOption\' type is an extension of the \'commodityOption\' product."]

    optionType PutCallEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The type of option transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The type of option transaction."]
    commodity Commodity (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the underlying instrument. Usual content is an ISDA Commodity Reference Price Name. The \'commodity\' underlyer component is specified using a reference to the \'commodity\' asset (see description above at the Commodity Underlyer section)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the underlying instrument. Usual content is an ISDA Commodity Reference Price Name. The \'commodity\' underlyer component is specified using a reference to the \'commodity\' asset (see description above at the Commodity Underlyer section)."]
    effectiveDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The effective date of the Commodity Option Transaction. Note that the Termination/Expiration Date should be specified in expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type, as applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The effective date of the Commodity Option Transaction. Note that the Termination/Expiration Date should be specified in expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type, as applicable."]
    terminationDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the termination date of the Commodity Option Transaction. In some confirmations this will be indicated as the second date in \"Option Term\" or \"Term\". Note: If provided, terminationDate should not be before specified expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the termination date of the Commodity Option Transaction. In some confirmations this will be indicated as the second date in \"Option Term\" or \"Term\". Note: If provided, terminationDate should not be before specified expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type."]
    calculationPeriodsSchedule CommodityCalculationPeriodsSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A parametric representation of the Calculation Periods of the Commodity Option Transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A parametric representation of the Calculation Periods of the Commodity Option Transaction."]
    calculationPeriods AdjustableDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "An absolute representation of the Calculation Period start dates of the Commodity Option Transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "An absolute representation of the Calculation Period start dates of the Commodity Option Transaction."]
    pricingDates CommodityPricingDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The dates on which the option will price."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The dates on which the option will price."]
    averagingMethod AveragingMethodEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Method of Averaging if there is more than one Pricing Date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Method of Averaging if there is more than one Pricing Date."]
    digital CommodityDigital (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The barrier and cash payout features of the digital option."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The barrier and cash payout features of the digital option."]
    notionalAmount NotionalAmount (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Volume contracted when volume is specified as a currency-denominated amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Volume contracted when volume is specified as a currency-denominated amount."]
    notionalQuantity CommodityNotionalQuantity (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The volume contracted when the volume is specified as a quantity of commodity."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The volume contracted when the volume is specified as a quantity of commodity."]
    totalNotionalQuantity number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exercise CommodityDigitalExercise (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The parameters for defining how the commodity option can be exercised and how it is settled."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The parameters for defining how the commodity option can be exercised and how it is settled."]
    premium CommodityPremium (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The option premium payable by the buyer to the seller."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The option premium payable by the buyer to the seller."]
    commonPricing boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If Common Pricing is elected (“true”) for a Transaction with referencing more than one Commodity Reference Price then no date will be a Pricing Date unless such a date is a day on which all Commodity Reference Prices are scheduled to be published."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If Common Pricing is elected (“true”) for a Transaction with referencing more than one Commodity Reference Price then no date will be a Pricing Date unless such a date is a day on which all Commodity Reference Prices are scheduled to be published."]
    marketDisruption CommodityMarketDisruption (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Contains contract terms related to triggers and responses to market disruptions as defined in the 1993 or 2005 Commodity Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Contains contract terms related to triggers and responses to market disruptions as defined in the 1993 or 2005 Commodity Definitions."]
    settlementDisruption CommodityBullionSettlementDisruptionEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Describes contract terms related to the consequences of Bullion Settlement Disruption Events."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Describes contract terms related to the consequences of Bullion Settlement Disruption Events."]
    rounding Rounding (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Rounding direction and precision for amounts."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Rounding direction and precision for amounts."]

    condition Choice0:
        optional choice calculationPeriodsSchedule, calculationPeriods

    condition Choice1:
        if notionalAmount exists
        then notionalQuantity is absent and totalNotionalQuantity is absent
        else notionalQuantity exists or totalNotionalQuantity exists

type CommodityForward extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Commodity Forward"]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Commodity Forward"]

    valueDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the value date of the Commodity Forward Transaction. This is the day on which both the cash and the physical commodity settle."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the value date of the Commodity Forward Transaction. This is the day on which both the cash and the physical commodity settle."]
    fixedLeg NonPeriodicFixedPriceLeg (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The fixed leg of a Commodity Forward Transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The fixed leg of a Commodity Forward Transaction."]
    averagePriceLeg AveragePriceLeg (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the calculated floating price leg of a Commodity Forward Transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the calculated floating price leg of a Commodity Forward Transaction."]
    physicalCommodityForwardLeg PhysicalLegBase (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    commonPricing boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If Common Pricing is elected (“true”) for a Transaction with referencing more than one Commodity Reference Price then no date will be a Pricing Date unless such a date is a day on which all Commodity Reference Prices are scheduled to be published."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If Common Pricing is elected (“true”) for a Transaction with referencing more than one Commodity Reference Price then no date will be a Pricing Date unless such a date is a day on which all Commodity Reference Prices are scheduled to be published."]
    marketDisruption CommodityMarketDisruption (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Contains contract terms related to triggers and responses to market disruptions as defined in the 1993 or 2005 Commodity Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Contains contract terms related to triggers and responses to market disruptions as defined in the 1993 or 2005 Commodity Definitions."]
    settlementDisruption CommodityBullionSettlementDisruptionEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Describes contract terms related to the consequences of Bullion Settlement Disruption Events."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Describes contract terms related to the consequences of Bullion Settlement Disruption Events."]
    rounding Rounding (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Rounding direction and precision for amounts."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Rounding direction and precision for amounts."]

    condition Choice:
        optional choice fixedLeg, averagePriceLeg

type CommodityInterestLeg extends CommodityPerformanceSwapLeg:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing the interest rate leg (a.k.a fee leg) of the commodity performance swap."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing the interest rate leg (a.k.a fee leg) of the commodity performance swap."]

    calculationDates AdjustableDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Calculation Period dates for this leg of the trade where the Calculation Periods are all one day long. Only dates explicitly included determine the Calculation Periods and there is a Calculation Period for each date specified. As such one-day Calculation Period are typical a physically-settled emissions or metals trades it is expected that this element will not be used in performance swaps."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Calculation Period dates for this leg of the trade where the Calculation Periods are all one day long. Only dates explicitly included determine the Calculation Periods and there is a Calculation Period for each date specified. As such one-day Calculation Period are typical a physically-settled emissions or metals trades it is expected that this element will not be used in performance swaps."]
    calculationPeriods AdjustableDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Calculation Period start dates for this leg of the swap. This type is only intended to be used if the Calculation Periods differ on each leg. If Calculation Periods mirror another leg, then the calculationPeriodsReference element should be used to point to the Calculation Periods on that leg - or the calculationPeriodsScheduleReference can be used to point to the Calculation Periods Schedule for that leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Calculation Period start dates for this leg of the swap. This type is only intended to be used if the Calculation Periods differ on each leg. If Calculation Periods mirror another leg, then the calculationPeriodsReference element should be used to point to the Calculation Periods on that leg - or the calculationPeriodsScheduleReference can be used to point to the Calculation Periods Schedule for that leg."]
    calculationPeriodsSchedule CommodityCalculationPeriodsSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Calculation Periods for this leg of the swap. This type is only intended to be used if the Calculation Periods differ on each leg. If Calculation Periods mirror another leg, then the calculationPeriodsReference element should be used to point to the Calculation Periods on the other leg - or the calculationPeriodsScheduleReference can be used to point to the Calculation Periods Schedule for that leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Calculation Periods for this leg of the swap. This type is only intended to be used if the Calculation Periods differ on each leg. If Calculation Periods mirror another leg, then the calculationPeriodsReference element should be used to point to the Calculation Periods on the other leg - or the calculationPeriodsScheduleReference can be used to point to the Calculation Periods Schedule for that leg."]
    calculationPeriodsReference CalculationPeriodsReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to the Calculation Periods defined on another leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to the Calculation Periods defined on another leg."]
    calculationPeriodsScheduleReference CalculationPeriodsScheduleReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to the Calculation Periods Schedule defined on another leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to the Calculation Periods Schedule defined on another leg."]
    calculationPeriodsDatesReference CalculationPeriodsDatesReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to single-day-duration Calculation Periods defined on another leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to single-day-duration Calculation Periods defined on another leg."]
    relativePaymentDates CommodityRelativePaymentDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Payment Dates of the trade relative to the Calculation Periods."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Payment Dates of the trade relative to the Calculation Periods."]
    paymentDates AdjustableDatesOrRelativeDateOffset (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Dates on which payments will be made."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Dates on which payments will be made."]
    masterAgreementPaymentDates boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If present and true indicates that the Payment Date(s) are specified in the relevant master agreement."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If present and true indicates that the Payment Date(s) are specified in the relevant master agreement."]
    notionalAmount CommodityNotionalAmount (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the notional amount of a commodity performance type swap. It is a currency-denominated value (i.e. price-times-quantity). In confirmations is also referred to as the Notional Quantity (sic, expressed in currency units), Notional Amount, Equity Notional Amount and, in the case of reinvesting swaps, Initial Notional Amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the notional amount of a commodity performance type swap. It is a currency-denominated value (i.e. price-times-quantity). In confirmations is also referred to as the Notional Quantity (sic, expressed in currency units), Notional Amount, Equity Notional Amount and, in the case of reinvesting swaps, Initial Notional Amount."]
    notionalAmountReference CommodityNotionalAmountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the Return swap notional amount defined in another leg of the return swap."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the Return swap notional amount defined in another leg of the return swap."]
    commodityFixedInterestCalculation CommodityFixedInterestCalculation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the interest payment amount on a return swap. This amount may be referred to as the interest amount or the fee amount. Used when the interest (a.k.a. \"Fee\") is calculated very simply: notional amount * (rate * (number of days in Calculation Period / number of days assumed in the the year))."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the interest payment amount on a return swap. This amount may be referred to as the interest amount or the fee amount. Used when the interest (a.k.a. \"Fee\") is calculated very simply: notional amount * (rate * (number of days in Calculation Period / number of days assumed in the the year))."]

    condition Choice0:
        required choice relativePaymentDates, paymentDates, masterAgreementPaymentDates

    condition Choice1:
        optional choice calculationDates, calculationPeriods, calculationPeriodsSchedule, calculationPeriodsReference, calculationPeriodsScheduleReference, calculationPeriodsDatesReference

    condition Choice2:
        optional choice notionalAmount, notionalAmountReference

type CommodityOption extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Defines a commodity option product type. The product support for financially-settled exercises or exercise into physical forward contracts written on precious and non-precious metals. options in FpML is based on the creation of a \'commodityOption\' product. The product references the \'commodity\' underlyer in order to support the underlying asset of the option."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Defines a commodity option product type. The product support for financially-settled exercises or exercise into physical forward contracts written on precious and non-precious metals. options in FpML is based on the creation of a \'commodityOption\' product. The product references the \'commodity\' underlyer in order to support the underlying asset of the option."]

    buyerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
    buyerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that buys this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that buys this instrument."]
    sellerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
    sellerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that sells this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that sells this instrument."]
    optionType PutCallEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The type of option transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The type of option transaction."]
    commodity Commodity (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the underlying instrument. Usual content is an ISDA Commodity Reference Price Name. The \'commodity\' underlyer component is specified using a reference to the \'commodity\' asset (see description above at the Commodity Underlyer section)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the underlying instrument. Usual content is an ISDA Commodity Reference Price Name. The \'commodity\' underlyer component is specified using a reference to the \'commodity\' asset (see description above at the Commodity Underlyer section)."]
    effectiveDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The effective date of the Commodity Option Transaction. Note that the Termination/Expiration Date should be specified in expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type, as applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The effective date of the Commodity Option Transaction. Note that the Termination/Expiration Date should be specified in expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type, as applicable."]
    terminationDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the termination date of the Commodity Option Transaction. In some confirmations this will be indicated as the second date in \"Option Term\" or \"Term\". Note: If provided, terminationDate should not be before specified expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the termination date of the Commodity Option Transaction. In some confirmations this will be indicated as the second date in \"Option Term\" or \"Term\". Note: If provided, terminationDate should not be before specified expirationDate within the CommodityAmericanExercise type or the CommodityEuropeanExercise type."]
