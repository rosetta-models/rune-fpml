        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The first day(s) of the exercise period(s) for an American-style option where it is relative to the occurrence of an external event."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The first day(s) of the exercise period(s) for an American-style option where it is relative to the occurrence of an external event."]
    relativeExpirationDates CommodityRelativeExpirationDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
