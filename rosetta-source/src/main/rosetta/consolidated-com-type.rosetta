    [docReference ISDA FPML version "confirmation-5.13"]

    firm ElectricityDeliveryFirm (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates under what condtitions the Parties\' delivery obligations apply."]
        [docReference ISDA FPML version "confirmation-5.13"
