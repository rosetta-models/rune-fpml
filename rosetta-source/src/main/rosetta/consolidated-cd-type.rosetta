type ProtectionTermsReference extends fpml.consolidated.shared.Reference:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Reference to protectionTerms component."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Reference to protectionTerms component."]

