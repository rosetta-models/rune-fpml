type FloatingAmountEvents:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    failureToPayPrincipal boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A floating rate payment event. Corresponds to the failure by the Reference Entity to pay an expected principal amount or the payment of an actual principal amount that is less than the expected principal amount. ISDA 2003 Term: Failure to Pay Principal."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A floating rate payment event. Corresponds to the failure by the Reference Entity to pay an expected principal amount or the payment of an actual principal amount that is less than the expected principal amount. ISDA 2003 Term: Failure to Pay Principal."]
    interestShortfall InterestShortFall (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A floating rate payment event. With respect to any Reference Obligation Payment Date, either (a) the non-payment of an Expected Interest Amount or (b) the payment of an Actual Interest Amount that is less than the Expected Interest Amount. ISDA 2003 Term: Interest Shortfall."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A floating rate payment event. With respect to any Reference Obligation Payment Date, either (a) the non-payment of an Expected Interest Amount or (b) the payment of an Actual Interest Amount that is less than the Expected Interest Amount. ISDA 2003 Term: Interest Shortfall."]
    writedown boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A floating rate payment event. Results from the fact that the underlyer writes down its outstanding principal amount. ISDA 2003 Term: Writedown."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A floating rate payment event. Results from the fact that the underlyer writes down its outstanding principal amount. ISDA 2003 Term: Writedown."]
    impliedWritedown boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A floating rate payment event. Results from the fact that losses occur to the underlying instruments that do not result in reductions of the outstanding principal of the reference obligation."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A floating rate payment event. Results from the fact that losses occur to the underlying instruments that do not result in reductions of the outstanding principal of the reference obligation."]
    floatingAmountProvisions FloatingAmountProvisions (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the floating amount provisions associated with the floatingAmountEvents."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the floating amount provisions associated with the floatingAmountEvents."]
    additionalFixedPayments AdditionalFixedPayments (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the events that will give rise to the payment a additional fixed payments."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the events that will give rise to the payment a additional fixed payments."]

type FloatingAmountProvisions:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    wacCapInterestProvision boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "As specified by the ISDA Supplement for use with trades on mortgage-backed securities, \"WAC Cap\" means a weighted average coupon or weighted average rate cap provision (however defined in the Underlying Instruments) of the Underlying Instruments that limits, increases or decreases the interest rate or interest entitlement, as set out in the Underlying Instruments on the Effective Date without regard to any subsequent amendment The presence of the element with value set to \'true\' signifies that the provision is applicable. From a usage standpoint, this provision is typically applicable in the case of CMBS and not applicable in case of RMBS trades."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "As specified by the ISDA Supplement for use with trades on mortgage-backed securities, \"WAC Cap\" means a weighted average coupon or weighted average rate cap provision (however defined in the Underlying Instruments) of the Underlying Instruments that limits, increases or decreases the interest rate or interest entitlement, as set out in the Underlying Instruments on the Effective Date without regard to any subsequent amendment The presence of the element with value set to \'true\' signifies that the provision is applicable. From a usage standpoint, this provision is typically applicable in the case of CMBS and not applicable in case of RMBS trades."]
    stepUpProvision boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "As specified by the ISDA Standard Terms Supplement for use with trades on mortgage-backed securities. The presence of the element with value set to \'true\' signifies that the provision is applicable. If applicable, the applicable step-up terms are specified as part of that ISDA Standard Terms Supplement. From a usage standpoint, this provision is typically applicable in the case of RMBS and not applicable in case of CMBS trades."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "As specified by the ISDA Standard Terms Supplement for use with trades on mortgage-backed securities. The presence of the element with value set to \'true\' signifies that the provision is applicable. If applicable, the applicable step-up terms are specified as part of that ISDA Standard Terms Supplement. From a usage standpoint, this provision is typically applicable in the case of RMBS and not applicable in case of CMBS trades."]

type GeneralTerms:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    effectiveDate AdjustableDate2 (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The first day of the term of the trade. This day may be subject to adjustment in accordance with a business day convention. ISDA 2003 Term: Effective Date."]
        [docReference ISDA FPML version "confirmation-5.13"
