    loan Loan (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    primaryObligor LegalEntity (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The entity primarily responsible for repaying debt to a creditor as a result of borrowing or issuing bonds. ISDA 2003 Term: Primary Obligor"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The entity primarily responsible for repaying debt to a creditor as a result of borrowing or issuing bonds. ISDA 2003 Term: Primary Obligor"]
    primaryObligorReference LegalEntityReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to a reference entity defined elsewhere in the document. Used when the reference entity is the primary obligor."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a reference entity defined elsewhere in the document. Used when the reference entity is the primary obligor."]
    referenceObligationChoice ReferenceObligationChoice (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    standardReferenceObligation boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates if the reference obligation is a Standard Reference Obligation. ISDA 2014 Term: Standard Reference Obligation."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates if the reference obligation is a Standard Reference Obligation. ISDA 2014 Term: Standard Reference Obligation."]

    condition Choice0:
        required choice bond, convertibleBond, mortgage, loan

    condition Choice1:
        optional choice primaryObligor, primaryObligorReference

type ReferenceObligationChoice:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    guarantor LegalEntity (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The party that guarantees by way of a contractual arrangement to pay the debts of an obligor if the obligor is unable to make the required payments itself. ISDA 2003 Term: Guarantor"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The party that guarantees by way of a contractual arrangement to pay the debts of an obligor if the obligor is unable to make the required payments itself. ISDA 2003 Term: Guarantor"]
    guarantorReference LegalEntityReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to a reference entity defined elsewhere in the document. Used when the reference entity is the guarantor."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a reference entity defined elsewhere in the document. Used when the reference entity is the guarantor."]

    condition Choice:
        optional choice guarantor, guarantorReference

type ReferencePair:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    referenceEntity LegalEntity (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The corporate or sovereign entity on which you are buying or selling protection and any successor that assumes all or substantially all of its contractual and other obligations. It is vital to use the correct legal name of the entity and to be careful not to choose a subsidiary if you really want to trade protection on a parent company. Please note, Reference Entities cannot be senior or subordinated. It is the obligations of the Reference Entities that can be senior or subordinated. ISDA 2003 Term: Reference Entity"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The corporate or sovereign entity on which you are buying or selling protection and any successor that assumes all or substantially all of its contractual and other obligations. It is vital to use the correct legal name of the entity and to be careful not to choose a subsidiary if you really want to trade protection on a parent company. Please note, Reference Entities cannot be senior or subordinated. It is the obligations of the Reference Entities that can be senior or subordinated. ISDA 2003 Term: Reference Entity"]
    referenceObligation ReferenceObligation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Reference Obligation is a financial instrument that is either issued or guaranteed by the reference entity. It serves to clarify the precise reference entity protection is being offered upon, and its legal position with regard to other related firms (parents/subsidiaries). Furthermore the Reference Obligation is ALWAYS deliverable and establishes the Pari Passu ranking (as the deliverable bonds must rank equal to the reference obligation). ISDA 2003 Term: Reference Obligation"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Reference Obligation is a financial instrument that is either issued or guaranteed by the reference entity. It serves to clarify the precise reference entity protection is being offered upon, and its legal position with regard to other related firms (parents/subsidiaries). Furthermore the Reference Obligation is ALWAYS deliverable and establishes the Pari Passu ranking (as the deliverable bonds must rank equal to the reference obligation). ISDA 2003 Term: Reference Obligation"]
    noReferenceObligation boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Used to indicate that there is no Reference Obligation associated with this Credit Default Swap and that there will never be one."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Used to indicate that there is no Reference Obligation associated with this Credit Default Swap and that there will never be one."]
    entityType EntityType (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the reference entity types corresponding to a list of types in the ISDA First to Default documentation."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the reference entity types corresponding to a list of types in the ISDA First to Default documentation."]

    condition Choice:
        optional choice referenceObligation, noReferenceObligation

