        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates the original trade between the transferor and the remaining party."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates the original trade between the transferor and the remaining party."]
    feeTradeIdentifier PartyTradeIdentifier (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates a reference to the implied trade (the \"fee trade\") that the associated novation fee based on. This is equivalent to the new trade that is created by the novation (between the transferee and the remaining party), but is between the transferor and the transferee. A reference to the Fee Trade supports regulatory reporting of novations."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates a reference to the implied trade (the \"fee trade\") that the associated novation fee based on. This is equivalent to the new trade that is created by the novation (between the transferee and the remaining party), but is between the transferor and the transferee. A reference to the Fee Trade supports regulatory reporting of novations."]
    feeTrade Trade (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates the implied trade (the \"fee trade\") that the associated novation fee based on. This is equivalent to the new trade that is created by the novation (between the transferee and the remaining party), but is between the transferor and the transferee. Fee Trade supports regulatory reporting of novations."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates the implied trade (the \"fee trade\") that the associated novation fee based on. This is equivalent to the new trade that is created by the novation (between the transferee and the remaining party), but is between the transferor and the transferee. Fee Trade supports regulatory reporting of novations."]
    transferor PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to a party identifier defined elsewhere in the document. In a three-way novation the party referenced is the Transferor (outgoing party) in the novation. The Transferor means a party which transfers by novation to a Transferee all of its rights, liabilities, duties and obligations with respect to a Remaining Party. In a four-way novation the party referenced is Transferor 1 which transfers by novation to Transferee 1 all of its rights, liabilities, duties and obligations with respect to Transferor 2. ISDA 2004 Novation Term: Transferor (three-way novation) or Transferor 1 (four-way novation)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a party identifier defined elsewhere in the document. In a three-way novation the party referenced is the Transferor (outgoing party) in the novation. The Transferor means a party which transfers by novation to a Transferee all of its rights, liabilities, duties and obligations with respect to a Remaining Party. In a four-way novation the party referenced is Transferor 1 which transfers by novation to Transferee 1 all of its rights, liabilities, duties and obligations with respect to Transferor 2. ISDA 2004 Novation Term: Transferor (three-way novation) or Transferor 1 (four-way novation)."]
    transferorAccount AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    transferee PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to a party identifier defined elsewhere in the document. In a three-way novation the party referenced is the Transferee (incoming party) in the novation. Transferee means a party which accepts by way of novation all rights, liabilities, duties and obligations of a Transferor with respect to a Remaining Party. In a four-way novation the party referenced is Transferee 1 which accepts by way of novation the rights, liabilities, duties and obligations of Transferor 1. ISDA 2004 Novation Term: Transferee (three-way novation) or Transferee 1 (four-way novation)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a party identifier defined elsewhere in the document. In a three-way novation the party referenced is the Transferee (incoming party) in the novation. Transferee means a party which accepts by way of novation all rights, liabilities, duties and obligations of a Transferor with respect to a Remaining Party. In a four-way novation the party referenced is Transferee 1 which accepts by way of novation the rights, liabilities, duties and obligations of Transferor 1. ISDA 2004 Novation Term: Transferee (three-way novation) or Transferee 1 (four-way novation)."]
    otherTransferee PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to a party identifier defined elsewhere in the document. In a five-way novation the party referenced is the Transferee\'s legal entity that is involved in the settlement of the fee leg of the novation transaction (this might be a different legal entity than the one that assumes the novation trade). NB: this element has been added pending confirmation of the business need/context in which it would be used, and might not appear in a subsequent draft of this schema."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a party identifier defined elsewhere in the document. In a five-way novation the party referenced is the Transferee\'s legal entity that is involved in the settlement of the fee leg of the novation transaction (this might be a different legal entity than the one that assumes the novation trade). NB: this element has been added pending confirmation of the business need/context in which it would be used, and might not appear in a subsequent draft of this schema."]
    transfereeAccount AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    otherTransfereeAccount AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    remainingParty PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to a party identifier defined elsewhere in the document. In a three-way novation the party referenced is the Remaining Party in the novation. Remaining Party means a party which consents to a Transferor\'s transfer by novation and the acceptance thereof by the Transferee of all of the Transferor\'s rights, liabilities, duties and obligations with respect to such Remaining Party under and with respect of the Novated Amount of a transaction. In a four-way novation the party referenced is Transferor 2 per the ISDA definition and acts in the role of a Transferor. Transferor 2 transfers by novation to Transferee 2 all of its rights, liabilities, duties and obligations with respect to Transferor 1. ISDA 2004 Novation Term: Remaining Party (three-way novation) or Transferor 2 (four-way novation)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a party identifier defined elsewhere in the document. In a three-way novation the party referenced is the Remaining Party in the novation. Remaining Party means a party which consents to a Transferor\'s transfer by novation and the acceptance thereof by the Transferee of all of the Transferor\'s rights, liabilities, duties and obligations with respect to such Remaining Party under and with respect of the Novated Amount of a transaction. In a four-way novation the party referenced is Transferor 2 per the ISDA definition and acts in the role of a Transferor. Transferor 2 transfers by novation to Transferee 2 all of its rights, liabilities, duties and obligations with respect to Transferor 1. ISDA 2004 Novation Term: Remaining Party (three-way novation) or Transferor 2 (four-way novation)."]
    remainingPartyAccount AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    otherRemainingParty PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to a party identifier defined elsewhere in the document. This element is not applicable in a three-way novation and should be omitted. In a four-way novation the party referenced is Transferee 2. Transferee 2 means a party which accepts by way of novation the rights, liabilities, duties and obligations of Transferor 2. ISDA 2004 Novation Term: Transferee 2 (four-way novation)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a party identifier defined elsewhere in the document. This element is not applicable in a three-way novation and should be omitted. In a four-way novation the party referenced is Transferee 2. Transferee 2 means a party which accepts by way of novation the rights, liabilities, duties and obligations of Transferor 2. ISDA 2004 Novation Term: Transferee 2 (four-way novation)."]
    otherRemainingPartyAccount AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    novationDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the date that one party\'s legal obligations with regard to a trade are transferred to another party. It corresponds to the Novation Date section of the 2004 ISDA Novation Definitions, section 1.16."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the date that one party\'s legal obligations with regard to a trade are transferred to another party. It corresponds to the Novation Date section of the 2004 ISDA Novation Definitions, section 1.16."]
    executionDateTime ExecutionDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date and time at which the change was agreed."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date and time at which the change was agreed."]
    novationTradeDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the date the parties agree to assign or novate a Contract. If this element is not specified, the novationContractDate will be deemed to be the novationDate. It corresponds to the Novation Trade Date section of the 2004 ISDA Novation Definitions, section 1.17."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the date the parties agree to assign or novate a Contract. If this element is not specified, the novationContractDate will be deemed to be the novationDate. It corresponds to the Novation Trade Date section of the 2004 ISDA Novation Definitions, section 1.17."]
    novatedAmount Money (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The amount which represents the portion of the Old Contract being novated."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The amount which represents the portion of the Old Contract being novated."]
    remainingAmount Money (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The amount which represents the portion of the Old Contract not being novated."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The amount which represents the portion of the Old Contract not being novated."]
    novatedNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The number of options which represent the portion of the Old Contract being novated."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The number of options which represent the portion of the Old Contract being novated."]
    remainingNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The number of options which represent the portion of the Old Contract not being novated."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The number of options which represent the portion of the Old Contract not being novated."]
    novatedNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The number of options which represent the portion of the Old Contract being novated."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The number of options which represent the portion of the Old Contract being novated."]
    remainingNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The number of options which represent the portion of the Old Contract not being novated."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The number of options which represent the portion of the Old Contract not being novated."]
    novationAmount TradeLegSizeChange (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    fullFirstCalculationPeriod boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This element corresponds to the applicability of the Full First Calculation Period as defined in the 2004 ISDA Novation Definitions, section 1.20."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This element corresponds to the applicability of the Full First Calculation Period as defined in the 2004 ISDA Novation Definitions, section 1.20."]
    firstPeriodStartDate FirstPeriodStartDate (0..2)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Element that is used to be able to make sense of the “new transaction” without requiring reference back to the “old transaction”. In the case of interest rate products there are potentially 2 “first period start dates” to reference – one with respect to each party to the new transaction. For Credit Default Swaps there is just the one with respect to the party that is the fixed rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Element that is used to be able to make sense of the “new transaction” without requiring reference back to the “old transaction”. In the case of interest rate products there are potentially 2 “first period start dates” to reference – one with respect to each party to the new transaction. For Credit Default Swaps there is just the one with respect to the party that is the fixed rate payer."]
    nonReliance Empty (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This element corresponds to the non-Reliance section in the 2004 ISDA Novation Definitions, section 2.1 (c) (i). The element appears in the instance document when non-Reliance is applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This element corresponds to the non-Reliance section in the 2004 ISDA Novation Definitions, section 2.1 (c) (i). The element appears in the instance document when non-Reliance is applicable."]
    creditDerivativesNotices CreditDerivativesNotices (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This element should be specified if one or more of either a Credit Event Notice, Notice of Publicly Available Information, Notice of Physical Settlement or Notice of Intended Physical Settlement, as applicable, has been delivered by or to the Transferor or the Remaining Party. The type of notice or notices that have been delivered should be indicated by setting the relevant boolean element value(s) to true. The absence of the element means that no Credit Event Notice, Notice of Publicly Available Information, Notice of Physical Settlement or Notice of Intended Physical Settlement, as applicable, has been delivered by or to the Transferor or the Remaining Party."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This element should be specified if one or more of either a Credit Event Notice, Notice of Publicly Available Information, Notice of Physical Settlement or Notice of Intended Physical Settlement, as applicable, has been delivered by or to the Transferor or the Remaining Party. The type of notice or notices that have been delivered should be indicated by setting the relevant boolean element value(s) to true. The absence of the element means that no Credit Event Notice, Notice of Publicly Available Information, Notice of Physical Settlement or Notice of Intended Physical Settlement, as applicable, has been delivered by or to the Transferor or the Remaining Party."]
    contractualDefinitions ContractualDefinitions (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The definitions (such as those published by ISDA) that will define the terms of the novation transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The definitions (such as those published by ISDA) that will define the terms of the novation transaction."]
    contractualTermsSupplement ContractualTermsSupplement (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A contractual supplement (such as those published by ISDA) that will apply to the trade."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A contractual supplement (such as those published by ISDA) that will apply to the trade."]
    payment Payment (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Describes a payment made in settlement of the novation."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Describes a payment made in settlement of the novation."]

    condition Choice0:
        optional choice newTradeIdentifier, newTrade

    condition Choice1:
        optional choice novatedAmount, novatedNumberOfOptions, novatedNumberOfUnits, novationAmount

    condition Choice2:
        if novatedAmount exists
        then remainingNumberOfOptions is absent
                and remainingNumberOfUnits is absent
                and optional choice oldTradeIdentifier, oldTrade
                and if oldTradeIdentifier exists
                    then optional choice feeTradeIdentifier, feeTrade
                and if oldTrade exists
                    then optional choice feeTradeIdentifier, feeTrade
                and if oldTradeIdentifier is absent and oldTrade is absent
                    then optional choice feeTradeIdentifier, feeTrade

    condition Choice3:
        if novatedNumberOfOptions exists
        then remainingAmount is absent
                and remainingNumberOfUnits is absent
                and optional choice oldTradeIdentifier, oldTrade
                and if oldTradeIdentifier exists
                    then optional choice feeTradeIdentifier, feeTrade
                and if oldTrade exists
                    then optional choice feeTradeIdentifier, feeTrade
                and if oldTradeIdentifier is absent and oldTrade is absent
                    then optional choice feeTradeIdentifier, feeTrade

    condition Choice4:
        if novatedNumberOfUnits exists
        then remainingAmount is absent
                and remainingNumberOfOptions is absent
                and optional choice oldTradeIdentifier, oldTrade
                and if oldTradeIdentifier exists
                    then optional choice feeTradeIdentifier, feeTrade
                and if oldTrade exists
                    then optional choice feeTradeIdentifier, feeTrade
                and if oldTradeIdentifier is absent and oldTrade is absent
                    then optional choice feeTradeIdentifier, feeTrade

    condition Choice5:
        if novationAmount exists
        then remainingAmount is absent
                and remainingNumberOfOptions is absent
                and remainingNumberOfUnits is absent
                and optional choice oldTradeIdentifier, oldTrade
                and if oldTradeIdentifier exists
                    then optional choice feeTradeIdentifier, feeTrade
                and if oldTrade exists
                    then optional choice feeTradeIdentifier, feeTrade
                and if oldTradeIdentifier is absent and oldTrade is absent
                    then optional choice feeTradeIdentifier, feeTrade

    condition Choice6:
        if novatedAmount is absent
                and novatedNumberOfOptions is absent
                and novatedNumberOfUnits is absent
                and novationAmount is absent
        then remainingAmount is absent
                and remainingNumberOfOptions is absent
                and remainingNumberOfUnits is absent
                and optional choice oldTradeIdentifier, oldTrade
                and optional choice feeTradeIdentifier, feeTrade

type TradingEventSummary:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type that records a short form event history of a trade."]

    eventIdentifier BusinessEventIdentifier (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    eventType EventType (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    agreementDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date on which the change was agreed."]
    executionDateTime ExecutionDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date and time at which the negotiated change to the terms of the original contract was agreed, such as via telephone or electronic trading system (i.e., agreement date/time)."]
    effectiveDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date on which the change become effective."]
    notionalChange NotionalChangeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indication as to whether the transaction is an increase or decrease of notional of a derivative contract. Only applies when there is change in notional for a derivative contract"]
    changeInNotional MoneyRef (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The change in notional amount for a prior report as a result of this event. The current notional will be reported in the trade itself. This corresponds to MiFIR Nominal or Monetary amount values; these can be distinguished by the esmaNotionalType indicator."]
    changeInNumberOfOptions AmountRef (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The change in nominal amount from a prior report as a result of this event. The current number of options will be reported in the trade itself. This corresponds to the MiFIR \"units\" value."]
    changeInQuantity UnitQuantityRef (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The change in quantity(s) from a prior report as a result of this event. The current quantity will be reported in the trade itself. This corresponds to the MiFIR \"units\" value."]
    payment NonNegativePayment (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A fee which compensates one of the parties for taking on a position that is off market."]

    condition Choice:
        optional choice changeInNotional, changeInNumberOfOptions, changeInQuantity

type TouchRateObservation extends TriggerRateObservation:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    exerciseSide ExerciseSideEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    settlementType SettlementTypeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    cashSettlement SimplePayment (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    physicalSettlement PhysicalSettlement (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    payment NonNegativePayment (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    clearingInstructions ClearingInstructions (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    isExercisable boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If the touch or no touch event hasn\'t generated an exercise, then we specify whether the option is exercisable or not."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If the touch or no touch event hasn\'t generated an exercise, then we specify whether the option is exercisable or not."]

    condition Choice0:
        isExercisable is absent
            or exerciseSide is absent
                and payment is absent
                and clearingInstructions is absent

    condition Choice1:
        optional choice settlementType, cashSettlement, physicalSettlement, isExercisable

type TriggerRateObservation:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    observationDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date on which the rate observation occurred, in order to trigger the barrier event.observationDate"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date on which the rate observation occurred, in order to trigger the barrier event.observationDate"]
    observationTime BusinessCenterTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The time at which the observation occurred."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The time at which the observation occurred."]
    informationSource InformationSource (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    triggerRate number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The rate value (level) which was attained/breached, in order to trigger the barrier event."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The rate value (level) which was attained/breached, in order to trigger the barrier event."]
    quotedCurrencyPair QuotedCurrencyPair (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the currency pair and quote basis for an FX rate."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the currency pair and quote basis for an FX rate."]
    observedRate number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The observed rate value which triggered the barrier event."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The observed rate value which triggered the barrier event."]
    triggerPrice PositiveMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The price value (level) which was attained/breached, in order to trigger the barrier event."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The price value (level) which was attained/breached, in order to trigger the barrier event."]
    observedPrice PositiveMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The observed price value which triggered the barrier event."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The observed price value which triggered the barrier event."]
    triggerCondition TriggerConditionEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The side of the trigger rate/price (level) on which a rate observation occurred, in order to trigger the barrier event."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The side of the trigger rate/price (level) on which a rate observation occurred, in order to trigger the barrier event."]

    condition Choice:
        triggerPrice is absent and observedPrice is absent
            or triggerRate is absent
                and quotedCurrencyPair is absent
                and observedRate is absent

type Withdrawal:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structure describing the removal of a trade from a service, such as a reporting service."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure describing the removal of a trade from a service, such as a reporting service."]

    partyTradeIdentifier PartyTradeIdentifier (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Identifiers of the trade that is being withdrawn."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Identifiers of the trade that is being withdrawn."]
    partyTradeInformation WithdrawalPartyTradeInformation (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Holds party-specific information about the trade that is being withdrawn from."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Holds party-specific information about the trade that is being withdrawn from."]
    trade Trade (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The full trade representation that is being withdrawn."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The full trade representation that is being withdrawn."]
    effectiveDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    requestedAction RequestedWithdrawalAction (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    reason WithdrawalReason (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    reportingRegime ReportingRegimeIdentifier (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. The supervisor/regulator to which this withdrawal applies"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "DEPRECATED. The supervisor/regulator to which this withdrawal applies"]

    condition Choice:
        trade is absent
            or partyTradeIdentifier is absent and partyTradeInformation is absent

type WithdrawalPartyTradeInformation:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining party-specific additional information that may be recorded against a trade, for withdrawal purposes."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining party-specific additional information that may be recorded against a trade, for withdrawal purposes."]

    partyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to a party."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to a party."]
    accountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to an account."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to an account."]
    relatedParty RelatedParty (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This may be used to identify one or more parties that perform a role within the transaction. If this is within a partyTradeInformation block, the related party performs the role with respect to the party identifie by the \"partyReference\" in the partyTradeInformation block."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This may be used to identify one or more parties that perform a role within the transaction. If this is within a partyTradeInformation block, the related party performs the role with respect to the party identifie by the \"partyReference\" in the partyTradeInformation block."]
    category TradeCategory (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Used to categorize trades into user-defined categories, such as house trades vs. customer trades."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Used to categorize trades into user-defined categories, such as house trades vs. customer trades."]
    reportingRegime ReportingRegimeIdentifier (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Allows the organization to specify which if any relevant regulators or other supervisory bodies this is relevant for, and what reporting rules apply."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Allows the organization to specify which if any relevant regulators or other supervisory bodies this is relevant for, and what reporting rules apply."]

type WithdrawalReason:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type that describes why a trade was withdrawn."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type that describes why a trade was withdrawn."]

    value Scheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    withdrawalReasonScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type UnitQuantityRef extends UnitQuantity:
    [docReference ISDA FPML version "recordkeeping-5.13"
