type TradeLegSizeChange:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structure describing a change to the size of a single leg or stream of a trade."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure describing a change to the size of a single leg or stream of a trade."]

    notionalReference NotionalReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    changeInNotionalAmount NonNegativeMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    outstandingNotionalAmount NonNegativeMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    numberOfOptionsReference NumberOfOptionsReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    changeInNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    outstandingNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    numberOfUnitsReference NumberOfUnitsReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    changeInNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    outstandingNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    notionalScheduleReference NotionalReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    changeInNotionalSchedule NonNegativeAmountSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    outstandingNotionalSchedule NonNegativeAmountSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    knownAmountReference AmountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    changeInKnownAmount NonNegativeMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    outstandingKnownAmount NonNegativeMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

    condition Choice:
        if changeInNotionalAmount exists or outstandingNotionalAmount exists
        then changeInNotionalAmount exists
                and outstandingNotionalAmount exists
                and numberOfOptionsReference is absent
                and changeInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and numberOfUnitsReference is absent
                and changeInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and notionalScheduleReference is absent
                and changeInNotionalSchedule is absent
                and outstandingNotionalSchedule is absent
                and knownAmountReference is absent
                and changeInKnownAmount is absent
                and outstandingKnownAmount is absent
        else if changeInNumberOfOptions exists or outstandingNumberOfOptions exists
        then changeInNumberOfOptions exists
                and outstandingNumberOfOptions exists
                and changeInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and notionalReference is absent
                and numberOfUnitsReference is absent
                and changeInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and notionalScheduleReference is absent
                and changeInNotionalSchedule is absent
                and outstandingNotionalSchedule is absent
                and knownAmountReference is absent
                and changeInKnownAmount is absent
                and outstandingKnownAmount is absent
        else if changeInNumberOfUnits exists or outstandingNumberOfUnits exists
        then changeInNumberOfUnits exists
                and outstandingNumberOfUnits exists
                and changeInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and changeInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and notionalReference is absent
                and numberOfOptionsReference is absent
                and notionalScheduleReference is absent
                and changeInNotionalSchedule is absent
                and outstandingNotionalSchedule is absent
                and knownAmountReference is absent
                and changeInKnownAmount is absent
                and outstandingKnownAmount is absent
        else if changeInNotionalSchedule exists or outstandingNotionalSchedule exists
        then changeInNotionalSchedule exists
                and outstandingNotionalSchedule exists
                and changeInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and changeInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and changeInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and notionalReference is absent
                and numberOfOptionsReference is absent
                and numberOfUnitsReference is absent
                and knownAmountReference is absent
                and changeInKnownAmount is absent
                and outstandingKnownAmount is absent
        else if changeInKnownAmount exists or outstandingKnownAmount exists
        then changeInKnownAmount exists
                and outstandingKnownAmount exists
                and changeInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and changeInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and changeInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and changeInNotionalSchedule is absent
                and outstandingNotionalSchedule is absent
                and notionalReference is absent
                and numberOfOptionsReference is absent
                and numberOfUnitsReference is absent
                and notionalScheduleReference is absent
        else False

type TradeNotionalChange extends TradeChangeBase:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structure describing a change to the size of a trade."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure describing a change to the size of a trade."]

    changeInNotionalAmount NonNegativeMoney (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the Notional Amount changes. The direction of the change (increase or decrease) is specified by the event type (Termination =&gt; reduction, Increase =&gt; greater.)"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the Notional Amount changes. The direction of the change (increase or decrease) is specified by the event type (Termination =&gt; reduction, Increase =&gt; greater.)"]
    outstandingNotionalAmount NonNegativeMoney (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Notional amount after the Change"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Notional amount after the Change"]
    changeInNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the Number of Options changes"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the Number of Options changes"]
    outstandingNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Number of Options after the Change."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Number of Options after the Change."]
    changeInNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the Number of Units changes"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the Number of Units changes"]
    outstandingNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Number of Units"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Number of Units"]
    sizeChange TradeLegSizeChange (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    priceChange TradeLegPriceChange (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

    condition Choice:
        if changeInNotionalAmount exists
        then changeInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and changeInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and sizeChange is absent
        else if changeInNumberOfOptions exists
        then changeInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and changeInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and sizeChange is absent
        else if changeInNumberOfUnits exists
        then changeInNotionalAmount is absent
                and changeInNumberOfOptions is absent
                and outstandingNotionalAmount is absent
                and outstandingNumberOfOptions is absent
                and sizeChange is absent
        else changeInNotionalAmount is absent
            and changeInNumberOfOptions is absent
            and changeInNumberOfUnits is absent
            and outstandingNotionalAmount is absent
            and outstandingNumberOfOptions is absent
            and outstandingNumberOfUnits is absent

