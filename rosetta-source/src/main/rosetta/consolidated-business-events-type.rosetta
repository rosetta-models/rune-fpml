namespace fpml.consolidated.business.events : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*
import fpml.consolidated.asset.*
import fpml.consolidated.cd.*
import fpml.consolidated.com.*
import fpml.consolidated.doc.*
import fpml.consolidated.fpmlenum.*
import fpml.consolidated.generic.*
import fpml.consolidated.shared.*

type BasketChange extends BasketChangeEvent:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Describes a change due to change in composition of basket underlyer"]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Describes a change due to change in composition of basket underlyer"]

type ChangeEvent extends AbstractEvent:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Abstract base type for non-negotiated trade change descriptions"]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Abstract base type for non-negotiated trade change descriptions"]

type CreditChangeEvent extends CreditChangeEventBase:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structure indicating that a trade has changed due to a credit event, including both shared (by single name, index and basket) and index specific components."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure indicating that a trade has changed due to a credit event, including both shared (by single name, index and basket) and index specific components."]

    indexReferenceInformation CreditEventIndexReferenceInformation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A type defining the Credit Default Swap Index impacted by the credit event."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A type defining the Credit Default Swap Index impacted by the credit event."]
    excludedReferenceEntity ReferenceInformation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The corporate or sovereign entity (and, optionally, associated obligations) in a basket impacted by the credit event."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The corporate or sovereign entity (and, optionally, associated obligations) in a basket impacted by the credit event."]

    condition Choice:
        optional choice indexReferenceInformation, excludedReferenceEntity

type CorporateAction extends CorporateActionEvent:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Describes a change due to a corporate action"]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Describes a change due to a corporate action"]

type IndexChange extends ChangeEvent:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structure describing the effect of a change to an index."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure describing the effect of a change to an index."]

    indexFactor number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    factoredCalculationAmount Money (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type AbstractEvent:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Abstract base type for all events."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Abstract base type for all events."]

    eventIdentifier BusinessEventIdentifier (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type ActionOnExpiration:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    exerciseAction ExerciseActionEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    expiry boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    fullExercise boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseInNotionalAmount Money (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as notional amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as notional amount."]
    outstandingNotionalAmount Money (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Notional amount after the Change"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Notional amount after the Change"]
    exerciseInNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as number of options."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as number of options."]
    outstandingNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Number of Options after the Change."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Number of Options after the Change."]
    exerciseInNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the option should be exercised express as number of units."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the option should be exercised express as number of units."]
    outstandingNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Number of Units"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Number of Units"]
    specifiedExercise OptionExerciseAmounts (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Number of Units"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Number of Units"]

    condition Choice:
        if exerciseAction exists
        then expiry is absent
                and fullExercise is absent
                and exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and specifiedExercise is absent
        else if expiry exists
        then fullExercise is absent
                and exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and specifiedExercise is absent
        else if fullExercise exists
        then exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and specifiedExercise is absent
        else if specifiedExercise exists
        then exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
        else exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
            or exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
            or exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent

type AdditionalEvent extends AbstractEvent:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Abstract base type for an extension/substitution point to customize FpML and add additional events."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Abstract base type for an extension/substitution point to customize FpML and add additional events."]

type AmountRef:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining a nominal amount with a reference."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining a nominal amount with a reference."]

    amount PositiveDecimal (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    amountReference AmountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type BasketChangeEvent extends ChangeEvent:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structure indicating that the basket underlyer of the trade has changed due to client trading activity"]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure indicating that the basket underlyer of the trade has changed due to client trading activity"]

type BusinessEventIdentifier:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining an event identifier issued by the indicated party."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining an event identifier issued by the indicated party."]

    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    partyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to a party."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to a party."]
    accountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to an account."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to an account."]
    eventId EventId (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type ResetCalculationDetails:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A cashflow component with optional calculation details that explain how the reset value was computed."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A cashflow component with optional calculation details that explain how the reset value was computed."]

    observation Observation (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The underlyer rate or price observation(s) used to compute the amount of this cashflow component."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The underlyer rate or price observation(s) used to compute the amount of this cashflow component."]
    calculationElements ResetCalculationElements (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The calculation details used to compute the reset rate."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The calculation details used to compute the reset rate."]

type ResetCalculationElements:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    notional CashflowNotional (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Identifies the notional in effect for this calculation period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Identifies the notional in effect for this calculation period."]
    calculatedRate CashflowFixing (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The computed rate(s) or price(s) used to calculate the amount of this reset. These computed rates or prices may include averaging and/or various types of rate treatment rules."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The computed rate(s) or price(s) used to calculate the amount of this reset. These computed rates or prices may include averaging and/or various types of rate treatment rules."]
    calculationPeriod ResetCalculationPeriod (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The period details for calculation/accrual periods that comprise this reset."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The period details for calculation/accrual periods that comprise this reset."]

type ResetCalculationPeriod:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "The period calculation details for a calculation/accrual period. This will include information about the dates and duration of the accrual period, the rate fixing(s), the notional in effect, and the amount of the accrual."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "The period calculation details for a calculation/accrual period. This will include information about the dates and duration of the accrual period, the rate fixing(s), the notional in effect, and the amount of the accrual."]

    adjustedStartDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Date that defines the beginning of the calculation period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date that defines the beginning of the calculation period."]
    adjustedEndDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Date that defines the end of the calculation period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date that defines the end of the calculation period."]
    numberOfDays int(min: 1) (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The number of days from the adjusted effective / start date to the adjusted termination / end date calculated in accordance with the applicable day count fraction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The number of days from the adjusted effective / start date to the adjusted termination / end date calculated in accordance with the applicable day count fraction."]
    dayCountFraction DayCountFraction (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The specification for how the number of days between two dates is calculated for purposes of calculation of a fixed or floating payment amount and the basis for how many days are assumed to be in a year. Day Count Fraction is an ISDA term. The equivalent AFB (Association Francaise de Banques) term is Calculation Basis."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The specification for how the number of days between two dates is calculated for purposes of calculation of a fixed or floating payment amount and the basis for how many days are assumed to be in a year. Day Count Fraction is an ISDA term. The equivalent AFB (Association Francaise de Banques) term is Calculation Basis."]
    dayCountYearFraction number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The year fraction value of the calculation period, result of applying the ISDA rules for day count fraction defined in the ISDA Annex."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The year fraction value of the calculation period, result of applying the ISDA rules for day count fraction defined in the ISDA Annex."]

type CashflowFixing:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Details of the computation of a computed rate or price used to calculate the amount of a cashflow component. This computed rate or price may include averaging and/or various types of rate treatment rules. The details include all of the observations, the calculation parameters, and the resulting value."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Details of the computation of a computed rate or price used to calculate the amount of a cashflow component. This computed rate or price may include averaging and/or various types of rate treatment rules. The details include all of the observations, the calculation parameters, and the resulting value."]

    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    observationReference CashflowObservationReference (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to the observation details of a particular rate observation."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to the observation details of a particular rate observation."]
    calculatedValue number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The value computed based on averaging the underlying observation and applying any spreads, multipliers, and cap and floors values. average or treated value computed based on the underlyer observations, following the calculation rules."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The value computed based on averaging the underlying observation and applying any spreads, multipliers, and cap and floors values. average or treated value computed based on the underlyer observations, following the calculation rules."]
    multiplier number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A rate multiplier to apply to the floating rate. The multiplier can be a positive or negative decimal. This element should only be included if the multiplier is not equal to 1 (one)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A rate multiplier to apply to the floating rate. The multiplier can be a positive or negative decimal. This element should only be included if the multiplier is not equal to 1 (one)."]
    spread number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The ISDA Spread, if any, which applies for the calculation period. It also defines spread as price. The spread is a per annum rate, expressed as a decimal. For purposes of determining a calculation period amount, if positive the spread will be added to the floating rate and if negative the spread will be subtracted from the floating rate. A positive 10 basis point (0.1%) spread would be represented as 0.001."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The ISDA Spread, if any, which applies for the calculation period. It also defines spread as price. The spread is a per annum rate, expressed as a decimal. For purposes of determining a calculation period amount, if positive the spread will be added to the floating rate and if negative the spread will be subtracted from the floating rate. A positive 10 basis point (0.1%) spread would be represented as 0.001."]
    capValue Strike (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The cap rate or price, if any, which applies to the floating rate for the calculation period. The cap rate (strike) is only required where the floating rate on a swap stream is capped at a certain strike level. The cap rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A cap rate of 5% would be represented as 0.05."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The cap rate or price, if any, which applies to the floating rate for the calculation period. The cap rate (strike) is only required where the floating rate on a swap stream is capped at a certain strike level. The cap rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A cap rate of 5% would be represented as 0.05."]
    floorValue Strike (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The floor rate or price, if any, which applies to the floating rate for the calculation period. The floor rate (strike) is only required where the floating rate on a swap stream is floored at a certain strike level. The floor rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. The floor rate of 5% would be represented as 0.05."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The floor rate or price, if any, which applies to the floating rate for the calculation period. The floor rate (strike) is only required where the floating rate on a swap stream is floored at a certain strike level. The floor rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. The floor rate of 5% would be represented as 0.05."]
    negativeInterestRate boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Flag to indicate if negative interest rate is applied."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Flag to indicate if negative interest rate is applied."]
    rounding Rounding (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Rounding direction and precision for price values."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Rounding direction and precision for price values."]

type CashflowObservationReference extends fpml.consolidated.shared.Reference:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Reference to a cash flow observation component."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Reference to a cash flow observation component."]

    href string (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type ClearingInstructions:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    requestedClearingAction RequestedClearingAction (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    requestedClearingOrganizationPartyReference PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type CorporateActionEvent extends ChangeEvent:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structure indicating that a trade has changed due to a corporate action"]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure indicating that a trade has changed due to a corporate action"]

    ^type CorporateActionType (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type CorporateActionType:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type that describes what type of corporate action occurred."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type that describes what type of corporate action occurred."]

    value Scheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    corporateActionScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type CreditChangeEventBase extends ChangeEvent:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structure indicating that a trade has changed due to a credit event and containing only components shared by single name, index and basket."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure indicating that a trade has changed due to a credit event and containing only components shared by single name, index and basket."]

    creditEventType CreditEventType (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the type of credit event taking place."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the type of credit event taking place."]
    eventDeterminationDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date at which a Credit Event Resolution Request Date (CERD) or Notice Delivery Date occurs."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date at which a Credit Event Resolution Request Date (CERD) or Notice Delivery Date occurs."]
    auctionDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date on which the auction is scheduled to occur."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date on which the auction is scheduled to occur."]
    settlementMethod CashOrPhysicalSettlementEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies whether the process is to be physically settled or cash settled."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies whether the process is to be physically settled or cash settled."]
    settlementDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date on which settlement is scheduled to occur."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date on which settlement is scheduled to occur."]
    finalPrice number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The final price resulting from the auction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The final price resulting from the auction."]
    recoveryPercent number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The percentage of the original value of the asset affected by the credit event that can be recovered."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The percentage of the original value of the asset affected by the credit event that can be recovered."]
    publiclyAvailableInformation Resource (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A public information source, e.g. a particular newspaper or electronic news service, that may publish relevant information used in the determination of whether or not a credit event has occurred."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A public information source, e.g. a particular newspaper or electronic news service, that may publish relevant information used in the determination of whether or not a credit event has occurred."]

type EventId:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A post-trade event reference identifier allocated by a party. FpML does not define the domain values associated with this element. Note that the domain values for this element are not strictly an enumerated list."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A post-trade event reference identifier allocated by a party. FpML does not define the domain values associated with this element. Note that the domain values for this element are not strictly an enumerated list."]

    value NonEmptyScheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    eventIdScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type EventTaxonomy:
    [docReference ISDA FPML version "recordkeeping-5.13"]

    value NonEmptyScheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    eventTaxonomyScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]

type EventType:
    [docReference ISDA FPML version "recordkeeping-5.13"]

    value NonEmptyScheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    eventTypeScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]

type KnockOutRateObservation extends TriggerRateObservation:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Describes an observation that caused a barrier knock out to trigger"]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Describes an observation that caused a barrier knock out to trigger"]

    rebatePayment NonNegativePayment (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Any rebate payable as a result of the knock out"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Any rebate payable as a result of the knock out"]

type MoneyRef extends PositiveMoney:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining a currency amount with a reference."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining a currency amount with a reference."]

    notionalReference NotionalReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to the associated notional schedule defined elsewhere in the document."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to the associated notional schedule defined elsewhere in the document."]

type NoTouchLowerBarrierObservation:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    triggerRate number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The rate value (level) which was attained/breached, in order to trigger the barrier event."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The rate value (level) which was attained/breached, in order to trigger the barrier event."]
    quotedCurrencyPair QuotedCurrencyPair (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the currency pair and quote basis for an FX rate."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the currency pair and quote basis for an FX rate."]
    minimumObservedRate ObservedRate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The minimum value observed during the condition period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The minimum value observed during the condition period."]
    triggerPrice PositiveMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The price value (level) which was attained/breached, in order to trigger the barrier event."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The price value (level) which was attained/breached, in order to trigger the barrier event."]
    minimumObservedPrice ObservedPrice (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The minimum value observed during the condition period"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The minimum value observed during the condition period"]

    condition Choice:
        triggerPrice is absent and minimumObservedPrice is absent
            or triggerRate is absent
                and quotedCurrencyPair is absent
                and minimumObservedRate is absent

type NoTouchRateObservation:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    observationStartDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    observationEndDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    lowerBarrier NoTouchLowerBarrierObservation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    upperBarrier NoTouchUpperBarrierObservation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseSide ExerciseSideEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    settlementType SettlementTypeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    cashSettlement SimplePayment (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    physicalSettlement PhysicalSettlement (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    payment NonNegativePayment (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    clearingInstructions ClearingInstructions (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    isExercisable boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If the touch or no touch event hasn\'t generated an exercise, then we specify whether the option is exercisable or not."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If the touch or no touch event hasn\'t generated an exercise, then we specify whether the option is exercisable or not."]

    condition Choice0:
        isExercisable is absent
            or exerciseSide is absent
                and payment is absent
                and clearingInstructions is absent

    condition Choice1:
        optional choice settlementType, cashSettlement, physicalSettlement, isExercisable

