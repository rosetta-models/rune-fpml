        [docReference ISDA FPML version "confirmation-5.13"]
    time time (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]

type PackageHeader:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Identifying information for a tradePackage (a bundle of trades)."]

    packageIdentifier IssuerTradeId (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    orderIdentifier OrderIdentifier (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    packageType PackageType (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Classification of the package. FpML has defined a list of coding scheme values. Different organizations might have different naming schemes for the packages so the multiplicity of unbounded is meant to support synonyms but it does not mean that a trade has multiple package types."]
    size PositiveDecimal (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    originatingEvent OriginatingEvent (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This may be used to describe why a package was created. This can be used to provide context for a newly created package that is not part of a post-trade event. For example, it can report that the package was created as a result of netting activity, or due to a transfer, an allocation process, etc."]
    packageInformation PackageInformation (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]

type TradeMaturity:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure describing a trade maturing."]

    tradeIdentifier PartyTradeIdentifier (1..*)
        [docReference ISDA FPML version "confirmation-5.13"]
    date zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]

type TradePackage:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A bundle of trades collected together into a single unit for reporting."]

    packageHeader PackageHeader (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    trade Trade (0..*)
        [docReference ISDA FPML version "confirmation-5.13"]
    tradePackageSequence TradePackageSequence (0..*)
        [docReference ISDA FPML version "confirmation-5.13"]
    tradeIdentifier TradeIdentifier (0..*)
        [docReference ISDA FPML version "confirmation-5.13"]
    approvals Approvals (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A container for approval states in the workflow."]

    condition Choice:
        required choice trade, tradePackageSequence, tradeIdentifier

type TradePackageSequence:
    [docReference ISDA FPML version "confirmation-5.13"]

    tradeReferenceInformation TradeReferenceInformation (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Information about a trade."]

type TradeReferenceInformation:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Defines a type that allows trade identifiers and/or trade information to be represented for a trade."]

    originatingEvent OriginatingEvent (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This may be used to describe why a trade was created. This can be used to provide context for a newly created trade that is not part of a post-trade event. For example, it can report that the trade was created as a result of netting activity, or due to a transfer, an allocation process, etc. Omitting this implies that the trade record was created as a result of a negotiated new trade."]
    terminatingEvent TerminatingEvent (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This may be used to describe why a trade was terminated."]
    partyTradeIdentifier PartyTradeIdentifier (1..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This allows the acknowledging party to supply additional trade identifiers for a trade underlying a request relating to a business event."]
    partyTradeInformation PartyTradeInformation (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This allows the acknowledging party to supply additional trade information about a trade underlying a request relating to a business event."]
    productType ProductType (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    productId ProductId (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]

    condition Choice:
        optional choice originatingEvent, terminatingEvent

