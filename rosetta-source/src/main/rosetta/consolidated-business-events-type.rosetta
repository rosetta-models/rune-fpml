    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Reference to the observation details of a particular rate observation."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Reference to the observation details of a particular rate observation."]

type OptionEvent extends AbstractEvent:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    originalTrade Trade (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Fully describes the original trade (prior to the exercise)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Fully describes the original trade (prior to the exercise)."]
    tradeIdentifier PartyTradeIdentifier (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Identified the trade to which the option event applies."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Identified the trade to which the option event applies."]
    knockIn TriggerRateObservation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A structure describing a barrier knock in event"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure describing a barrier knock in event"]
    knockOut KnockOutRateObservation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A structure describing a barrier knock out event"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure describing a barrier knock out event"]
    touch TouchRateObservation (0..2)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A structure describing a touch event"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure describing a touch event"]
    noTouch NoTouchRateObservation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A structure describing the outcome of an option having no touch events"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure describing the outcome of an option having no touch events"]

    condition Choice0:
        optional choice originalTrade, tradeIdentifier

    condition Choice1:
        optional choice knockIn, knockOut, touch, noTouch

type OptionExercise extends AbstractEvent:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structure describing an option exercise. The OptionExercise type supports partial exercise (specify the number of options or amount to exercise), full exercise (use fullExercise flag), as well as the option to request options not to be exercised."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure describing an option exercise. The OptionExercise type supports partial exercise (specify the number of options or amount to exercise), full exercise (use fullExercise flag), as well as the option to request options not to be exercised."]

    optionSeller PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    optionBuyer PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    originalTrade Trade (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Fully describes the original trade (prior to the exercise)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Fully describes the original trade (prior to the exercise)."]
    tradeIdentifier PartyTradeIdentifier (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseTime time (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseTiming ExerciseTimingEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseAction ExerciseActionEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    expiry boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    fullExercise boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseInNotionalAmount Money (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as notional amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as notional amount."]
    outstandingNotionalAmount Money (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Notional amount after the Change"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Notional amount after the Change"]
    exerciseInNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as number of options."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as number of options."]
    outstandingNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Number of Options after the Change."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Number of Options after the Change."]
    exerciseInNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the option should be exercised express as number of units."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the option should be exercised express as number of units."]
    outstandingNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Number of Units"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Number of Units"]
    specifiedExercise OptionExerciseAmounts (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Number of Units"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Number of Units"]
    exerciseSide ExerciseSideEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    settlementType SettlementTypeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    cashSettlement SimplePayment (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    physicalSettlement PhysicalSettlement (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    payment NonNegativePayment (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    clearingInstructions ClearingInstructions (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

    condition Choice0:
        exerciseTiming is absent or exerciseDate is absent and exerciseTime is absent

    condition Choice1:
        optional choice settlementType, cashSettlement, physicalSettlement

    condition Choice2:
        optional choice originalTrade, tradeIdentifier

    condition Choice3:
        if exerciseAction exists
        then expiry is absent
                and fullExercise is absent
                and exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and specifiedExercise is absent
        else if expiry exists
        then fullExercise is absent
                and exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and specifiedExercise is absent
        else if fullExercise exists
        then exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
                and specifiedExercise is absent
        else if specifiedExercise exists
        then exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
        else exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
            or exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
            or exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent

type OptionExerciseAmounts:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    notionalReference NotionalReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseInNotionalAmount Money (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as notional amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as notional amount."]
    outstandingNotionalAmount Money (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Notional amount after the Change"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Notional amount after the Change"]
    notionalScheduleReference NotionalReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseInNotionalSchedule NonNegativeAmountSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the amount by which the option should be exercised expressed as notional schedule."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the amount by which the option should be exercised expressed as notional schedule."]
    outstandingNotionalSchedule NonNegativeAmountSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Notional schedule after the Change"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Notional schedule after the Change"]
    numberOfOptionsReference NumberOfOptionsReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseInNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as number of options."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the option should be exercised expressed as number of options."]
    outstandingNumberOfOptions number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Number of Options after the Change."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Number of Options after the Change."]
    numberOfUnitsReference NumberOfUnitsReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    exerciseInNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fixed amount by which the option should be exercised express as number of units."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fixed amount by which the option should be exercised express as number of units."]
    outstandingNumberOfUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Number of Units"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Number of Units"]

    condition Choice:
        notionalScheduleReference is absent
                and exerciseInNotionalSchedule is absent
                and outstandingNotionalSchedule is absent
                and numberOfOptionsReference is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and numberOfUnitsReference is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
            or notionalReference is absent
                and exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and numberOfOptionsReference is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent
                and numberOfUnitsReference is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
            or notionalReference is absent
                and exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and notionalScheduleReference is absent
                and exerciseInNotionalSchedule is absent
                and outstandingNotionalSchedule is absent
                and numberOfUnitsReference is absent
                and exerciseInNumberOfUnits is absent
                and outstandingNumberOfUnits is absent
            or notionalReference is absent
                and exerciseInNotionalAmount is absent
                and outstandingNotionalAmount is absent
                and notionalScheduleReference is absent
                and exerciseInNotionalSchedule is absent
                and outstandingNotionalSchedule is absent
                and numberOfOptionsReference is absent
                and exerciseInNumberOfOptions is absent
                and outstandingNumberOfOptions is absent

