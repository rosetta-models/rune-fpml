    [docReference ISDA FPML version "confirmation-5.13"]

    executed CreditLimitUtilizationPosition (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Credit limit utilization attributable to executed trades."]
    pending CreditLimitUtilizationPosition (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Credit limit utilization attributable to pending unexecuted orders."]

type CreditLimitUtilizationPosition:
    [docReference ISDA FPML version "confirmation-5.13"]

    short NonNegativeDecimal (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Credit limit utilization attributable to short positions."]
    long NonNegativeDecimal (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
