    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structure describing a change to the size of a single leg or stream of a trade."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure describing a change to the size of a single leg or stream of a trade."]

    priceReference fpml.consolidated.shared.Reference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
