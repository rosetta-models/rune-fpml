    global NonNegativeDecimal (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Global credit limit utilization amount, agnostic of long/short position direction."]

type DeClear:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure describing a declear event. The deClear event allows a firm to request that a trade be removed from clearing, or a clearing service to request consent for this, or to report that is has been done."]

    tradeIdentifier PartyTradeIdentifier (1..*)
        [docReference ISDA FPML version "confirmation-5.13"]
    effectiveDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    reason DeclearReason (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]

