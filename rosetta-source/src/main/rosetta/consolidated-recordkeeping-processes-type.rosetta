namespace fpml.consolidated.recordkeeping.processes : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*
import fpml.consolidated.asset.*
import fpml.consolidated.business.events.*
import fpml.consolidated.doc.*
import fpml.consolidated.fpmlenum.*
import fpml.consolidated.msg.*
import fpml.consolidated.reg.fpmlreporting.shared.*
import fpml.consolidated.shared.*

type NonpublicExecutionReport extends CorrectableRequestMessage:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Non public execution report message."]

    asOfDate IdentifiedDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date for which this document reports positions and valuations."]
    asOfTime time (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The time for which this report was generated (i.e., the cut-off time of the report)."]
    portfolioReference PortfolioReferenceBase (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    originatingEvent OriginatingEvent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    trade Trade (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    tradingEvent TradingEventSummary (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This is provided to support snapshot reporting that requires trading history. Some implementations are using the \"trade\" event to report the current snapshot of a contract. In these cases it may also be necessary to report the most recent trading event to support regulatory reporting mandates. For this reason the tradingEvent is provided to allow that event to be attached to the trade report."]
    amendment TradeAmendmentContent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    increase TradeNotionalChange (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    terminatingEvent TerminatingEvent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This may be used to describe why a trade was terminated."]
    termination TradeNotionalChange (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    novation TradeNovationContent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    withdrawal Withdrawal (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    observation ObservationEvent (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    reset ResetEvent (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    change TradeChangeContent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    optionExercise OptionExercise (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A structure describing an option exercise event. The optionExercise event supports partial exercise (specify the number of options or amount to exercise), full exercise (use fullExercise flag), as well as the option to request options not to be exercised."]
    optionExpiry OptionExpiry (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A structure describing an option expiring event (i.e. passing its last exercise time and becoming worthless.)"]
    optionEvent OptionEvent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A structure describing knock in, knock out, touch and no touch events."]
    additionalEvent AdditionalEvent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    quote BasicQuotation (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Pricing information for the trade."]
    scheduledDate ScheduledDateBase (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Upcoming important dates for the trade. Added to support CFTC Amendments to Part 43/45 (Published November 2020)."]
    collateralization RegulatoryReportingCollateralization (0..2)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    party Party (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document."]
    account Account (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Optional account information used to precisely define the origination and destination of financial instruments."]

    condition Choice:
        if trade exists
        then amendment is absent
                and increase is absent
                and terminatingEvent is absent
                and termination is absent
                and novation is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
        else if increase exists
        then amendment is absent
                and terminatingEvent is absent
                and termination is absent
                and novation is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and originatingEvent is absent
                and trade is absent
                and tradingEvent is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
        else if termination exists
        then amendment is absent
                and increase is absent
                and novation is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and originatingEvent is absent
                and trade is absent
                and tradingEvent is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
        else if novation exists
        then amendment is absent
                and increase is absent
                and terminatingEvent is absent
                and termination is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and originatingEvent is absent
                and trade is absent
                and tradingEvent is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
        else if withdrawal exists
        then amendment is absent
                and increase is absent
                and terminatingEvent is absent
                and termination is absent
                and novation is absent
                and observation is absent
                and reset is absent
                and originatingEvent is absent
                and trade is absent
                and tradingEvent is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
        else if reset exists
        then amendment is absent
                and increase is absent
                and terminatingEvent is absent
                and termination is absent
                and novation is absent
                and withdrawal is absent
                and originatingEvent is absent
                and trade is absent
                and tradingEvent is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
        else if change exists
        then originatingEvent is absent
                and trade is absent
                and tradingEvent is absent
                and amendment is absent
                and increase is absent
                and terminatingEvent is absent
                and termination is absent
                and novation is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
        else if optionExercise exists
        then optionExpiry is absent
                and optionEvent is absent
                and originatingEvent is absent
                and trade is absent
                and tradingEvent is absent
                and amendment is absent
                and increase is absent
                and terminatingEvent is absent
                and termination is absent
                and novation is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and change is absent
                and additionalEvent is absent
        else if optionExpiry exists
        then optionExercise is absent
                and optionEvent is absent
                and originatingEvent is absent
                and trade is absent
                and tradingEvent is absent
                and amendment is absent
                and increase is absent
                and terminatingEvent is absent
                and termination is absent
                and novation is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and change is absent
                and additionalEvent is absent
        else if optionEvent exists
        then optionExercise is absent
                and optionExpiry is absent
                and originatingEvent is absent
                and trade is absent
                and tradingEvent is absent
                and amendment is absent
                and increase is absent
                and terminatingEvent is absent
                and termination is absent
                and novation is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and change is absent
                and additionalEvent is absent
        else if additionalEvent exists
        then originatingEvent is absent
                and trade is absent
                and tradingEvent is absent
                and amendment is absent
                and increase is absent
                and terminatingEvent is absent
                and termination is absent
                and novation is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
        else increase is absent
            and terminatingEvent is absent
            and termination is absent
            and novation is absent
            and withdrawal is absent
            and observation is absent
            and reset is absent
            and originatingEvent is absent
            and trade is absent
            and tradingEvent is absent
            and change is absent
            and optionExercise is absent
            and optionExpiry is absent
            and optionEvent is absent
            and additionalEvent is absent

type NonpublicExecutionReportAcknowledgement extends Acknowledgement:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Acknowledgement message for nonpublicExecutionReport."]

type NonpublicExecutionReportException extends Exception:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Exception message for nonpublicExecutionReport."]

type NonpublicExecutionReportRetracted extends NonCorrectableRequestMessage:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Retraction message for nonpublicExecutionReport."]

    originatingEvent OriginatingEvent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    trade Trade (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    tradingEvent TradingEventSummary (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This is provided to support snapshot reporting that requires trading history. Some implementations are using the \"trade\" event to report the current snapshot of a contract. In these cases it may also be necessary to report the most recent trading event to support regulatory reporting mandates. For this reason the tradingEvent is provided to allow that event to be attached to the trade report."]
    amendment TradeAmendmentContent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    increase TradeNotionalChange (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    terminatingEvent TerminatingEvent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This may be used to describe why a trade was terminated."]
    termination TradeNotionalChange (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    novation TradeNovationContent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    withdrawal Withdrawal (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    observation ObservationEvent (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    reset ResetEvent (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    change TradeChangeContent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    optionExercise OptionExercise (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A structure describing an option exercise event. The optionExercise event supports partial exercise (specify the number of options or amount to exercise), full exercise (use fullExercise flag), as well as the option to request options not to be exercised."]
    optionExpiry OptionExpiry (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A structure describing an option expiring event (i.e. passing its last exercise time and becoming worthless.)"]
    optionEvent OptionEvent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A structure describing knock in, knock out, touch and no touch events."]
    additionalEvent AdditionalEvent (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    primaryAssetClass AssetClass (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    tradeIdentifier PartyTradeIdentifier (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    eventIdentifier BusinessEventIdentifier (0..2)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Individual parties should only use a single event identifier to identify a retraction. Platforms providing services on behalf of both parties in a transaction may provide event identifiers for both parties; in this case it is up to the recipient (the trade repository) to validate that the event IDs refer to the same event."]
    relatedParty RelatedParty (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This may be used to identify one or more parties that perform a role within the transaction. If this is within a partyTradeInformation block, the related party performs the role with respect to the party identifie by the \"partyReference\" in the partyTradeInformation block."]
    party Party (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document."]
    account Account (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Optional account information used to precisely define the origination and destination of financial instruments."]

    condition Choice:
        if trade exists
        then amendment is absent
                and increase is absent
                and terminatingEvent is absent
                and termination is absent
                and novation is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
        else if increase exists
        then amendment is absent
                and terminatingEvent is absent
                and termination is absent
                and novation is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and originatingEvent is absent
                and tradingEvent is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
        else if termination exists
        then amendment is absent
                and novation is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and originatingEvent is absent
                and tradingEvent is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
        else if novation exists
        then amendment is absent
                and terminatingEvent is absent
                and withdrawal is absent
                and observation is absent
                and reset is absent
                and originatingEvent is absent
                and tradingEvent is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
        else if withdrawal exists
        then amendment is absent
                and terminatingEvent is absent
                and observation is absent
                and reset is absent
                and originatingEvent is absent
                and tradingEvent is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
        else if reset exists
        then amendment is absent
                and terminatingEvent is absent
                and originatingEvent is absent
                and tradingEvent is absent
                and change is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
        else if change exists
        then originatingEvent is absent
                and tradingEvent is absent
                and amendment is absent
                and terminatingEvent is absent
                and observation is absent
                and optionExercise is absent
                and optionExpiry is absent
                and optionEvent is absent
                and additionalEvent is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
        else if optionExercise exists
        then optionExpiry is absent
                and optionEvent is absent
                and originatingEvent is absent
                and tradingEvent is absent
                and amendment is absent
                and terminatingEvent is absent
                and observation is absent
                and additionalEvent is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
        else if optionExpiry exists
        then optionEvent is absent
                and originatingEvent is absent
                and tradingEvent is absent
                and amendment is absent
                and terminatingEvent is absent
                and observation is absent
                and additionalEvent is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
        else if optionEvent exists
        then originatingEvent is absent
                and tradingEvent is absent
                and amendment is absent
                and terminatingEvent is absent
                and observation is absent
                and additionalEvent is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
        else if additionalEvent exists
        then originatingEvent is absent
                and tradingEvent is absent
                and amendment is absent
                and terminatingEvent is absent
                and observation is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
        else terminatingEvent is absent
                and observation is absent
                and originatingEvent is absent
                and tradingEvent is absent
                and primaryAssetClass is absent
                and tradeIdentifier is absent
                and eventIdentifier is absent
                and relatedParty is absent
            or originatingEvent is absent
                and tradingEvent is absent
                and amendment is absent
                and terminatingEvent is absent
                and observation is absent

type RegulatoryDisclosure extends AddressedMessage:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). A type that defines a message to be used for reporting non-public information to a regulator, typically via a trade repository or other reporting service. CAVEAT: This new regulatory reporting message set is supported by the FpML Standards Committee, and will be present in future versions of the standard. However, there is no absolute guarantee of backward compatibility with future versions of the standard, until such time as the Standards Committee deems that the message set has been extensively adopted in production. The Standards Committee will attempt to maintain full backward compatibility with this version while adjusting as required to take into account implementation experience with the message set. The Standards Committee advises that the areas where there is more likely to be change include the applicableRegulatiorns section, the regulatorionSpecificInformation section, and the regulatoryProductInformation [DEPRECATED] product, which is developed as part of this reporting framework. Feedback or questions can be addressed to ISDA at rptwgchair@fpml.org."]

    isCorrection boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). Indicates if this message corrects an earlier submission. If true, the recipient is directed to record information about the most recent lifecycle event affecting the trade as a correction of the previous submission, rather than as a new lifecycle event."]
    onBehalfOf OnBehalfOf (0..4)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). Indicates which party (or parties) (and accounts) a trade or event is being processed for. Normally there will only be a maximum of 2 parties, but in the case of a novation there could be a transferor, transferee, remaining party, and other remaining party. Also, in the context of a trade package there could be several parties for which limit check is requested, necessitating multiple onBehalfOf elements. Except for these cases, there should be no more than two onBehalfOf references in a message."]
    asOfDate IdentifiedDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). The date for which this document reports positions and valuations."]
    asOfTime time (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). The time for which this report was generated (i.e., the cut-off time of the report)."]
    eventId EventId (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). A unique event identifier."]
    eventType EventTaxonomy (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). A structured code indicating the event type."]
    eventTimestamps EventTimestamps (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). Various timestamps related to the event."]
    reportingPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the reporting party."]
    counterPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the reporting party."]
    notionalChange NotionalChangeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indication as to whether the transaction is an increase or decrease of notional of a derivative contract. Only applies when there is change in notional for a derivative contract"]
    changeInNotional MoneyRef (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The change in notional amount for a prior report as a result of this event. The current notional will be reported in the trade itself. This corresponds to MiFIR Nominal or Monetary amount values; these can be distinguished by the esmaNotionalType indicator."]
    changeInNumberOfOptions AmountRef (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The change in nominal amount from a prior report as a result of this event. The current number of options will be reported in the trade itself. This corresponds to the MiFIR \"units\" value."]
    changeInQuantity UnitQuantityRef (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The change in quantity(s) from a prior report as a result of this event. The current quantity will be reported in the trade itself. This corresponds to the MiFIR \"units\" value."]
    payment NonNegativePayment (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). Payments in settlement of the event"]
    applicableRegulations ApplicableRegulations (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). All the regulators to which this trade should be reported. Optional, can be infeerred from the list of regulations to which the trade is submitted."]
    regulationSpecificInformation RegulationDetails (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). All the regulations that this trade should be reported under."]
    cpmiIoscoCDE RegReportingCDE (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). The revised state of the trade or its final state for a lifecycle ending event"]
    trade Trade (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). The revised state of the trade or its final state for a lifecycle ending event"]
    quote BasicQuotation (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). Pricing information for the trade."]
    collateralization RegulatoryReportingCollateralization (0..2)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12)."]
    party Party (1..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Not in use (RPTWG decision 2024-12-12). The supporting party definitions."]

    condition Choice:
        optional choice changeInNotional, changeInNumberOfOptions, changeInQuantity

type RegulatoryReportingAcknowledgement extends Message:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining an acknowledgement to a regulatory reporting submission, e.g. regulatoryDisclosure or regulatoryWithdrawal."]

    header ResponseMessageHeader (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Standard FpML message header"]
    tradeIdentifier PartyTradeIdentifier (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "identifies the affected trade"]
    reportingStatus ReportingStatus (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Information about how the position is being reported to regulators."]
    additionalData AdditionalData (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    party Party (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference information about parties, business units, and persons involed in the trade."]

type RegulatoryReportingException extends Message:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining the basic content for a message sent to inform another system that some exception has been detected in a regulatory reporting message."]

    header ExceptionMessageHeader (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    reason Reason (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "An instance of the Reason type used to record the nature of any errors associated with a message."]
    additionalData AdditionalData (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Any string of additional data that may help the message processor, for example in a rejection message this might contain a code value or the text of the original request (within a CDATA section)."]

type RegulatoryWithdrawal extends AddressedMessage:
    [rootType]
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining the message used to request withdrawal from one or more jurisdictions."]

    onBehalfOf OnBehalfOf (0..4)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates which party (or parties) (and accounts) a trade or event is being processed for. Normally there will only be a maximum of 2 parties, but in the case of a novation there could be a transferor, transferee, remaining party, and other remaining party. Also, in the context of a trade package there could be several parties for which limit check is requested, necessitating multiple onBehalfOf elements. Except for these cases, there should be no more than two onBehalfOf references in a message."]
    tradeIdentifier PartyTradeIdentifier (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "identifies the affected trade"]
    primaryAssetClass AssetClass (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The asset class of the underlying product."]
    inapplicableRegulation InapplicableRegulation (1..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates which regulation the trade is to withdrawn from. At least one child element must be selected."]
    withdrawalReason NormalizedString (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    fullyWithdrawn boolean (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates if the trade is now fully withdrawn from all regulatory reports. This can be used by a trade repository to perform a consistency check. For instance, if \"fullyWithdrawn\" is \"true\" but the TR believes that the trade is still reportable to at least one regulator, it could report an exception with the identity of that regulator. Or if \"fullyWithdrawn\" is false but the TR believes that the trade is no longer reportable to any regulator, the TR should report that fact."]
    relatedParty RelatedParty (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
    party Party (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The supporting party definitions."]

