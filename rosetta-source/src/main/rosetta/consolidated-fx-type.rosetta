        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies whether \"Mean Adjustment\" is applicable or not in the calculation of the Realized Volatility."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies whether \"Mean Adjustment\" is applicable or not in the calculation of the Realized Volatility."]
    additionalPayment Payment (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Additional Payment means, in respect of an FX Transaction, where such fee is required, and a Transaction Fee Payment Date, the amount, if any, that is specified or otherwise determined as provided in the related Confirmation and, subject to any applicable condition precedent, is payable by one party to the other as further specified or otherwise determined as provided in the related Confirmation on the Transaction Fee Payment Date or on each Transaction Fee Payment Date if more than one is specified, for value on such date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Additional Payment means, in respect of an FX Transaction, where such fee is required, and a Transaction Fee Payment Date, the amount, if any, that is specified or otherwise determined as provided in the related Confirmation and, subject to any applicable condition precedent, is payable by one party to the other as further specified or otherwise determined as provided in the related Confirmation on the Transaction Fee Payment Date or on each Transaction Fee Payment Date if more than one is specified, for value on such date."]
    cashSettlement FxCashSettlementSimple (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the Settlement currency and fixing details for cash settlement. The FX Volatility and FX Variance Swaps are inherently cash settled, but into the notional currency. The optional cashSettlement block is provided for the case where the Settlement Currency differs from that of the Notional."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the Settlement currency and fixing details for cash settlement. The FX Volatility and FX Variance Swaps are inherently cash settled, but into the notional currency. The optional cashSettlement block is provided for the case where the Settlement Currency differs from that of the Notional."]
    numberOfReturns int (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Number of Returns is the number of Observation Dates in the Observation Period, excluding the Initial Observation Date (where the Observation Rate on the Initial Observation Date shall equal S0)."]

    condition Choice:
        optional choice valuationDate, valuationDateOffset

type FxStraddle:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Straddle details. Straddle is composed of two options: a call and a put involving the quotedCurrencyPair."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Straddle details. Straddle is composed of two options: a call and a put involving the quotedCurrencyPair."]

    straddleType FxStraddleTypeEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The type Straddle as agreed on the Trade Date, e.g. at the money forward straddle, or delta neutral straddle."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The type Straddle as agreed on the Trade Date, e.g. at the money forward straddle, or delta neutral straddle."]
    tenorPeriod Period (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A Tenor (time to maturity) of the straddle starting from the Fixing Date (e.g. 1y, 3m)"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A Tenor (time to maturity) of the straddle starting from the Fixing Date (e.g. 1y, 3m)"]
    europeanExercise FxEuropeanExercise (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The parameters for exercising the FxStraddle (underlying options), the underlying options are always European style options."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The parameters for exercising the FxStraddle (underlying options), the underlying options are always European style options."]
    exerciseProcedure ExerciseProcedure (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A set of parameters defining procedures associated with the exercise."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A set of parameters defining procedures associated with the exercise."]
    notional NonNegativeMoney (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The currency amount for the FxStraddle. This will be the notional for the underlying options, which may be exercised by the Buyer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The currency amount for the FxStraddle. This will be the notional for the underlying options, which may be exercised by the Buyer."]
    counterCurrency Currency (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The counter currency and amount for the FxStraddle. The Counter Currency Amount is determined using the notional and the Strike Price (which is determined at the fixingTime on the fixingDate)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The counter currency and amount for the FxStraddle. The Counter Currency Amount is determined using the notional and the Strike Price (which is determined at the fixingTime on the fixingDate)."]
    premium FxStraddlePremium (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the FX Straddle premium amount, payer and dates. This amount is also determined at the fixingTime on the fixingDate."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the FX Straddle premium amount, payer and dates. This amount is also determined at the fixingTime on the fixingDate."]
    settlementDate AdjustableOrAdjustedDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. The settlement date is already expressed by europeanExercise/valueDate. The Settlement Date for the FxStraddle (if exercised at the expiryTime on the expiry Date)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "DEPRECATED. The settlement date is already expressed by europeanExercise/valueDate. The Settlement Date for the FxStraddle (if exercised at the expiryTime on the expiry Date)."]
    cashSettlement FxCashSettlementSimple (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the settlement type for the FxStraddle. If deliverable then this element is removed. If non-deliverable, then the In-The-Money amount of the relevant option within the FxStraddle is paid by the Seller to the Buyer. The In-The-Money amount is calculated using the parameters within this element."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the settlement type for the FxStraddle. If deliverable then this element is removed. If non-deliverable, then the In-The-Money amount of the relevant option within the FxStraddle is paid by the Seller to the Buyer. The In-The-Money amount is calculated using the parameters within this element."]

