namespace fpml.consolidated.fx : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*
import fpml.consolidated.fpmlenum.*
import fpml.consolidated.option.shared.*
import fpml.consolidated.shared.*

typeAlias PointValue: <"Constrains the forward point tick/pip factor to 1, 0.1, 0.01, 0.001, etc.">
    number

type FxDigitalOption extends Option:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Describes an option having a triggerable fixed payout."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Describes an option having a triggerable fixed payout."]

    effectiveDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Effective date for a forward starting derivative. If this element is not present, the effective date is the trade date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Effective date for a forward starting derivative. If this element is not present, the effective date is the trade date."]
    tenorPeriod Period (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A tenor expressed as a period type and multiplier (e.g. 1D, 1Y, etc.)"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A tenor expressed as a period type and multiplier (e.g. 1D, 1Y, etc.)"]
    americanExercise FxDigitalAmericanExercise (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The parameters for defining the exercise period for an American style option."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The parameters for defining the exercise period for an American style option."]
    touch FxTouch (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines one or more conditions underwhich the option will payout if exercisable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines one or more conditions underwhich the option will payout if exercisable."]
    europeanExercise FxEuropeanExercise (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The parameters for defining the exercise period for an European style option."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The parameters for defining the exercise period for an European style option."]
    trigger FxTrigger (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines one or more conditions underwhich the option will payout if exercisable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines one or more conditions underwhich the option will payout if exercisable."]
    exerciseProcedure ExerciseProcedure (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A set of parameters defining procedures associated with the exercise."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A set of parameters defining procedures associated with the exercise."]
    payout FxOptionPayout (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The amount of currency which becomes payable if and when a trigger event occurs."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The amount of currency which becomes payable if and when a trigger event occurs."]
    premium FxOptionPremium (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Premium amount or premium installment amount for an option."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Premium amount or premium installment amount for an option."]

    condition Choice:
        if americanExercise exists
        then touch exists and europeanExercise is absent and trigger is absent
        else europeanExercise exists and trigger exists and touch is absent

type FxFlexibleForward extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Product model for a flexible-term fx forward (also known as callable forward, window forward). This is a term forward transaction over a specific period, allowing the client full flexibility on the timing of the transactional flow(s). The product allows for (full or partial) execution at a predetermined forward rate, at any time between the start date and the expiry date. Although, the product is an outright, it has some option-like characteristics, leading to the use of option components in the model: (i) the BuyerSeller model expresses the roles of the parties in the overall transaction - the client \"buys\" the product (ii) the PutCallCurrency model expresses the buyer\'s perspective on the exchanged currencies i.e. the client may buy (call) or sell (put) the notional currency for the alternative currency."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Product model for a flexible-term fx forward (also known as callable forward, window forward). This is a term forward transaction over a specific period, allowing the client full flexibility on the timing of the transactional flow(s). The product allows for (full or partial) execution at a predetermined forward rate, at any time between the start date and the expiry date. Although, the product is an outright, it has some option-like characteristics, leading to the use of option components in the model: (i) the BuyerSeller model expresses the roles of the parties in the overall transaction - the client \"buys\" the product (ii) the PutCallCurrency model expresses the buyer\'s perspective on the exchanged currencies i.e. the client may buy (call) or sell (put) the notional currency for the alternative currency."]

    buyerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
    buyerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that buys this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that buys this instrument."]
    sellerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
    sellerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that sells this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that sells this instrument."]
    putCurrency Currency (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The currency which: - the option buyer will pay (sell) - the option writer will receive (buy)"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The currency which: - the option buyer will pay (sell) - the option writer will receive (buy)"]
    callCurrency Currency (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The currency which: - the option buyer will receive (buy) - the option writer will pay (sell)"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The currency which: - the option buyer will receive (buy) - the option writer will pay (sell)"]
    notionalAmount NonNegativeMoney (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The aggregate notional amount which will be exchanged, possibly as multiple partial executions, during the course of the execution period. Any residual notional which remains unexchanged at the expiry date will automatically be executed at the applicable exchange rate (strike)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The aggregate notional amount which will be exchanged, possibly as multiple partial executions, during the course of the execution period. Any residual notional which remains unexchanged at the expiry date will automatically be executed at the applicable exchange rate (strike)."]
    minimumExecutionAmount PositiveMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The minimum notional amount which must be executed in any single transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The minimum notional amount which must be executed in any single transaction."]
    settlementAmount NonNegativeMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The total amount of settlement currency that will be paid over the life of the trade if calculable. The Settlement Amount element is a synonym for Contra Amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The total amount of settlement currency that will be paid over the life of the trade if calculable. The Settlement Amount element is a synonym for Contra Amount."]
    executionPeriodDates FxFlexibleForwardExecutionPeriod (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The period during which the client has the right to execute a transaction, on any business day defined by reference to the specified business centers, subject to the constraints of the minimum execution amount and aggregate total notional amount. * Period dates are inclusive i.e. the expiry date is the final date on which execution may occur."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The period during which the client has the right to execute a transaction, on any business day defined by reference to the specified business centers, subject to the constraints of the minimum execution amount and aggregate total notional amount. * Period dates are inclusive i.e. the expiry date is the final date on which execution may occur."]
    earliestExecutionTime BusinessCenterTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The earliest time of day at the specified business center, at which the client may execute a transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The earliest time of day at the specified business center, at which the client may execute a transaction."]
    latestExecutionTime BusinessCenterTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The latest time of day at the specified business center, at which the client may execute a transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The latest time of day at the specified business center, at which the client may execute a transaction."]
    settlementDateOffset RelativeDateOffset (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date on which delivery of the transacted currency amounts will occur, expressed as an offset from the execution date. * This property is optional in the schema, allowing it to be omitted by systems which do not support it; however this information would be expected in contractual documentation (e.g. termsheet, confirmation)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date on which delivery of the transacted currency amounts will occur, expressed as an offset from the execution date. * This property is optional in the schema, allowing it to be omitted by systems which do not support it; however this information would be expected in contractual documentation (e.g. termsheet, confirmation)."]
    finalSettlementDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The final date for settlement. This is the date on which any residual exchange amount will be delivered. * This is an adjusted date i.e. a good business day for delivery in the location(s) specified in executionPeriodDates /businessCenters"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The final date for settlement. This is the date on which any residual exchange amount will be delivered. * This is an adjusted date i.e. a good business day for delivery in the location(s) specified in executionPeriodDates /businessCenters"]
    forwardRate FxFlexibleForwardRate (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Definition of the forward exchange rate for transactions executed during the execution period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Definition of the forward exchange rate for transactions executed during the execution period."]
    additionalPayment Payment (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Fee paid by the client at inception (analagous to an option premium)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Fee paid by the client at inception (analagous to an option premium)."]

type FxForwardVolatilityAgreement extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Describes a contract on future levels of implied volatility. The main characteristic of this product is that the underlying is a straddle (underlying options) with a specific tenor starting from the fixing (effective or pricing) date, and are priced on that fixing date using a level of volatility that is agreed at the time of execution of the volatility agreement."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Describes a contract on future levels of implied volatility. The main characteristic of this product is that the underlying is a straddle (underlying options) with a specific tenor starting from the fixing (effective or pricing) date, and are priced on that fixing date using a level of volatility that is agreed at the time of execution of the volatility agreement."]

    buyerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
    buyerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that buys this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that buys this instrument."]
    sellerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
    sellerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that sells this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that sells this instrument."]
    quotedCurrencyPair QuotedCurrencyPair (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A currency Pair the straddle is based on."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A currency Pair the straddle is based on."]
    fixingDate zonedDateTime (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date when the underlying options are priced using the agreed forwardVolatilityStrikePrice and other market factors as agreed by the parties. Also known as \"Effective Date\" or \"Reference Date\"."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date when the underlying options are priced using the agreed forwardVolatilityStrikePrice and other market factors as agreed by the parties. Also known as \"Effective Date\" or \"Reference Date\"."]
    fixingTime BusinessCenterTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The time of the fixing date when the underlying options are priced using the agreed forwardVolatilityStrikePrice and other market factors as agreed by the parties."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The time of the fixing date when the underlying options are priced using the agreed forwardVolatilityStrikePrice and other market factors as agreed by the parties."]
    forwardVolatilityStrikePrice PositiveDecimal (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "the Volatility level as agreed on the Trade Date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "the Volatility level as agreed on the Trade Date."]
    straddle FxStraddle (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "details of the straddle (underlying options)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "details of the straddle (underlying options)."]
    additionalPayment Payment (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The currency, amount and payment details for the Forward Volatility Agreement, as agreed at the time of execution."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The currency, amount and payment details for the Forward Volatility Agreement, as agreed at the time of execution."]

type FxOption extends Option:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Describes an FX option with optional asian and barrier features."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Describes an FX option with optional asian and barrier features."]

    effectiveDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Effective date for a forward starting derivative. If this element is not present, the effective date is the trade date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Effective date for a forward starting derivative. If this element is not present, the effective date is the trade date."]
    tenorPeriod Period (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A tenor expressed as a period type and multiplier (e.g. 1D, 1Y, etc.)"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A tenor expressed as a period type and multiplier (e.g. 1D, 1Y, etc.)"]
    americanExercise FxAmericanExercise (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The parameters for defining the exercise period for an American style option."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The parameters for defining the exercise period for an American style option."]
    europeanExercise FxEuropeanExercise (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The parameters for defining the exercise period for an European style option."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The parameters for defining the exercise period for an European style option."]
    exerciseProcedure ExerciseProcedure (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A set of parameters defining procedures associated with the exercise."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A set of parameters defining procedures associated with the exercise."]
    putCurrencyAmount NonNegativeMoney (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The currency amount that the option gives the right to sell."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The currency amount that the option gives the right to sell."]
    callCurrencyAmount NonNegativeMoney (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The currency amount that the option gives the right to buy."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The currency amount that the option gives the right to buy."]
    soldAs PutCallEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates how the product was original sold as a Put or a Call."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates how the product was original sold as a Put or a Call."]
    strike FxStrikePrice (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the option strike price."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the option strike price."]
    spotRate PositiveDecimal (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "An optional element used for FX forwards and certain types of FX OTC options. For deals consumated in the FX Forwards Market, this represents the current market rate for a particular currency pair. For barrier and digital/binary options, it can be useful to include the spot rate at the time the option was executed to make it easier to know whether the option needs to move \"up\" or \"down\" to be triggered."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "An optional element used for FX forwards and certain types of FX OTC options. For deals consumated in the FX Forwards Market, this represents the current market rate for a particular currency pair. For barrier and digital/binary options, it can be useful to include the spot rate at the time the option was executed to make it easier to know whether the option needs to move \"up\" or \"down\" to be triggered."]
    features FxOptionFeatures (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Describes additional features within the option."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Describes additional features within the option."]
    premium FxOptionPremium (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Premium amount or premium installment amount for an option."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Premium amount or premium installment amount for an option."]
    cashSettlement FxCashSettlement (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the currency and fixing details for cash settlement. This optional element is produced only where it has been specified at execution time that the option wlll be settled into a single cash payment - for example, in the case of a non-deliverable option (although note that an Fx option may be contractually cash settled, without necessarily being non-deliverable)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the currency and fixing details for cash settlement. This optional element is produced only where it has been specified at execution time that the option wlll be settled into a single cash payment - for example, in the case of a non-deliverable option (although note that an Fx option may be contractually cash settled, without necessarily being non-deliverable)."]

    condition Choice:
        optional choice americanExercise, europeanExercise

type FxSingleLeg extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining either a spot or forward FX transactions."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining either a spot or forward FX transactions."]

    exchangedCurrency1 Payment (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This is the first of the two currency flows that define a single leg of a standard foreign exchange transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This is the first of the two currency flows that define a single leg of a standard foreign exchange transaction."]
    exchangedCurrency2 Payment (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This is the second of the two currency flows that define a single leg of a standard foreign exchange transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This is the second of the two currency flows that define a single leg of a standard foreign exchange transaction."]
    dealtCurrency DealtCurrencyEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates which currency was dealt."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates which currency was dealt."]
    tenorName FxTenorPeriodEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A tenor expressed with a standard business term (i.e. Spot, TomorrowNext, etc.)"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A tenor expressed with a standard business term (i.e. Spot, TomorrowNext, etc.)"]
    tenorPeriod Period (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A tenor expressed as a period type and multiplier (e.g. 1D, 1Y, etc.)"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A tenor expressed as a period type and multiplier (e.g. 1D, 1Y, etc.)"]
    valueDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date on which both currencies traded will settle."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date on which both currencies traded will settle."]
    currency1ValueDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date on which the currency1 amount will be settled. To be used in a split value date scenario."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date on which the currency1 amount will be settled. To be used in a split value date scenario."]
    currency2ValueDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date on which the currency2 amount will be settled. To be used in a split value date scenario."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date on which the currency2 amount will be settled. To be used in a split value date scenario."]
    exchangeRate ExchangeRate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The rate of exchange between the two currencies."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The rate of exchange between the two currencies."]
    nonDeliverableSettlement FxCashSettlement (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Used to describe a particular type of FX forward transaction that is settled in a single currency (for example, a non-deliverable forward)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Used to describe a particular type of FX forward transaction that is settled in a single currency (for example, a non-deliverable forward)."]
    disruption FxDisruption (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Describes the disruption events and fallbacks applicable to a currency pair referenced by the transaction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Describes the disruption events and fallbacks applicable to a currency pair referenced by the transaction."]

    condition Choice0:
        optional choice tenorName, tenorPeriod

    condition Choice1:
        if valueDate exists
        then currency1ValueDate is absent and currency2ValueDate is absent
        else currency1ValueDate exists and currency2ValueDate exists

type FxSwap extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining either a spot/forward or forward/forward FX swap transaction."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining either a spot/forward or forward/forward FX swap transaction."]

