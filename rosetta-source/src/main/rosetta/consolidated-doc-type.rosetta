        [docReference ISDA FPML version "confirmation-5.13"]
    verificationMethodScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type VersionedTradeId:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Trade Id with Version Support"]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Trade Id with Version Support"]

    tradeId TradeId (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    version int(min: 0) (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The version number"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The version number"]
    effectiveDate IdentifiedDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Optionally it is possible to specify a version effective date when a versionId is supplied."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Optionally it is possible to specify a version effective date when a versionId is supplied."]

type ContractId:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A contact id identifier allocated by a party. FpML does not define the domain values associated with this element."]

    value NonEmptyScheme (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    contractIdScheme NonEmptyURI (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    id string (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]

type ContractIdentifier:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining a contract identifier issued by the indicated party."]

    id string (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    partyReference PartyReference (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a party identifier defined elsewhere in the document. The party referenced has allocated the contract identifier."]
    contractId ContractId (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A contract id which is not version aware."]
    versionedContractId VersionedContractId (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A contract id which is version aware."]

    condition Choice:
        required choice contractId, versionedContractId

type PackageInformation:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining additional information that may be recorded against a package of trades."]

    relatedParty RelatedParty (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This may be used to identify one or more parties that perform a role within the transaction. If this is within a partyTradeInformation block, the related party performs the role with respect to the party identifie by the \"partyReference\" in the partyTradeInformation block."]
    category TradeCategory (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Used to categorize trades into user-defined categories, such as house trades vs. customer trades."]
    executionDateTime ExecutionDateTime (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Trade execution date time, for example as provided by a central execution facility. Normally this refers to the original execution time of the trade, not the execution time of any post-trade events that may have affected it. However, in the case of a post trade event that reports the new version of the trade (for example, the novation trade in an novation event, or the amended trade in an amendment event), the execution date time may contain the time that the newly created or modified trade was created or modified."]
    timestamps TradeProcessingTimestamps (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Allows timing information about a trade to be recorded."]
    intentToAllocate boolean (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies whether the trade is anticipated to be allocated."]
    allocationStatus AllocationReportingStatus (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies whether the trade is anticipated to be allocated, has been allocated, or will not be allocated."]
    intentToClear boolean (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies whether the trade is anticipated to be cleared via a derivative clearing organization"]
    clearingStatus ClearingStatusValue (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Describes the status with respect to clearing (e.g. AwaitingAcceptance, Pending, Accepted, Rejected, etc.)"]
    executionVenueType ExecutionVenueType (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Used to describe the type of venue where trade was executed, e.g via an execution facility or privately."]

type Portfolio:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type representing an arbitary grouping of trade references."]

    id string (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    partyPortfolioName PartyPortfolioName (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The name of the portfolio together with the party that gave the name."]
    tradeId TradeId (0..*)
        [docReference ISDA FPML version "confirmation-5.13"]
    partyTradeIdentifier PartyTradeIdentifier (0..*)
        [docReference ISDA FPML version "confirmation-5.13"]
    portfolio Portfolio (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "An arbitary grouping of trade references (and possibly other portfolios)."]

    condition Choice:
        optional choice tradeId, partyTradeIdentifier

type TradeDifference:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type used to record the details of a difference between two business objects/"]

    differenceType DifferenceTypeEnum (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The type of difference that exists."]
    differenceSeverity DifferenceSeverityEnum (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "An indication of the severity of the difference."]
    element NonEmptyToken (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The name of the element affected."]
    basePath NonEmptyToken (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "XPath to the element in the base object."]
    baseValue NonEmptyToken (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The value of the element in the base object."]
    otherPath NonEmptyToken (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "XPath to the element in the other object."]
    otherValue NonEmptyToken (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Value of the element in the other trade."]
    missingElement NonEmptyToken (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Element(s) that are missing in the other trade."]
    extraElement NonEmptyToken (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Element(s) that are extraneous in the other object."]
    message NonEmptyNormalizedString (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A human readable description of the problem."]

type Trader:
    [docReference ISDA FPML version "confirmation-5.13"]

    value Scheme (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    traderScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]

