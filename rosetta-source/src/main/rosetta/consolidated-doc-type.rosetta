namespace fpml.consolidated.doc : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*
import fpml.consolidated.asset.*
import fpml.consolidated.fpmlenum.*
import fpml.consolidated.shared.*

typeAlias FpMLVersion: Token

type InstrumentTradeDetails extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "The economics of a trade of a multiply traded instrument."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "The economics of a trade of a multiply traded instrument."]

    buyerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that buys this instrument, ie. pays for this instrument and receives the rights defined by it. See 2000 ISDA definitions Article 11.1 (b). In the case of FRAs this the fixed rate payer."]
    buyerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that buys this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that buys this instrument."]
    sellerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that sells (\"writes\") this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. See 2000 ISDA definitions Article 11.1 (a). In the case of FRAs this is the floating rate payer."]
    sellerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that sells this instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that sells this instrument."]
    underlyingAsset Asset (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The FpML asset description for the asset."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The FpML asset description for the asset."]
    quantity InstrumentTradeQuantity (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A description of how much of the instrument was traded."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A description of how much of the instrument was traded."]
    pricing InstrumentTradePricing (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The price paid for the instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The price paid for the instrument."]
    principal InstrumentTradePrincipal (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The value, in instrument currency, of the amount of the instrument that was traded."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The value, in instrument currency, of the amount of the instrument that was traded."]

type Strategy extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining a group of products making up a single trade."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining a group of products making up a single trade."]

    strategyComponentIdentifier StrategyComponentIdentification (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Provides distinct identification for a component of a strategy."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Provides distinct identification for a component of a strategy."]
    premiumProductReference ProductReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates which product within a strategy represents the premium payment."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates which product within a strategy represents the premium payment."]
    product Product (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type AdditionalData:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Provides extra information not represented in the model that may be useful in processing the message i.e. diagnosing the reason for failure."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Provides extra information not represented in the model that may be useful in processing the message i.e. diagnosing the reason for failure."]

    mimeType MimeType (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates the type of media used to provide the extra information. mimeType is used to determine the software product(s) that can read the content. MIME Types are described in RFC 2046."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates the type of media used to provide the extra information. mimeType is used to determine the software product(s) that can read the content. MIME Types are described in RFC 2046."]
    string NonEmptyString (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Provides extra information as string. In case the extra information is in XML format, a CDATA section must be placed around the source message to prevent its interpretation as XML content."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Provides extra information as string. In case the extra information is in XML format, a CDATA section must be placed around the source message to prevent its interpretation as XML content."]
    hexadecimalBinary string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Provides extra information as binary contents coded in hexadecimal."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Provides extra information as binary contents coded in hexadecimal."]
    base64Binary string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Provides extra information as binary contents coded in base64."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Provides extra information as binary contents coded in base64."]
    originalMessage UnprocessedElementWrapper (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Provides the content of the original message."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Provides the content of the original message."]

    condition Choice:
        optional choice string, hexadecimalBinary, base64Binary, originalMessage

type AdmissionToTrading:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Information about whether and when a product was admitted to trading on a facility."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Information about whether and when a product was admitted to trading on a facility."]

    requested boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Whether the issuer of the financial instrument has requested or approved the trading or admission to trading of their financial instruments on a trading venue."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Whether the issuer of the financial instrument has requested or approved the trading or admission to trading of their financial instruments on a trading venue."]
    requestDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Date and time of the request for admission to trading on the trading venue."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date and time of the request for admission to trading on the trading venue."]
    approvalDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Date and time the issuer has approved admission to trading or trading in its financial instruments on a trading venue."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date and time the issuer has approved admission to trading or trading in its financial instruments on a trading venue."]
    admissionDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Date and time of the admission to trading on the trading venue or the date and time when the instrument was first traded or an order or quote was first received by the trading venue."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date and time of the admission to trading on the trading venue or the date and time when the instrument was first traded or an order or quote was first received by the trading venue."]
    terminationDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Date and time when the financial instrument ceases to be traded or to be admitted to trading on the trading venue."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date and time when the financial instrument ceases to be traded or to be admitted to trading on the trading venue."]

type Algorithm:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    name string (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The name of the algorithm."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The name of the algorithm."]
    role AlgorithmRole (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The category of the function of the algorithm. The related individual performs the role specified in this field for the base party. For example, if the role is \"Trader\", the related person acts acts or acted as the base party\'s trader."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The category of the function of the algorithm. The related individual performs the role specified in this field for the base party. For example, if the role is \"Trader\", the related person acts acts or acted as the base party\'s trader."]

type AlgorithmRole:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing a role played by an algorithm in one or more transactions. Examples include roles such as TradingDecision, RoutingDecision. This can be extended to provide custom roles."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing a role played by an algorithm in one or more transactions. Examples include roles such as TradingDecision, RoutingDecision. This can be extended to provide custom roles."]

    value Scheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    algorithmRoleScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type Allocation:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    allocationTradeId TradeIdentifier (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Unique ID for the allocation. Multiple allocation trade IDs are provided to allow for the use of USI/UTI representations along with party-specific trade identifiers."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Unique ID for the allocation. Multiple allocation trade IDs are provided to allow for the use of USI/UTI representations along with party-specific trade identifiers."]
    partyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to a party."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to a party."]
    accountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to an account."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to an account."]
    allocatedFraction number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The fractional allocation (0.45 = 45%) of the notional and \"block\" fees to this particular client subaccount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The fractional allocation (0.45 = 45%) of the notional and \"block\" fees to this particular client subaccount."]
    allocatedNotional Money (0..2)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The notional allocation (amount and currency) to this particular client account."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The notional allocation (amount and currency) to this particular client account."]
    collateral Collateral (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The sum that must be posted upfront to collateralize against counterparty credit risk."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The sum that must be posted upfront to collateralize against counterparty credit risk."]
    creditChargeAmount Money (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Special credit fee assessed to certain institutions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Special credit fee assessed to certain institutions."]
    approvals Approvals (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A container for approval states in the workflow."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A container for approval states in the workflow."]
    masterConfirmationDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date of the confirmation executed between the parties and intended to govern the allocated trade between those parties."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date of the confirmation executed between the parties and intended to govern the allocated trade between those parties."]
    relatedParty RelatedParty (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies any relevant parties to the allocation which should be referenced."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies any relevant parties to the allocation which should be referenced."]

    condition Choice:
        optional choice allocatedFraction, allocatedNotional

type AllocationReportingStatus:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Code that describes what type of allocation applies to the trade. Options include Unallocated, PreAllocation, PostAllocation."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Code that describes what type of allocation applies to the trade. Options include Unallocated, PreAllocation, PostAllocation."]

    value Scheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    allocationReportingStatusScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type Allocations:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "The allocations for a single side of a trade."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "The allocations for a single side of a trade."]

    allocatingPartyReference PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to one of the parties to the trade, defined elsewhere in the document. The party referenced has requested its position in the trade to be allocated to several other parties or accounts."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to one of the parties to the trade, defined elsewhere in the document. The party referenced has requested its position in the trade to be allocated to several other parties or accounts."]
    allocation Allocation (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type Approval:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A specific approval state in the workflow."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A specific approval state in the workflow."]

    ^type ApprovalType (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The type of approval (e.g. \"pre-clearing credit\")."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The type of approval (e.g. \"pre-clearing credit\")."]
    status NormalizedString (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The current state of approval (.e.g preapproved, pending approval, etc.)"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The current state of approval (.e.g preapproved, pending approval, etc.)"]
    approver PersonId (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The full name or identifiying ID of the relevant approver."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The full name or identifiying ID of the relevant approver."]
    approvingPartyReference PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to a party defined elsewhere in the document. The party referenced has approved the specified item (e.g. trade or allocation)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a party defined elsewhere in the document. The party referenced has approved the specified item (e.g. trade or allocation)."]
    approvedPartyReference PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to a party defined elsewhere in the document. The party referenced was approved for the specified item (e.g. trade or allocation) by the approving party (if specified)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a party defined elsewhere in the document. The party referenced was approved for the specified item (e.g. trade or allocation) by the approving party (if specified)."]
    approvalId ApprovalId (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "An identifer for a specific appoval, to allow the approval to be identified and tracked."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "An identifer for a specific appoval, to allow the approval to be identified and tracked."]

type ApprovalId:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "An approval identifier allocated by a party. FpML does not define the domain values associated with this element."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An approval identifier allocated by a party. FpML does not define the domain values associated with this element."]

    value NonEmptyScheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    approvalIdScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type Approvals:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    approval Approval (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type ApprovalType:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type that qualifies the type of approval."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type that qualifies the type of approval."]

    value Scheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    approvalTypeScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type ClearingStatusValue:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "The current status value of a clearing request."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "The current status value of a clearing request."]

    value Scheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    clearingStatusScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type ClearingExceptionReason:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "The reason a trade is exempted from a clearing mandate."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "The reason a trade is exempted from a clearing mandate."]

    value Scheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    clearingExceptionReasonScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type ConfirmationMethod:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type used to represent the type of mechanism that can be used to confirm a trade."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type used to represent the type of mechanism that can be used to confirm a trade."]

    value Scheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    confirmationMethodScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type CreditDerivativesNotices:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    creditEvent boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This element corresponds to the Credit Event Notice Delivered Under Old Transaction and Deemed Delivered Under New Transaction under the EXHIBIT C to 2004 ISDA Novation Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This element corresponds to the Credit Event Notice Delivered Under Old Transaction and Deemed Delivered Under New Transaction under the EXHIBIT C to 2004 ISDA Novation Definitions."]
    publiclyAvailableInformation boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This element corresponds to the Notice of Publicly Available Information Delivered Under Old Transaction and Deemed Delivered Under New Transaction under the EXHIBIT C to 2004 ISDA Novation Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This element corresponds to the Notice of Publicly Available Information Delivered Under Old Transaction and Deemed Delivered Under New Transaction under the EXHIBIT C to 2004 ISDA Novation Definitions."]
    physicalSettlement boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This element corresponds to the Notice of Intended Physical Settlement Delivered Under Old Transaction under the EXHIBIT C to 2004 ISDA Novation Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This element corresponds to the Notice of Intended Physical Settlement Delivered Under Old Transaction under the EXHIBIT C to 2004 ISDA Novation Definitions."]

type CreditDocument:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A credit arrangement used in support of swaps trading."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A credit arrangement used in support of swaps trading."]

    value Scheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    creditDocumentScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type CurrencyPairClassification:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type containing a code representing the risk classification of a currency pair, as specified by a regulator."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type containing a code representing the risk classification of a currency pair, as specified by a regulator."]

    value Scheme (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    currencyPairClassificationScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type Document:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "The abstract base type from which all FpML compliant messages and documents must be derived."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "The abstract base type from which all FpML compliant messages and documents must be derived."]

    fpmlVersion FpMLVersion (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicate which version of the FpML Schema an FpML message adheres to."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicate which version of the FpML Schema an FpML message adheres to."]
    expectedBuild int(min: 1) (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This optional attribute can be supplied by a message creator in an FpML instance to specify which build number of the schema was used to define the message when it was generated."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This optional attribute can be supplied by a message creator in an FpML instance to specify which build number of the schema was used to define the message when it was generated."]
    actualBuild int(min: 1) (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The specific build number of this schema version. This attribute is not included in an instance document. Instead, it is supplied by the XML parser when the document is validated against the FpML schema and indicates the build number of the schema file. Every time FpML publishes a change to the schema, validation rules, or examples within a version (e.g., version 4.2) the actual build number is incremented. If no changes have been made between releases within a version (i.e. from Trial Recommendation to Recommendation) the actual build number stays the same."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The specific build number of this schema version. This attribute is not included in an instance document. Instead, it is supplied by the XML parser when the document is validated against the FpML schema and indicates the build number of the schema file. Every time FpML publishes a change to the schema, validation rules, or examples within a version (e.g., version 4.2) the actual build number is incremented. If no changes have been made between releases within a version (i.e. from Trial Recommendation to Recommendation) the actual build number stays the same."]

