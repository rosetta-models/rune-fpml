        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Information about the trade package if any that the trade originated from."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Information about the trade package if any that the trade originated from."]
    tradeDate IdentifiedDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The trade date. This is the date the trade was originally executed. In the case of a novation, the novated part of the trade should be reported (by both the remaining party and the transferee) using a trade date corresponding to the date the novation was agreed. The remaining part of a trade should be reported (by both the transferor and the remaining party) using a trade date corresponding to the original execution date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The trade date. This is the date the trade was originally executed. In the case of a novation, the novated part of the trade should be reported (by both the remaining party and the transferee) using a trade date corresponding to the date the novation was agreed. The remaining part of a trade should be reported (by both the transferor and the remaining party) using a trade date corresponding to the original execution date."]
    clearedDate IdentifiedDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If the trade was cleared (novated) through a central counterparty clearing service, this represents the date the trade was cleared (transferred to the central counterparty)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If the trade was cleared (novated) through a central counterparty clearing service, this represents the date the trade was cleared (transferred to the central counterparty)."]

    condition Choice:
        if uniqueSwapIdentifier exists
        then True
        else uniqueTransactionIdentifier exists or partyTradeIdentifier exists

type TradeIdentifier:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining a trade identifier issued by the indicated party."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining a trade identifier issued by the indicated party."]

    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    issuer IssuerId (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    tradeId TradeId (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    partyReference PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to a party."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to a party."]
    accountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to an account."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to an account."]
    tradeIdentifierChoice TradeIdentifierChoice (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

    condition Choice:
        if issuer exists or tradeId exists
        then issuer exists
                and tradeId exists
                and partyReference is absent
                and accountReference is absent
                and tradeIdentifierChoice is absent
        else if partyReference exists
        then issuer is absent and tradeId is absent
        else issuer is absent
            and tradeId is absent
            and partyReference is absent
            and accountReference is absent
            and tradeIdentifierChoice is absent

type TradeIdentifierChoice:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    tradeId TradeId (0..1)
