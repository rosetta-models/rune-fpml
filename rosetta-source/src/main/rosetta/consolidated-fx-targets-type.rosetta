namespace fpml.consolidated.fx.targets : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*
import fpml.consolidated.fpmlenum.*
import fpml.consolidated.shared.*

type FxTargetKnockoutForward extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structured forward product which consists of a strip of forwards. Each forward may be settled as an exchange of currencies or cash settled. At each settlement, the amount of gain that one party achieves is measured. The product has a target level of gain. Once the accumulated gain exceeds the target level, the product terminates and there are no further settlements."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structured forward product which consists of a strip of forwards. Each forward may be settled as an exchange of currencies or cash settled. At each settlement, the amount of gain that one party achieves is measured. The product has a target level of gain. Once the accumulated gain exceeds the target level, the product terminates and there are no further settlements."]

    quotedCurrencyPair QuotedCurrencyPair (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Quoted Currency Pair that is used accross the product."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Quoted Currency Pair that is used accross the product."]
    notionalAmount NonNegativeAmountSchedule (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Notional amount of the Target."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Notional amount of the Target."]
    target FxTarget (1..2)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "It defines the target level of gain. Once the accumulated gain exceeds the target level, the product terminates and there are no further settlements."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "It defines the target level of gain. Once the accumulated gain exceeds the target level, the product terminates and there are no further settlements."]
    expirySchedule FxExpirySchedule (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the expiry/observation schedule of the target product."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the expiry/observation schedule of the target product."]
    settlementSchedule FxSettlementSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the settlement/payment schedule of the target product."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the settlement/payment schedule of the target product."]
    fixingInformationSource FxInformationSource (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Information source for fixing the exchange rate. It is the same for all fixing periods."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Information source for fixing the exchange rate. It is the same for all fixing periods."]
    spotRate NonNegativeDecimal (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Spot rate"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Spot rate"]
    pivot FxPivot (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The boundary where the contract flips from being long and short is the pivot point. So the pivot indicates the level in which there is a change in direction of the currencies exchanged by the parties."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The boundary where the contract flips from being long and short is the pivot point. So the pivot indicates the level in which there is a change in direction of the currencies exchanged by the parties."]
    constantPayoffRegion FxTargetConstantPayoffRegion (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A region in which constant payoff applies i.e. the payoff is defined as a contant currency amount or fixing adjustment, unrelated to the fixing. In absence of the \"payoff\" element, zero payoff is assumed (note: zero payoff does not necessarily imply that no settlement occurs)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A region in which constant payoff applies i.e. the payoff is defined as a contant currency amount or fixing adjustment, unrelated to the fixing. In absence of the \"payoff\" element, zero payoff is assumed (note: zero payoff does not necessarily imply that no settlement occurs)."]
    linearPayoffRegion FxTargetLinearPayoffRegion (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A region in which linear payoff applies i.e. the payoff bears a linear relationship to the fixing value (increases/decreases linearly with the fixing)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A region in which linear payoff applies i.e. the payoff bears a linear relationship to the fixing value (increases/decreases linearly with the fixing)."]
    fxTargetKnockoutForwardChoice FxTargetKnockoutForwardChoice (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    barrier FxTargetBarrier (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Generic FxTarget barrier. Element \"scope\" specifies whether the barrier has effect for the expiry period in which it is observed, or globally for whole product. Optional element \"rebate\" may be produced in conjunction with a Global Knockout barrier, to specify a rebate payable in the event of knockout."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Generic FxTarget barrier. Element \"scope\" specifies whether the barrier has effect for the expiry period in which it is observed, or globally for whole product. Optional element \"rebate\" may be produced in conjunction with a Global Knockout barrier, to specify a rebate payable in the event of knockout."]
    additionalPayment SimplePayment (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "It supports the representation of premiums, fees, etc."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "It supports the representation of premiums, fees, etc."]
    cashSettlement FxCashSettlementSimple (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Cash settlement currency."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Cash settlement currency."]
    settlementPeriodSchedule FxTargetSettlementPeriodSchedule (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "It supports the representation of a matrix/tabular approach of the product by defining a set of settlement periods."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "It supports the representation of a matrix/tabular approach of the product by defining a set of settlement periods."]

type FxComplexBarrierBase:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Attribute to be able to point to the"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Attribute to be able to point to the"]
    barrierType FxBarrierTypeSimpleEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the outcome (action) in the event that the barrier is triggered i.e. whether the product becomes active (Knockin) or is extinguished (Knockout)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the outcome (action) in the event that the barrier is triggered i.e. whether the product becomes active (Knockin) or is extinguished (Knockout)."]
    style FxBarrierStyleEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The barrier observation style: continuous (American) or discrete (European)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The barrier observation style: continuous (American) or discrete (European)."]
    scope FxBarrierScopeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The scope of the barrier (PerExpiry|Global). Specifies whether the barrier has effect for the current expiry period (in the case of a multi-phase product), or for the product as a whole."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The scope of the barrier (PerExpiry|Global). Specifies whether the barrier has effect for the current expiry period (in the case of a multi-phase product), or for the product as a whole."]
    condition ConditionEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the condition when the barrier applies: AtOrAbove, AtOrBelow, Above, Below."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the condition when the barrier applies: AtOrAbove, AtOrBelow, Above, Below."]
    triggerRate Schedule (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The market rate is observed relative to the trigger rate, and if it is found to be on the predefined side of (above or below) the trigger rate, a barrier event is deemed to have occurred."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The market rate is observed relative to the trigger rate, and if it is found to be on the predefined side of (above or below) the trigger rate, a barrier event is deemed to have occurred."]
    observationStartDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date on which the observation period for an american barrier starts. If the start date is not present, then the date and time of the start of the period is deemed to be the date and time the transaction was entered into."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date on which the observation period for an american barrier starts. If the start date is not present, then the date and time of the start of the period is deemed to be the date and time the transaction was entered into."]
    observationStartTime BusinessCenterTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The time on the start date at which the observation period for an american barrier starts. If the time is not present and the start date is equivalent to the transaction date, the time is deemed to be the time the transaction was entered into. If the time is not present and the start date is other than the transaction date, then the time is deemed to be the same as the expiration time."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The time on the start date at which the observation period for an american barrier starts. If the time is not present and the start date is equivalent to the transaction date, the time is deemed to be the time the transaction was entered into. If the time is not present and the start date is other than the transaction date, then the time is deemed to be the same as the expiration time."]
    observationEndDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date on which the observation period for an american barrier ends. If the end date is not present, then the date and time of the end of the period is deemed to be the date and time of expiration."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date on which the observation period for an american barrier ends. If the end date is not present, then the date and time of the end of the period is deemed to be the date and time of expiration."]
    observationEndTime BusinessCenterTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The time on the end date at which the observation period for an american barrier ends. If the time is not present, then the time is deemed to be the same as the expiration time."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The time on the end date at which the observation period for an american barrier ends. If the time is not present, then the time is deemed to be the same as the expiration time."]

type FxComplexBarrierBaseReference extends fpml.consolidated.shared.Reference:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Reference to a barrier structure defined within the parametric representation."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Reference to a barrier structure defined within the parametric representation."]

    href string (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type FxCounterCurrencyAmount extends NonNegativeAmountSchedule:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    strikeReference FxStrikeReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "In case of multiple counter currency notionals, a strike reference to the appropriate strike may be provided."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "In case of multiple counter currency notionals, a strike reference to the appropriate strike may be provided."]

type FxDateOffset:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "The representation of the schedule as an offset relative to another schedule. For example, the settlement schedule may be relative to the expiry schedule by an FxForward offset."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "The representation of the schedule as an offset relative to another schedule. For example, the settlement schedule may be relative to the expiry schedule by an FxForward offset."]

    convention FxOffsetConventionEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The FX Offset Convention can be FxSpot or FxForward."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The FX Offset Convention can be FxSpot or FxForward."]
    offset Period (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The settlement offset to the expiry schedule or the expiry offset to the settlement schedule. It is only specified when the settlement convention is FxForward."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The settlement offset to the expiry schedule or the expiry offset to the settlement schedule. It is only specified when the settlement convention is FxForward."]
    relativeTo FxScheduleReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates whether the settlement schedule is relative to the expiry schedule or the expiry schedule is relative to the settlement schedule."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates whether the settlement schedule is relative to the expiry schedule or the expiry schedule is relative to the settlement schedule."]

type FxExchangedCurrency:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Indicates the direction who pays and receives a specific currency without specifying the amount."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Indicates the direction who pays and receives a specific currency without specifying the amount."]

    payerPartyReference PartyReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party responsible for making the payments defined by this structure."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party responsible for making the payments defined by this structure."]
    payerAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account responsible for making the payments defined by this structure."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account responsible for making the payments defined by this structure."]
    receiverPartyReference PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party that receives the payments corresponding to this structure."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party that receives the payments corresponding to this structure."]
    receiverAccountReference AccountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the account that receives the payments corresponding to this structure."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the account that receives the payments corresponding to this structure."]
    currency Currency (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type FxExpirySchedule extends FxSchedule:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Defines the expiry/observation schedule of the target."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Defines the expiry/observation schedule of the target."]

    finalExpiryDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The final expiry date facilitates informing the final date without having to process all expiry dates in the schedule."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The final expiry date facilitates informing the final date without having to process all expiry dates in the schedule."]
    expiryTime BusinessCenterTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Time of expiration of each expiry date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Time of expiration of each expiry date."]

type FxKnockoutCount:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    conditionalFixings int (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Number of fixings that are in the money. No accumulation process."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Number of fixings that are in the money. No accumulation process."]
    settlementAtKnockout boolean (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Whether there is settlement at knockout."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Whether there is settlement at knockout."]

type FxKnockoutLevel:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Defines the Target level of gain."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Defines the Target level of gain."]

    amount NonNegativeMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Target level expressed as a cash amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Target level expressed as a cash amount."]
    intrinsicValue number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Target level expressed as intrinsic value (cumulative benefit over the prevailing spot rate at each observation point)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Target level expressed as intrinsic value (cumulative benefit over the prevailing spot rate at each observation point)."]
    targetStyle FxTargetStyleEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Target style when it settles, whether it is Inclusive, Exclusive, or Exact. Exclusive: the gain for the knockout period is adjusted to zero i.e. the target yields zero value in the final period. Exact: the gain for the knockout period is adjusted to yield a final accumulated value equal to the target level. Inclusive: the gain for the knockout period is equal to the whole benefit of the final fixing over spot i.e. the final accumulated value may exceed the target level."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Target style when it settles, whether it is Inclusive, Exclusive, or Exact. Exclusive: the gain for the knockout period is adjusted to zero i.e. the target yields zero value in the final period. Exact: the gain for the knockout period is adjusted to yield a final accumulated value equal to the target level. Inclusive: the gain for the knockout period is equal to the whole benefit of the final fixing over spot i.e. the final accumulated value may exceed the target level."]
    settlementAdjustmentStyle FxSettlementAdjustmentMethodEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the calculation method by which the final accumulated value is adjusted equal to the target value, in the case where the target style is \"Exact\". This element must be produced (only) where the target style is \"Exact\", and should be omitted otherwise."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the calculation method by which the final accumulated value is adjusted equal to the target value, in the case where the target style is \"Exact\". This element must be produced (only) where the target style is \"Exact\", and should be omitted otherwise."]

    condition Choice:
        required choice amount, intrinsicValue

type FxLevel extends Schedule:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Level is expressed as Schedule, with an initial value and optional steps."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Level is expressed as Schedule, with an initial value and optional steps."]

type FxLevelReference extends fpml.consolidated.shared.Reference:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Reference to a level structure."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Reference to a level structure."]

    href string (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type FxOutstandingGain:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    targetReference FxTargetReference (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to a target structure within the product."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to a target structure within the product."]
    settlementAdjustmentStyle FxSettlementAdjustmentMethodEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Settlement Adjustment Style can be VariedStrike or VariedNotional."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Settlement Adjustment Style can be VariedStrike or VariedNotional."]

type FxPayoffCap:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "The amount of gain on the client upside or firm upside is limited. If spot settles above the cap, or below the floor, the payout is adjusted to limit the gain. The adjustment may be made by varying the strike, or by maintaining the strike, but varying the payout notionals."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "The amount of gain on the client upside or firm upside is limited. If spot settles above the cap, or below the floor, the payout is adjusted to limit the gain. The adjustment may be made by varying the strike, or by maintaining the strike, but varying the payout notionals."]

    condition ConditionEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Condition in which Cap or Floor applies."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Condition in which Cap or Floor applies."]
    rate Schedule (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Cap/Floor rate."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Cap/Floor rate."]
    settlementAdjustmentStyle FxSettlementAdjustmentMethodEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Settlement Adjustment Style can be VariedStrike or VariedNotional."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Settlement Adjustment Style can be VariedStrike or VariedNotional."]

type FxPivot extends Schedule:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Pivot is expressed as Schedule, with an initial value and optional steps."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Pivot is expressed as Schedule, with an initial value and optional steps."]

type FxPivotReference extends fpml.consolidated.shared.Reference:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Reference to a pivot structure."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Reference to a pivot structure."]

    href string (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type FxSchedule:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "The FxSchedule may be expressed as explicit adjusted dates, or a parametric representation plus optional adjusted dates, or as an offset plus optional adusted dates."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "The FxSchedule may be expressed as explicit adjusted dates, or a parametric representation plus optional adjusted dates, or as an offset plus optional adusted dates."]

    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    dateAdjustments BusinessDayAdjustments (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Date adjustments applied to the adjusted dates including the business day convention and the business centers."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date adjustments applied to the adjusted dates including the business day convention and the business centers."]
    adjustedDate zonedDateTime (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "List of schedule dates. These dates have been subject to adjustments based on the dateAdjustments structure."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "List of schedule dates. These dates have been subject to adjustments based on the dateAdjustments structure."]
    startDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Start of the schedule."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Start of the schedule."]
    endDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "End of the schedule."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "End of the schedule."]
    observationFrequency ObservationFrequency (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the frequency at which calculation period end dates occur within the period schedule and their roll date convention."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the frequency at which calculation period end dates occur within the period schedule and their roll date convention."]
    dayType DayTypeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A day type classification, e.g. Business, Calendar, etc."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A day type classification, e.g. Business, Calendar, etc."]
    businessCentersReference BusinessCentersReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A pointer style reference to a set of financial business centers defined elsewhere in the document. This set of business centers is used to determine whether a particular day is a business day or not."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A pointer style reference to a set of financial business centers defined elsewhere in the document. This set of business centers is used to determine whether a particular day is a business day or not."]
    businessCenters BusinessCenters (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    dateOffset FxDateOffset (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The representation of the schedule as an offset relative to another schedule. For example, the settlement schedule may be relative to the expiry schedule by an FxForward offset."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The representation of the schedule as an offset relative to another schedule. For example, the settlement schedule may be relative to the expiry schedule by an FxForward offset."]

    condition Choice0:
        optional choice dateAdjustments, businessCentersReference, businessCenters, dateOffset

    condition Choice1:
        optional choice observationFrequency, businessCentersReference

    condition Choice2:
        if businessCentersReference exists
        then dayType exists and (startDate exists or endDate exists)

    condition Choice3:
        optional choice observationFrequency, businessCenters

    condition Choice4:
        if businessCenters exists
        then dayType exists and (startDate exists or endDate exists)

    condition Choice5:
        dateOffset is absent
            or startDate is absent
                and endDate is absent
                and observationFrequency is absent
                and dayType is absent

    condition Choice6:
        optional choice dateAdjustments, dayType

    condition Choice7:
        if dateAdjustments exists
        then if observationFrequency exists
            then startDate exists or endDate exists
            else if adjustedDate exists
            then startDate is absent and endDate is absent
            else False

    condition Choice8:
        if dayType exists
        then startDate exists and observationFrequency is absent
                or endDate exists and observationFrequency is absent
                or businessCentersReference exists
                or businessCenters exists
                or dateOffset exists

    condition Choice9:
        if dateAdjustments is absent and dayType is absent
        then startDate exists and observationFrequency exists
                or adjustedDate exists
                    and observationFrequency is absent
                    and startDate is absent
                    and endDate is absent
                or observationFrequency exists and endDate exists
                or businessCentersReference exists
                or businessCenters exists
                or dateOffset exists

