    payoffCap number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The amount of gain on the client upside or firm upside is limited. If spot settles above the cap, or below the floor, the payout is adjusted to limit the gain. The adjustment may be made by varying the strike, or by maintaining the strike, but varying the payout notionals."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The amount of gain on the client upside or firm upside is limited. If spot settles above the cap, or below the floor, the payout is adjusted to limit the gain. The adjustment may be made by varying the strike, or by maintaining the strike, but varying the payout notionals."]

type FxTargetSettlementPeriodSchedule:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    settlementPeriod FxTargetSettlementPeriod (1..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines each settlement period in the tabular/matrix representation of the product."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines each settlement period in the tabular/matrix representation of the product."]

type FxTargetSettlementPeriod extends SettlementPeriod:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    pivot number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Pivot for the settlement period. When pivot is present, at least two payoff elements must be present within the settlement period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Pivot for the settlement period. When pivot is present, at least two payoff elements must be present within the settlement period."]
    payoff FxTargetSettlementPeriodPayoff (1..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Payoff Region within the settlement period to link strike with the relevant payoff components."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Payoff Region within the settlement period to link strike with the relevant payoff components."]
    barrier FxSettlementPeriodBarrier (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The trigger rate of the barrier (Per Expiry or Global Knockout) for the settlement period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The trigger rate of the barrier (Per Expiry or Global Knockout) for the settlement period."]

type FxTargetPhysicalSettlement:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    exchangedCurrency1 FxExchangedCurrency (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates the first direction of who pays and receives a specific currency without specifying the amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates the first direction of who pays and receives a specific currency without specifying the amount."]
    exchangedCurrency2 FxExchangedCurrency (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Indicates the second direction of who pays and receives a specific currency without specifying the amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Indicates the second direction of who pays and receives a specific currency without specifying the amount."]
    settlementAdjustmentStyle FxSettlementAdjustmentMethodEnum (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Settlement Adjustment Style can be VariedStrike or VariedNotional."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Settlement Adjustment Style can be VariedStrike or VariedNotional."]
    strike FxStrike (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Strike price of the Target."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Strike price of the Target."]
    strikeReference FxStrikeReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to an existing strike structure within the FX product."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to an existing strike structure within the FX product."]

    condition Choice:
        optional choice strike, strikeReference

type FxTargetReference extends fpml.consolidated.shared.Reference:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Reference to a target structure."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Reference to a target structure."]

    href string (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

type SettlementPeriod:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    expiryDate zonedDateTime (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Expiry date for the settlement period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Expiry date for the settlement period."]
    settlementDate zonedDateTime (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Settlement date for the settlement period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Settlement date for the settlement period."]
    notionalAmount number (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Notional Amount for the settlement period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Notional Amount for the settlement period."]

type SettlementPeriodFixingDates:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    fixingDate zonedDateTime (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Observation date in a fixing period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Observation date in a fixing period."]
    startDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Start date of the period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Start date of the period."]
    endDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "End date of the period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "End date of the period."]
    numberOfFixings int (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Number of fixings between the fixing start and end date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Number of fixings between the fixing start and end date."]

    condition Choice:
        if fixingDate exists
        then startDate is absent and endDate is absent and numberOfFixings is absent
        else if startDate exists or endDate exists
        then startDate exists
                and endDate exists
                and fixingDate is absent
                and numberOfFixings is absent
        else if numberOfFixings exists
        then fixingDate is absent and startDate is absent and endDate is absent
        else False

type SettlementPeriodLeverage:
    [docReference ISDA FPML version "recordkeeping-5.13"]
    [docReference ISDA FPML version "confirmation-5.13"]

    ratio number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Leverage expressed as ratio."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Leverage expressed as ratio."]
    notionalAmount number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Leverage notional."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Leverage notional."]
    counterCurrencyAmount number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Leverage counter currency notional."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Leverage counter currency notional."]

    condition Choice:
        ratio is absent or notionalAmount is absent and counterCurrencyAmount is absent
