    _30Minutes displayName "30Minutes" [ docReference ISDA FPML version "recordkeeping-5.13" provision "Half-hourly duration applies." ]
    _15Minutes displayName "15Minutes" [ docReference ISDA FPML version "recordkeeping-5.13" provision "Quarter-hourly duration applies." ]

