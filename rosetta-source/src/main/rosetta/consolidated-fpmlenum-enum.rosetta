namespace fpml.consolidated.fpmlenum : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*

enum AveragingInOutEnum:
    [docReference ISDA FPML version "recordkeeping-5.13"]

    In [ docReference ISDA FPML version "recordkeeping-5.13" ]
    Out [ docReference ISDA FPML version "recordkeeping-5.13" ]
    Both [ docReference ISDA FPML version "recordkeeping-5.13" ]

enum AveragingMethodEnum:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "The method of calculation to be used when averaging rates. Per ISDA 2000 Definitions, Section 6.2. Certain Definitions Relating to Floating Amounts."]

    Unweighted [ docReference ISDA FPML version "recordkeeping-5.13" ]
    Weighted [ docReference ISDA FPML version "recordkeeping-5.13" ]

enum BullionTypeEnum:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Defines which type of bullion is applicable for a Bullion Transaction."]

    Gold [ docReference ISDA FPML version "recordkeeping-5.13" provision "Gold. Quality as per the Good Delivery Rules issued by the London Bullion Market Association." ]
    Palladium [ docReference ISDA FPML version "recordkeeping-5.13" provision "Palladium. Quality as per the Good Delivery Rules issued by the London Platinum and Palladium Market." ]
    Platinum [ docReference ISDA FPML version "recordkeeping-5.13" provision "Palladium. Quality as per the Good Delivery Rules issued by the London Platinum and Palladium Market." ]
    Silver [ docReference ISDA FPML version "recordkeeping-5.13" provision "Silver. Quality as per the Good Delivery Rules issued by the London Bullion Market Association." ]
    Rhodium [ docReference ISDA FPML version "recordkeeping-5.13" provision "Quality as per the Good Delivery Rules for Rhodium." ]
    RhodiumSponge [ docReference ISDA FPML version "recordkeeping-5.13" ]
    Iridium [ docReference ISDA FPML version "recordkeeping-5.13" provision "Quality as per the Good Delivery Rules for Iridium." ]
    Ruthenium [ docReference ISDA FPML version "recordkeeping-5.13" provision "Quality as per the Good Delivery Rules for Ruthenium." ]
    Osmium [ docReference ISDA FPML version "recordkeeping-5.13" provision "Quality as per the Good Delivery Rules for Osmium." ]

