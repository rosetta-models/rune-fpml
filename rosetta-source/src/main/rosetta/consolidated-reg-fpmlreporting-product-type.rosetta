namespace fpml.consolidated.reg.fpmlreporting.product : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*
import fpml.consolidated.com.*
import fpml.consolidated.fpmlenum.*
import fpml.consolidated.fx.*
import fpml.consolidated.generic.*
import fpml.consolidated.shared.*

type RegulatoryProductInfo extends RegulatoryReportingProduct:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Product data fields required by regulators in satisfaction of non-public (recordkeeping) regulatory reporting regulations. These are identified where possible using CPMI-IOSCO Common Data Element lexicon and terminology, but include additional fields required by other regulations. This product is not intended to provide the full trade economics required for confirmation or valuation purposes. This product allows a simpler representation of OTC derivative products that have full standardized representations in FpML. DEPRECATED. Reason: Not used. (RPTWG decision 2024-05-30)"]

type RegReportingPayment extends NonNegativePayment:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Simple product representation providing key information about trade economics of any type of trade for regulatory reporting purposes. DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]

    paymentType PaymentType (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A classification of the type of fee or additional payment, e.g. brokerage, upfront fee etc. FpML does not define domain values for this element. DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]

type RegulatoryReportingNonCDEOptionDetails:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "This defines data elements not defined in CDE that describe option characteristics. DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]

    optionType OptionTypeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "For options, what type of option it is (e.g. butterfly). DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]
    firstExerciseDate zonedDateTime (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]
    optionExpirationDate zonedDateTime (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]
    underlyerMaturityDate zonedDateTime (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]
    exerciseStyle GenericExerciseStyle (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "For options, whether the option is a put or call option. DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]
    feature GenericProductFeature (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Special features that the option may have, such as Asian averaging, Barriers, Digital payout, etc. DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]

type RegulatoryReportingNonCDEProductCommodityDetails:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Commodity product data fields not called out in CPMI-IOSCO CDE. DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]

    grade GenericCommodityGrade (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The grade(s) of material which can be delivered in seller\'s option."]
    settlementPeriods GenericCommodityDeliveryPeriod (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the delivery time periods (normally used for electricity swaps)."]
    loadType LoadTypeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "LoadType is a summary of the full description of the settlement periods with respect to the region. Used for describing Electricity delivery schedules (e.g. Base, Peak, Off-Peak, Custom)."]
    quantity number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The periodic quantity. Used in conjunction with the quantityFrequency to define quantity per period."]
    quantityFrequency CommodityQuantityFrequency (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The frequency at which the Notional Quantity is deemed to apply for purposes of calculating the Total Notional Quantity."]
    fixedPrice CommodityFixedPrice (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Fixed price on which fixed payments are based."]
    interconnectionPoint InterconnectionPoint (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Identification of the border(s) or border point(s) of a transportation contract."]

type RegulatoryReportingProduct extends Product:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Simple product representation providing key information about trade economics of any type of trade for regulatory reporting purposes. DEPRECATED. Reason: Not used. (RPTWG decision 2024-05-30)"]

    parties RegulatoryReportingProductParties (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]
    dates RegulatoryReportingProductDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]
    sizes RegulatoryReportingProductSizes (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]
