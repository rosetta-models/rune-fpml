    floatingReceiverPartyReference PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]
    floating2PayerPartyReference PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]
    floating2ReceiverPartyReference PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. Reason: Not used, deprecated parent element. (RPTWG decision 2024-05-30)"]

