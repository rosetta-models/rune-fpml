type ApprovalStatusNotification extends fpml.consolidated.msg.NotificationMessage: <"A message describing the approvals currently applied to the trade and their status (e.g. pending, approved, refused).">
    [rootType]

    trade fpml.consolidated.doc.Trade (0..1)
    tradeIdentifier fpml.consolidated.doc.TradeIdentifier (0..1)
    approvals fpml.consolidated.doc.Approvals (1..1) <"All of the approvals for a specific trade.">
