namespace fpml.consolidated.confirmation.processes : < "fpml definition" >
version "${project.version}"

type RequestExecution extends fpml.consolidated.msg.CorrectableRequestMessage: <"A message requesting that an order be executed.">
    [rootType]

    tradePackage fpml.consolidated.business.events.TradePackage (0..1)
    originatingEvent fpml.consolidated.shared.OriginatingEvent (0..1)
    trade fpml.consolidated.doc.Trade (0..1)
    additionalEvent fpml.consolidated.business.events.AdditionalEvent (0..1)
    optionExercise fpml.consolidated.business.events.OptionExercise (0..1) <"A structure describing an option exercise event. The optionExercise event supports partial exercise (specify the number of options or amount to exercise), full exercise (use fullExercise flag), as well as the option to request options not to be exercised.">
    party fpml.consolidated.shared.Party (1..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

type RequestExecutionRetracted extends fpml.consolidated.msg.NonCorrectableRequestMessage: <"A message withdrawing a request that an order be executed.">
    [rootType]

    tradePackage fpml.consolidated.business.events.TradePackage (0..1)
    originatingEvent fpml.consolidated.shared.OriginatingEvent (0..1)
    trade fpml.consolidated.doc.Trade (0..1)
    additionalEvent fpml.consolidated.business.events.AdditionalEvent (0..1)
    optionExercise fpml.consolidated.business.events.OptionExercise (0..1) <"A structure describing an option exercise event. The optionExercise event supports partial exercise (specify the number of options or amount to exercise), full exercise (use fullExercise flag), as well as the option to request options not to be exercised.">
    party fpml.consolidated.shared.Party (0..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

type ExecutionNotification extends fpml.consolidated.msg.CorrectableRequestMessage: <"A message notifying a party that a trade execution has occurred. (Typically this is sent by an execution platform to a participant.)">
    [rootType]

    tradePackage fpml.consolidated.business.events.TradePackage (0..1)
    originatingEvent fpml.consolidated.shared.OriginatingEvent (0..1)
    trade fpml.consolidated.doc.Trade (0..1)
    amendment fpml.consolidated.business.events.TradeAmendmentContent (0..1)
    optionExercise fpml.consolidated.business.events.OptionExercise (0..1) <"A structure describing an option exercise event. The optionExercise event supports partial exercise (specify the number of options or amount to exercise), full exercise (use fullExercise flag), as well as the option to request options not to be exercised.">
    optionExpiry fpml.consolidated.business.events.OptionExpiry (0..*) <"A structure describing an option expiring event (i.e. passing its last exercise time and becoming worthless.)">
    optionEvent fpml.consolidated.business.events.OptionEvent (0..1) <"A structure describing knock in, knock out, touch and no touch events.">
    additionalEvent fpml.consolidated.business.events.AdditionalEvent (0..1)
    quote fpml.consolidated.asset.BasicQuotation (0..*) <"Pricing information for the trade.">
    collateralization fpml.consolidated.reg.fpmlreporting.shared.RegulatoryReportingCollateralization (0..2) <"Collateralization block, that holds Regulator specific requirement about the trades\' collateralization, is added here to accommodate a technical implementation of SFTR. The change aligns with the established principle that the content in recordkeeping view is now also available in the confirmation view for both functional and technical reasons. The appropriate place for this information is \'regulatoryDisclosure\' and \'nonpublicExecutionReport\' messages in the Recordkeeping view.">
    party fpml.consolidated.shared.Party (1..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

type ExecutionRetracted extends fpml.consolidated.msg.NonCorrectableRequestMessage: <"A message retracting a notification to a party that a trade execution has occurred. (Typically this is sent by an execution platform to a participant.)">
    [rootType]

    tradePackage fpml.consolidated.business.events.TradePackage (0..1)
    originatingEvent fpml.consolidated.shared.OriginatingEvent (0..1)
    trade fpml.consolidated.doc.Trade (0..1)
    additionalEvent fpml.consolidated.business.events.AdditionalEvent (0..1)
    optionExercise fpml.consolidated.business.events.OptionExercise (0..1) <"A structure describing an option exercise event. The optionExercise event supports partial exercise (specify the number of options or amount to exercise), full exercise (use fullExercise flag), as well as the option to request options not to be exercised.">
    party fpml.consolidated.shared.Party (0..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

type ExecutionAcknowledgement extends EventRequestAcknowledgement:
    [rootType]

type ExecutionException extends fpml.consolidated.msg.Exception:
    [rootType]

type ExecutionAdvice extends fpml.consolidated.msg.CorrectableRequestMessage: <"A message advising a third party that a trade execution has occurred.">
    [rootType]

    productType fpml.consolidated.shared.ProductType (0..1)
    tradePackage fpml.consolidated.business.events.TradePackage (0..1)
    originatingEvent fpml.consolidated.shared.OriginatingEvent (0..1)
    trade fpml.consolidated.doc.Trade (0..1)
    amendment fpml.consolidated.business.events.TradeAmendmentContent (0..1)
    increase fpml.consolidated.business.events.TradeNotionalChange (0..1)
    terminatingEvent fpml.consolidated.business.events.TerminatingEvent (0..1) <"This may be used to describe why a trade was terminated.">
    termination fpml.consolidated.business.events.TradeNotionalChange (0..1)
    novation fpml.consolidated.business.events.TradeNovationContent (0..1)
    withdrawal fpml.consolidated.business.events.Withdrawal (0..1)
    observation fpml.consolidated.business.events.ObservationEvent (0..*)
    reset fpml.consolidated.business.events.ResetEvent (0..*)
    change fpml.consolidated.business.events.TradeChangeContent (0..1)
    optionExercise fpml.consolidated.business.events.OptionExercise (0..1) <"A structure describing an option exercise event. The optionExercise event supports partial exercise (specify the number of options or amount to exercise), full exercise (use fullExercise flag), as well as the option to request options not to be exercised.">
    optionExpiry fpml.consolidated.business.events.OptionExpiry (0..*) <"A structure describing an option expiring event (i.e. passing its last exercise time and becoming worthless.)">
    optionEvent fpml.consolidated.business.events.OptionEvent (0..1) <"A structure describing knock in, knock out, touch and no touch events.">
    additionalEvent fpml.consolidated.business.events.AdditionalEvent (0..1)
    quote fpml.consolidated.asset.BasicQuotation (0..*) <"Pricing information for the trade.">
    collateralization fpml.consolidated.reg.fpmlreporting.shared.RegulatoryReportingCollateralization (0..2) <"Collateralization block, that holds Regulator specific requirement about the trades\' collateralization, is added here to accommodate a technical implementation of SFTR. The change aligns with the established principle that the content in recordkeeping view is now also available in the confirmation view for both functional and technical reasons. The appropriate place for this information is \'regulatoryDisclosure\' and \'nonpublicExecutionReport\' messages in the Recordkeeping view.">
    paymentDetails fpml.consolidated.shared.PaymentDetails (0..*) <"Details of the payments, like amount breakdowns, settlement information.">
    party fpml.consolidated.shared.Party (1..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

type ExecutionAdviceRetracted extends fpml.consolidated.msg.NonCorrectableRequestMessage: <"A message that withdraws an advice to a third party that a trade execution has occurred.">
    [rootType]

    tradePackage fpml.consolidated.business.events.TradePackage (0..1)
    originatingEvent fpml.consolidated.shared.OriginatingEvent (0..1)
    trade fpml.consolidated.doc.Trade (0..1)
    amendment fpml.consolidated.business.events.TradeAmendmentContent (0..1)
    increase fpml.consolidated.business.events.TradeNotionalChange (0..1)
    terminatingEvent fpml.consolidated.business.events.TerminatingEvent (0..1) <"This may be used to describe why a trade was terminated.">
    termination fpml.consolidated.business.events.TradeNotionalChange (0..1)
    novation fpml.consolidated.business.events.TradeNovationContent (0..1)
    withdrawal fpml.consolidated.business.events.Withdrawal (0..1)
    observation fpml.consolidated.business.events.ObservationEvent (0..*)
    reset fpml.consolidated.business.events.ResetEvent (0..*)
    change fpml.consolidated.business.events.TradeChangeContent (0..1)
    optionExercise fpml.consolidated.business.events.OptionExercise (0..1) <"A structure describing an option exercise event. The optionExercise event supports partial exercise (specify the number of options or amount to exercise), full exercise (use fullExercise flag), as well as the option to request options not to be exercised.">
    optionExpiry fpml.consolidated.business.events.OptionExpiry (0..*) <"A structure describing an option expiring event (i.e. passing its last exercise time and becoming worthless.)">
    optionEvent fpml.consolidated.business.events.OptionEvent (0..1) <"A structure describing knock in, knock out, touch and no touch events.">
    additionalEvent fpml.consolidated.business.events.AdditionalEvent (0..1)
    collateralization fpml.consolidated.reg.fpmlreporting.shared.RegulatoryReportingCollateralization (0..2)
    paymentDetails fpml.consolidated.shared.PaymentDetails (0..*) <"Details of the payments, like amount breakdowns, settlement information.">
    party fpml.consolidated.shared.Party (0..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

type ExecutionAdviceAcknowledgement extends EventRequestAcknowledgement:
    [rootType]

type ExecutionAdviceException extends fpml.consolidated.msg.Exception:
    [rootType]

type MaturityNotification extends fpml.consolidated.msg.CorrectableRequestMessage: <"A message used to notify another party that a trade has matured. This can be used to report, for example, that a swap has passed its final payment and can be removed, or that an option has expired without being executed.">
    [rootType]

    optionExpiry fpml.consolidated.business.events.OptionExpiryBase (0..1)
    tradeMaturity fpml.consolidated.business.events.TradeMaturity (0..1)
    party fpml.consolidated.shared.Party (1..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

type MaturityAcknowledgement extends EventRequestAcknowledgement:
    [rootType]

type MaturityException extends fpml.consolidated.msg.Exception:
    [rootType]

type RequestTradeReferenceInformationUpdate extends fpml.consolidated.msg.CorrectableRequestMessage: <"Defines the structure for a message requesting information updates to a trade. The trade reference information should contain at least one trade identifier that the recipient is aware of.">
    [rootType]

    tradeReferenceInformation fpml.consolidated.business.events.TradeReferenceInformation (1..1) <"Information about a trade.">
    party fpml.consolidated.shared.Party (1..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

type RequestTradeReferenceInformationUpdateRetracted extends fpml.consolidated.msg.NonCorrectableRequestMessage: <"Defines the structure for a message retracting a request to updated information about trade.">
    [rootType]

    tradeReferenceInformation fpml.consolidated.business.events.TradeReferenceInformation (1..1) <"Information about a trade.">
    party fpml.consolidated.shared.Party (0..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

type TradeReferenceInformationUpdateAcknowledgement extends EventRequestAcknowledgement:
    [rootType]

type TradeReferenceInformationUpdateException extends fpml.consolidated.msg.Exception:
    [rootType]

type TradeChangeAdvice extends fpml.consolidated.msg.CorrectableRequestMessage: <"Defines the structure for a message indicating that a trade is being changed due to a non-negotiated event.">
    [rootType]

    change fpml.consolidated.business.events.TradeChangeContent (1..1) <"Describes the details of the change.">
    quote fpml.consolidated.asset.BasicQuotation (0..*) <"Pricing information for the trade.">
    paymentDetails fpml.consolidated.shared.PaymentDetails (0..*) <"Details of the payments, like amount breakdowns, settlement information.">
    party fpml.consolidated.shared.Party (1..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

type TradeChangeAdviceRetracted extends fpml.consolidated.msg.NonCorrectableRequestMessage: <"Defines the structure for a message retracting a prior change advice.">
    [rootType]

    tradeIdentifier fpml.consolidated.doc.PartyTradeIdentifier (1..*) <"The qualified identifiers of the subject trade.">
    change fpml.consolidated.business.events.TradeChangeContent (0..1) <"Describes the details of the change being retracted.">
    paymentDetails fpml.consolidated.shared.PaymentDetails (0..*) <"Details of the payments, like amount breakdowns, settlement information.">
    party fpml.consolidated.shared.Party (1..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

type TradeChangeAdviceAcknowledgement extends EventRequestAcknowledgement:
    [rootType]

type TradeChangeAdviceException extends fpml.consolidated.msg.Exception:
    [rootType]

type RequestConsent extends fpml.consolidated.msg.CorrectableRequestMessage: <"A message requesting that the sender be authorized by the recipient to peform an action.">
    [rootType]

    requestedAction fpml.consolidated.shared.RequestedAction (0..1) <"The reason the consent was requested.">
    ^type fpml.consolidated.doc.ApprovalType (0..1) <"The type of approval (e.g. \"pre-clearing credit\").">
    approver fpml.consolidated.shared.PersonId (0..1) <"The full name or identifiying ID of the relevant approver.">
    approvingPartyReference fpml.consolidated.shared.PartyReference (0..1) <"A pointer style reference to a party defined elsewhere in the document. The party referenced needs to approve the specified item (e.g. trade or allocation).">
    portfolioReference fpml.consolidated.msg.PortfolioReference (0..1)
    compressionActivity fpml.consolidated.business.events.CompressionActivity (0..1) <"Compression information for the trade.">
    tradePackage fpml.consolidated.business.events.TradePackage (0..1)
    originatingEvent fpml.consolidated.shared.OriginatingEvent (0..1)
    trade fpml.consolidated.doc.Trade (0..1)
    amendment fpml.consolidated.business.events.TradeAmendmentContent (0..1)
    increase fpml.consolidated.business.events.TradeNotionalChange (0..1)
    terminatingEvent fpml.consolidated.business.events.TerminatingEvent (0..1) <"This may be used to describe why a trade was terminated.">
    termination fpml.consolidated.business.events.TradeNotionalChange (0..1)
    novation fpml.consolidated.business.events.TradeNovationContent (0..1)
    withdrawal fpml.consolidated.business.events.Withdrawal (0..1)
    observation fpml.consolidated.business.events.ObservationEvent (0..*)
    reset fpml.consolidated.business.events.ResetEvent (0..*)
    additionalEvent fpml.consolidated.business.events.AdditionalEvent (0..1)
    deClear fpml.consolidated.business.events.DeClear (0..1) <"A structure describing a declear event. The deClear event allows a firm to request that a trade be removed from clearing, or a clearing service to request consent for this, or to report that it has been done.">
    quote fpml.consolidated.asset.BasicQuotation (0..*) <"Pricing information for the trade.">
    party fpml.consolidated.shared.Party (1..*) <"A legal entity or a subdivision of a legal entity. Parties can perform multiple roles in a trade lifecycle. For example, the principal parties obligated to make payments from time to time during the term of the trade, but may include other parties involved in, or incidental to, the trade, such as parties acting in the role of novation transferor/transferee, broker, calculation agent, etc. In FpML roles are defined in multiple places within a document.">
    account fpml.consolidated.shared.Account (0..*) <"Optional account information used to precisely define the origination and destination of financial instruments.">

