type ApprovalStatusNotification extends NotificationMessage:
    [rootType]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A message describing the approvals currently applied to the trade and their status (e.g. pending, approved, refused)."]

    trade Trade (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    tradeIdentifier TradeIdentifier (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    approvals Approvals (1..1)
