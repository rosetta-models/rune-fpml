type ExecutionAcknowledgement extends EventRequestAcknowledgement:
    [rootType]
    [docReference ISDA FPML version "confirmation-5.13"]

type ExecutionException extends Exception:
    [rootType]
    [docReference ISDA FPML version "confirmation-5.13"]

