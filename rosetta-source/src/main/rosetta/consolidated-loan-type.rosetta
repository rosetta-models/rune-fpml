namespace fpml.consolidated.loan : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*
import fpml.consolidated.asset.*
import fpml.consolidated.business.events.*
import fpml.consolidated.doc.*
import fpml.consolidated.fpmlenum.*
import fpml.consolidated.msg.*
import fpml.consolidated.shared.*

type DelayedDraw extends AbstractFacility:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A facility which can be drawn at any point during a pre-defined period after the initial deal closing date,"]

    delayedDraw boolean (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A flag to determine whether the Term Loan has a delayed draw feature."]
    mustDrawByDate zonedDateTime (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date by which funds must be drawn."]

type LetterOfCreditFacility extends AbstractFacility:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A facility designed to issue letter of credit products."]

type Revolver extends AbstractFacility:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A facility which allows a flexible line of credit which can be drawn and repaid multiple times over the life of the facility."]

type TermLoan extends AbstractFacility:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A facility which is fully funded (utilized) at deal closing."]

type AccrualOptionChange extends AbstractFacilityEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event describing a change to an accrual option associated with a specific facility."]

    fixedRateOption FixedRateOption (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure that represents the accruing fixed rate option associated within a facility."]
    floatingRateOption LoanFloatingRateOption (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure that represents the accruing floating rate option associated within a facility."]
    legacyFloatingRateOption LegacyFloatingRateOption (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure that represents a legacy (pre-IBOR replacement) accruing floating rate option associated within a facility."]
    loanContractReference LoanContractReference (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A loan contract reference structure."]
    accruingPikOption AccruingPikOption (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure that represents the accruing PIK option associated within a facility."]
    lcOption LcOption (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure that represents the accruing L/C rate option associated within a facility."]
    letterOfCreditReference LetterOfCreditReference (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A letter of credit reference structure"]

    condition Choice:
        if fixedRateOption exists
        then floatingRateOption is absent
                and legacyFloatingRateOption is absent
                and accruingPikOption is absent
                and lcOption is absent
                and letterOfCreditReference is absent
        else if floatingRateOption exists
        then fixedRateOption is absent
                and legacyFloatingRateOption is absent
                and accruingPikOption is absent
                and lcOption is absent
                and letterOfCreditReference is absent
        else if legacyFloatingRateOption exists
        then fixedRateOption is absent
                and floatingRateOption is absent
                and accruingPikOption is absent
                and lcOption is absent
                and letterOfCreditReference is absent
        else if accruingPikOption exists
        then fixedRateOption is absent
                and floatingRateOption is absent
                and legacyFloatingRateOption is absent
                and loanContractReference is absent
                and lcOption is absent
                and letterOfCreditReference is absent
        else if lcOption exists
        then fixedRateOption is absent
                and floatingRateOption is absent
                and legacyFloatingRateOption is absent
                and accruingPikOption is absent
                and loanContractReference is absent
        else False

type AccruingFeeChange extends AbstractFacilityEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event describing a future change to an accruing fee associated with a specific facility."]

    accruingFeeOption AccruingFeeOption (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines new rate and the date on which the rate is no longer valid."]

type AccruingFeeExpiry extends AbstractFacilityEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event describing a future expiry of one of the accruing fees associated with a specific facility."]

    id AccrualTypeId (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A unique id associated with the loan accrual type."]
    ^type AccruingFeeType (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The accruing fee type which is expiring."]

type AccruingFeePayment extends AbstractFacilityEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event describing an accruing fee payment made at the facility level."]

    id AccrualTypeId (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A unique id associated with the loan accrual type."]
    startDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period begins."]
    endDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period ends."]
    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    accrualSchedule AccrualPeriod (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A schedule that incorporates all sub-periods of an accrual calculation."]
    projection PaymentProjection (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Projected interest payment details."]

type AccruingPikPayment extends AbstractFacilityEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing a payment to facilitate capitalization of interest on all outstanding contracts against a particular facility."]

    startDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period begins."]
    endDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period ends."]
    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    accrualSchedule AccrualPeriod (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A schedule that incorporates all sub-periods of an accrual calculation."]

type AmendmentFeePayment extends AbstractFacilityPaymentEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A fee charged to the borrower for an amendment being made to the originally agreed credit agreement. The fee is based on a rate (as stated in the agreement) applied to the current commitment level. Calculated as a percentage of the unutilized portion of the facility."]

type CommitmentAdjustment extends AbstractFacilityEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event defining a future change in facility commitment."]

    refusalAllowed boolean (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines whether the lender has an option to accept or deny the commitment change."]
    scheduled boolean (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines whether the commitment adjustment is scheduled."]
    pik boolean (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines whether the commitment adjustment is related to a PIK."]
    facilityCommitment FacilityCommitment (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The global/lender commitment amount stated AFTER a commitment adjustment has taken place."]
    adjustment Adjustment (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the type of adjustment applied - increase or decrease."]
    commitmentSchedule CommitmentSchedule (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The amortization schedule associated with the facility commitment."]

type DefaultRateChange extends AbstractFacilityRateChangeEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing a change in the default rate, applicable to outstanding loans in the event that the borrower is declared to be in default."]

type DefaultRateExpiry extends AbstractFacilityContractEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing expiration of the default rate applicable to borrowers in default."]

type FacilityExtensionFeePayment extends AbstractFacilityPaymentEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "This fee represents any fee paid by the borrower to the syndicate lenders for extending an existing facility."]

type FacilityPrepayment extends AbstractFacilityEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure that represents the prepayment structure associated within a facility."]

    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The amount of the prepayment."]

type FacilityPrepaymentFeePayment extends AbstractFacilityEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure that represents the payment of a facility prepayment fee."]

    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure representing a facility prepayment fee being made by the borrower."]

type FacilityTermination extends AbstractFacilityEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event describing the early termination of a facility."]

type FundingFeePayment extends AbstractFacilityPaymentEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A fee associated with the funding requirements for given facility."]

type MandatoryCostRateChange extends AbstractFacilityRateChangeEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing a change in the mandatory cost rate, applicable to certain outstanding loans in the UK market."]

type MandatoryCostRateExpiry extends AbstractFacilityContractEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing expiration of the mandatory cost rate applicable in the UK market."]

type MiscFeePayment extends AbstractFacilityPaymentEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event describing a misc (one-off) fee being paid at either the loan contract or facility level."]

    ^type MiscFeeType (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The misc fee type, based on a scheme."]
    description NonEmptyNormalizedString (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A description of the misc fee."]

    condition Choice:
        required choice ^type, description

type PenaltyRateChange extends AbstractFacilityRateChangeEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing a change in the penalty rate applicable to outstanding loans."]

type PenaltyRateExpiry extends AbstractFacilityContractEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing expiration of the penalty rate."]

type UpfrontFeePayment extends AbstractFacilityPaymentEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure that represents a fee, also known as Participation Fee, Arrangement Fee etc. This fee represents compensation to the members of the lending syndicate (and sometimes to institutional investors as well) in return for their commitment of capital."]

type WaiverFeePayment extends AbstractFacilityPaymentEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A fee structure that represents a payment made by the borrower to the syndicate lenders for processing and accepting a waiver request. The request is sent by the borrower to obtain approval from the syndicate lenders formally requesting waivers around particular terms of the credit agreement."]

type LoanContractAdjustment extends AbstractLoanContractEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing adjustment in the notional amount of a loan contract that has no cash flow effect. E.g. an amount adjustment due to a defaulted loan."]

    adjustment Adjustment (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the type of adjustment applied - increase or decrease."]
    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]

type BaseRateSet extends LoanContractBaseRateSet:
    [docReference ISDA FPML version "confirmation-5.13"]

type Borrowing extends AbstractLoanContractEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing a principal borrowing is being requested by the borrower."]

    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    conditionsPrecedentMet ConditionsPrecedentMetEnum (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "An enumeration which describes whether the conditions precedent have been met, not met or been waived. Please note: this field in not required since conditions precedent may not be applicable in certain scenarios."]

type BreakageFeePayment extends AbstractLoanContractPaymentEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A fee calculated as the cost of breaking financing against a loan contract which is repaid early."]

    breakageFeeClaimDate zonedDateTime (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date by which any breakage costs (if applicable) must be submitted by Lenders to the Agent."]
    breakageFeeCalculatedBy BreakageCalculatedByEnum (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Where breakage cost is applicable, this enumeration defines who is calculating it - agent bank or lender."]

type InterestCapitalization extends AbstractLoanContractEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing the capitalization of interest amounts for a given accrual period against a single loan contract."]

    startDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period begins."]
    endDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period ends."]
    calculationMethod InterestCalculationMethodEnum (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the way in which the agent bank is allocating cash/PIK interest - can be (i) pro-rata at the time of the interest payment/PIK or (ii) based on the loan contract share throughout the interest period (which is the preferred method)."]
    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    accrualSchedule AccrualPeriod (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A schedule that incorporates all sub-periods of an accrual calculation."]
    projection PaymentProjection (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Projected interest payment details."]

type InterestPayment extends LoanInterestPayment:
    [docReference ISDA FPML version "confirmation-5.13"]

type LegacyInterestCapitalization extends AbstractLoanContractEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing the legacy version (pre-IBOR replacement) of the capitalization of interest amounts for a given accrual period against a single loan contract."]

    startDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period begins."]
    endDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period ends."]
    calculationMethod InterestCalculationMethodEnum (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the way in which the agent bank is allocating cash/PIK interest - can be (i) pro-rata at the time of the interest payment/PIK or (ii) based on the loan contract share throughout the interest period (which is the preferred method)."]
    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    accrualSchedule LegacyAccrualPeriod (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A schedule that incorporates all sub-periods of an accrual calculation."]
    projection PaymentProjection (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Projected interest payment details."]

type LegacyInterestPayment extends LegacyLoanInterestPayment:
    [docReference ISDA FPML version "confirmation-5.13"]

type MaturityChange extends LoanContractMaturityChange:
    [docReference ISDA FPML version "confirmation-5.13"]

type Repayment extends AbstractLoanContractEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing a principal repayment being made by the borrower."]

    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    price NonNegativeDecimal (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The price at which the repayment occurred. This is usually Par but there could be scenarios where a repayment was made at a discounted level."]
    refusalAllowed boolean (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines whether the lender has an option to accept or deny the payment."]
    borrowerMandatory boolean (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines whether the repayment is mandatory from the borrower\'s perspective, based on the (amortization) schedule on the credit agreement."]
    scheduledRepayment boolean (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines whether the repayment is a scheduled repayment. This is normally the case when the repayment is defined on the amortization schedule associated with the facility (on the credit agreement)."]

type Rollover extends AbstractLoanServicingEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing the prepayment structure associated within a facility."]

    currentContracts LoanContractsReference (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A list of references to all contracts whose rates are resetting or that are terminating as part of a rollover event."]
    newContracts LoanContractList (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A list of all contracts whose rates are resetting or that are initiating as part of the rollover event."]

type LcAdjustment extends AbstractLcEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing a change in the notional amount associated with an outstanding letter of credit."]

    adjustment Adjustment (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the type of adjustment applied - increase or decrease."]
    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The letter of credit amount after the adjustment has been applied."]
    relatedBorrowing boolean (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Set to false for a normal increase or decrease in the letter of credit amount. If set to true, it signifies that a loan borrowing will take place in conjunction with this business event."]

type LcFxRevaluation extends AbstractLcEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing a change in either the L/C to Facility or L/C to Accrual FX rates (or both) on an outstanding letter of credit."]

    lcFxRate FxTerms (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines exchange rate between the letter of credit accrual and letter of credit currencies."]
    facilityFxRate FxTerms (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines exchange rate between the letter of credit and facility."]

type LcIssuance extends AbstractLcEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing the issuance of a new letter of credit under an existing facility."]

    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The letter of credit notional amount."]

type LcIssuanceFeePayment extends AbstractLcEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing a letter of credit issuance fee payment."]

    id AccrualTypeId (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A unique id associated with the loan accrual type."]
    startDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period begins."]
    endDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period ends."]
    amount MoneyWithParticipantShare (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    accrualSchedule AccrualPeriod (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A schedule that incorporates all sub-periods of an accrual calculation."]

type LcRateChange extends AbstractLcEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing a change in the rate on an outstanding letter of credit."]

    rate number (1..1)
        [docReference ISDA FPML version "confirmation-5.13"]

type LcRenewal extends AbstractLcEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing a change in the maturity date on an outstanding letter of credit."]

    finalExpiryDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The final letter of credit expiry date (as defined by the evergreen option)."]
    maturityDate zonedDateTime (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The original maturity date of the letter of credit."]

type LcTermination extends AbstractLcEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event representing either the expiry or cancellation of a letter of credit"]

    expiry boolean (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Determines whether this event was created due to a natural expiration of the letter of credit or an unscheduled cancellation."]

type LoanTrade extends LoanTradeEvent:
    [docReference ISDA FPML version "confirmation-5.13"]

type LoanTradeConfirmation extends LoanTradeEvent:
    [docReference ISDA FPML version "confirmation-5.13"]

type LoanTradeFeeDue extends LoanTradeTransferFeeDue:
    [docReference ISDA FPML version "confirmation-5.13"]

type LoanTradeFeeOwed extends LoanTradeTransferFeeOwed:
    [docReference ISDA FPML version "confirmation-5.13"]

type LoanAllocation extends LoanAllocationEvent:
    [docReference ISDA FPML version "confirmation-5.13"]

type LoanAllocationConfirmation extends LoanAllocationEvent:
    [docReference ISDA FPML version "confirmation-5.13"]

type LoanAllocationSettlement extends AbstractLoanAllocationSettlementEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event structure defining the counterparty-to-counterparty trade settlement details."]

    fundingFactors LoanTradingCounterpartySettlementFundingFactors (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Factors impacting the setttlement cash flows."]

type LoanAllocationFeeDue extends LoanAllocationTransferFeeDue:
    [docReference ISDA FPML version "confirmation-5.13"]

type LoanAllocationFeeOwed extends LoanAllocationTransferFeeOwed:
    [docReference ISDA FPML version "confirmation-5.13"]

type LoanAllocationSettlementDateAvailability extends AbstractLoanAllocationEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event structure defining information related to trade settlement date coordination."]

    specificDates DateList (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specific date or dates on which a trade may be settled."]
    startDate zonedDateTime (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period begins."]
    endDate zonedDateTime (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on which this period ends."]
    onOrAfterDate zonedDateTime (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Date on or after which a trade can be settled."]
    leadDays int (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Number of days advance notification required to express the intent to settle a trade."]
    cutOffTime time (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specific cutoff time to express the intent to settle a trade."]
    noSettlePeriod LoanAllocationNoSettlePeriod (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A period during which no settlement of a trade can occur, other than non-business days."]

    condition Choice:
        if specificDates exists
        then startDate is absent and endDate is absent and onOrAfterDate is absent
        else if startDate exists or endDate exists
        then startDate exists
                and endDate exists
                and specificDates is absent
                and onOrAfterDate is absent
        else if onOrAfterDate exists
        then specificDates is absent and startDate is absent and endDate is absent
        else False

type LoanAllocationSettlementDateFinalization extends AbstractLoanAllocationEvent:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An event structure defining the trade settlement date."]

    settlementDate zonedDateTime (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The settlement date associated with a single loan trade allocation."]

type LoanBulkServicingNotification extends AbstractContractNotification:
    [rootType]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A loan servicing notification used to communicate multiple business events, within a single notification."]

    loanBulkServicingNotificationChoice LoanBulkServicingNotificationChoice (2..*)
        [docReference ISDA FPML version "confirmation-5.13"]
    loanBulkServicingNotificationSequence LoanBulkServicingNotificationSequence (1..*)
        [docReference ISDA FPML version "confirmation-5.13"]
    party Party (1..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A legal entity or a subdivision of a legal entity."]

type LoanNotificationAcknowledgement extends LoanAcknowledgement:
    [rootType]
    [docReference ISDA FPML version "confirmation-5.13"
