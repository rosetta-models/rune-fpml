        provision "A structure to describe the eligible and ineligible parties to vote on an action (e.g. a legal action)."]

    approvalPartiesChoice ApprovalPartiesChoice (1..*)
        [docReference ISDA FPML version "confirmation-5.13"]

type ApprovalPartiesChoice:
    [docReference ISDA FPML version "confirmation-5.13"]

    eligibleParty PartyReference (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to a lender eligible to vote on the approval."]
    ineligibleParty PartyReference (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to a lender ineligible to vote on the approval."]
    ineligibleReason IneligiblePartyReasonType (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure to describe the reason a lender is ineligible to vote on the approval, based on a scheme."]

    condition Choice:
        if eligibleParty exists
        then ineligibleParty is absent and ineligibleReason is absent
        else if ineligibleParty exists
        then eligibleParty is absent
        else False

type ApprovalVoteDecision:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure to describe a party\'s approval vote decision."]

    voteDecision VoteDecisionEnum (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The vote decision of the party, based on an enumeration. This object represents the \"functional\" impact of the decision, and not the legal vernacular. Use either documentVoteDecision or description elements below to express the legal vernacular representing the vote decision."]
    documentVoteDecision DocumentVoteDecisionType (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The vote decision of the party, based on a scheme. This object represents the documented description of the vote decision (i.e. the decision as described by the legal document)."]
    description NonEmptyNormalizedString (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A free form field to provide a description of the vote decision of the party. This object represents the documented description of the vote decision (i.e. the decision as described by the legal document)."]

    condition Choice:
        optional choice documentVoteDecision, description

