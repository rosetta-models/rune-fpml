    loanContractInterestAccrual LoanTradingLoanContractAccrual (0..*)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Details of the amount of loan contract interest accrued by the traded portion of a loan contract."]
    letterOfCreditAccrual LoanTradingLetterOfCreditAccrual (0..*)
