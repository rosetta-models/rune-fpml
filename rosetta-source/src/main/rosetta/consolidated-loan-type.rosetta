        [docReference ISDA FPML version "confirmation-5.13"]

type LoanCovenantObligation extends AbstractLoanCovenantObligation:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A syndicated bank loan deal (credit agreement) covenant obligation definition."]

    deemedCovenantReference LoanCovenantObligationReference (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines a referenced covenant from another deal or facility, in the event that a covenant from another deal or facility is deemed applicable."]
    category LoanCovenantObligationCategoryType (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure used to uniquely identify a loan covenant obligation category, based on a scheme."]
    ^type LoanCovenantObligationType (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure used to uniquely identify a loan covenant obligation type, based on a scheme."]
    loanCovenantObligationChoice LoanCovenantObligationChoice (0..*)
        [docReference ISDA FPML version "confirmation-5.13"]
    triggerCriteria LoanCovenantObligationTriggerCriteriaDetails (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure to describe the trigger criteria of a covenant obligation."]
    accountingDetails LoanCovenantObligationAccountingDetails (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "An open structure to describe miscellaneous or other characteristics of the covenant."]

    condition Choice:
        if deemedCovenantReference exists
        then category is absent
                and ^type is absent
                and loanCovenantObligationChoice is absent
                and triggerCriteria is absent
                and accountingDetails is absent
        else if category exists or ^type exists
        then category exists and ^type exists and deemedCovenantReference is absent
        else False

type LoanCovenantObligationChoice:
    [docReference ISDA FPML version "confirmation-5.13"]

    description NonEmptyNormalizedString (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "An optional free form text field to further describe the covenant language. This field can be used to house the exact language as depicted in the credit agreement."]
    location NonEmptyNormalizedString (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A structure to describe the location of the covenant language within the credit agreement (i.e. specific section, paragraph, subparagraph, etc.). Note: this structure is intended to be used for indicative purposes only."]

    condition Choice:
        optional choice description, location

