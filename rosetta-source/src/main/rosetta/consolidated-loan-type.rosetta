        [docReference ISDA FPML version "confirmation-5.13"]
    tradingPartyRoleScheme NonEmptyURI (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]

type LoanTradePayment extends LoanSimplePayment:
    [docReference ISDA FPML version "confirmation-5.13"
