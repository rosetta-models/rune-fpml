        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to the loan trade."]
    receiverSettlementInstruction SettlementInstruction (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This structure can be utilized as an override to previously-communicated settlement instructions (via the LoanPartyProfileNotification)."]

type LoanTransferFee:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure that represents counterparty shares or alternatively the total amount of the assignment fee owed to the admin agent."]

    paidBy LoanTransferFeePaidByEnum (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Rule enumeration for transfer fee split and paid by."]
    totalAmount NonNegativeMoney (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The amount payable to the agent for re-assigning a share in one of the underlying facilities within the deal."]
    transferFeeAmounts BuyerSellerAmounts (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Counterparty shares of the transfer fee owed to the agent."]

    condition Choice:
        if paidBy exists
        then transferFeeAmounts is absent
        else if transferFeeAmounts exists
        then paidBy is absent and totalAmount is absent
        else False

