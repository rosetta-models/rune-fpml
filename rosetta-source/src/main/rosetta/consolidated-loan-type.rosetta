type LoanTradingLoanContractAccrual extends AbstractTradingAccrual:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure that incorporates sub-periods of an accrual calculation for a traded outstanding contract."]

    loanContractReference LoanContractReference (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A unique id for the loan contract."]

type LoanTradingNonAccruingFee:
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure that details the underlying elements that affect the calculation of a nonaccruing fee."]

    amount NonNegativeMoney (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The total accrual amount."]
    nonAccruingFeeTypeId NonAccruingFeeTypeId (1..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A unique id associated with the facility nonaccruing fee type."]
    nonAccruingFeetype LoanTradingNonAccruingFeeTypeEnum (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Describes the type of the accruing fee."]
    miscFeeType MiscFeeType (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Miscellaneous nonrecurring fee type."]
    facilityReference FacilityReference (0..1)
        [docReference ISDA FPML version "confirmation-5.13"]
    loanContractReference LoanContractReference (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A unique id for the loan contract."]
    letterOfCreditReference LetterOfCreditReference (0..1)
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A unique identifier for the letter of credit."]

    condition Choice0:
        optional choice nonAccruingFeetype, miscFeeType

    condition Choice1:
        required choice facilityReference, loanContractReference, letterOfCreditReference

type LoanTradingPartyRole:
    [docReference ISDA FPML version "confirmation-5.13"
