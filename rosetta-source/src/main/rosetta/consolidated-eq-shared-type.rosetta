namespace fpml.consolidated.eq.shared : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*
import fpml.consolidated.asset.*
import fpml.consolidated.fpmlenum.*
import fpml.consolidated.option.shared.*
import fpml.consolidated.shared.*

type InterestLeg extends DirectionalLeg:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing the fixed income leg of the equity swap."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing the fixed income leg of the equity swap."]

    interestLegCalculationPeriodDates InterestLegCalculationPeriodDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Component that holds the various dates used to specify the interest leg of the equity swap. It is used to define the InterestPeriodDates identifyer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Component that holds the various dates used to specify the interest leg of the equity swap. It is used to define the InterestPeriodDates identifyer."]
    notional ReturnSwapNotional (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the notional of a return type swap. When used in the equity leg, the definition will typically combine the actual amount (using the notional component defined by the FpML industry group) and the determination method. When used in the interest leg, the definition will typically point to the definition of the equity leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the notional of a return type swap. When used in the equity leg, the definition will typically combine the actual amount (using the notional component defined by the FpML industry group) and the determination method. When used in the interest leg, the definition will typically point to the definition of the equity leg."]
    interestAmount LegAmount (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies, in relation to each Interest Payment Date, the amount to which the Interest Payment Date relates. Unless otherwise specified, this term has the meaning defined in the ISDA 2000 ISDA Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies, in relation to each Interest Payment Date, the amount to which the Interest Payment Date relates. Unless otherwise specified, this term has the meaning defined in the ISDA 2000 ISDA Definitions."]
    interestCalculation InterestCalculation (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the calculation method of the interest rate leg of the equity swap. Includes the floating or fixed rate calculation definitions, along with the determination of the day count fraction."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the calculation method of the interest rate leg of the equity swap. Includes the floating or fixed rate calculation definitions, along with the determination of the day count fraction."]
    stubCalculationPeriod StubCalculationPeriod (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the stub calculation period."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the stub calculation period."]

type ReturnLeg extends ReturnSwapLegUnderlyer:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing the return leg of a return type swap."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing the return leg of a return type swap."]

    rateOfReturn ReturnLegValuation (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the terms of the initial price of the return type swap and of the subsequent valuations of the underlyer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the terms of the initial price of the return type swap and of the subsequent valuations of the underlyer."]
    notional ReturnSwapNotional (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the notional of a return type swap. When used in the equity leg, the definition will typically combine the actual amount (using the notional component defined by the FpML industry group) and the determination method. When used in the interest leg, the definition will typically point to the definition of the equity leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the notional of a return type swap. When used in the equity leg, the definition will typically combine the actual amount (using the notional component defined by the FpML industry group) and the determination method. When used in the interest leg, the definition will typically point to the definition of the equity leg."]
    amount ReturnSwapAmount (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies, in relation to each Payment Date, the amount to which the Payment Date relates. For return swaps this element is equivalent to the Equity Amount term as defined in the ISDA 2002 Equity Derivatives Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies, in relation to each Payment Date, the amount to which the Payment Date relates. For return swaps this element is equivalent to the Equity Amount term as defined in the ISDA 2002 Equity Derivatives Definitions."]
    return Return (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the conditions under which dividend affecting the underlyer will be paid to the receiver of the amounts."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the conditions under which dividend affecting the underlyer will be paid to the receiver of the amounts."]
    notionalAdjustments NotionalAdjustmentEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the conditions that govern the adjustment to the number of units of the return swap."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the conditions that govern the adjustment to the number of units of the return swap."]
    fxFeature FxFeature (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A quanto or composite FX feature."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A quanto or composite FX feature."]
    averagingDates AveragingPeriod (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Averaging Dates used in the swap."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Averaging Dates used in the swap."]

type ReturnSwap extends ReturnSwapBase:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing return swaps including return swaps (long form), total return swaps, and variance swaps."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing return swaps including return swaps (long form), total return swaps, and variance swaps."]

    earlyTermination ReturnSwapEarlyTermination (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies, for one or for both the parties to the trade, the date from which it can early terminate it."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies, for one or for both the parties to the trade, the date from which it can early terminate it."]
    extraordinaryEvents ExtraordinaryEvents (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Where the underlying is shares, specifies events affecting the issuer of those shares that may require the terms of the transaction to be adjusted."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Where the underlying is shares, specifies events affecting the issuer of those shares that may require the terms of the transaction to be adjusted."]

type AdditionalDisruptionEvents:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type for defining ISDA 2002 Equity Derivative Additional Disruption Events."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type for defining ISDA 2002 Equity Derivative Additional Disruption Events."]

    changeInLaw boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If true, then change in law is applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If true, then change in law is applicable."]
    failureToDeliver boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Where the underlying is shares and the transaction is physically settled, then, if true, a failure to deliver the shares on the settlement date will not be an event of default for the purposes of the master agreement."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Where the underlying is shares and the transaction is physically settled, then, if true, a failure to deliver the shares on the settlement date will not be an event of default for the purposes of the master agreement."]
    insolvencyFiling boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If true, then insolvency filing is applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If true, then insolvency filing is applicable."]
    hedgingDisruption boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If true, then hedging disruption is applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If true, then hedging disruption is applicable."]
    lossOfStockBorrow boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If true, then loss of stock borrow is applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If true, then loss of stock borrow is applicable."]
    maximumStockLoanRate DecimalFraction (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the maximum stock loan rate for Loss of Stock Borrow."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the maximum stock loan rate for Loss of Stock Borrow."]
    increasedCostOfStockBorrow boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If true, then increased cost of stock borrow is applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If true, then increased cost of stock borrow is applicable."]
    initialStockLoanRate DecimalFraction (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the initial stock loan rate for Increased Cost of Stock Borrow."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the initial stock loan rate for Increased Cost of Stock Borrow."]
    increasedCostOfHedging boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If true, then increased cost of hedging is applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If true, then increased cost of hedging is applicable."]
    determiningPartyReference PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A reference to the party which determines additional disruption events."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A reference to the party which determines additional disruption events."]
    foreignOwnershipEvent boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If true, then foreign ownership event is applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If true, then foreign ownership event is applicable."]

type AdditionalPaymentAmount:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Specifies the amount of the fee along with, when applicable, the formula that supports its determination."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Specifies the amount of the fee along with, when applicable, the formula that supports its determination."]

    paymentAmount NonNegativeMoney (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The currency amount of the payment."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The currency amount of the payment."]
    formula Formula (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies a formula, with its description and components."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies a formula, with its description and components."]

type AdjustableDateOrRelativeDateSequence:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing a date defined as subject to adjustment or defined in reference to another date through one or several date offsets."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing a date defined as subject to adjustment or defined in reference to another date through one or several date offsets."]

    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    adjustableDate AdjustableDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A date that shall be subject to adjustment if it would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A date that shall be subject to adjustment if it would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date."]
    relativeDateSequence RelativeDateSequence (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A date specified in relation to some other date defined in the document (the anchor date), where there is the opportunity to specify a combination of offset rules. This component will typically be used for defining the valuation date in relation to the payment date, as both the currency and the exchange holiday calendars need to be considered."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A date specified in relation to some other date defined in the document (the anchor date), where there is the opportunity to specify a combination of offset rules. This component will typically be used for defining the valuation date in relation to the payment date, as both the currency and the exchange holiday calendars need to be considered."]

    condition Choice:
        required choice adjustableDate, relativeDateSequence

type BoundedCorrelation:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing correlation bounds, which form a cap and a floor on the realized correlation."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing correlation bounds, which form a cap and a floor on the realized correlation."]

    minimumBoundaryPercent number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Minimum Boundary as a percentage of the Strike Price."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Minimum Boundary as a percentage of the Strike Price."]
    maximumBoundaryPercent number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Maximum Boundary as a percentage of the Strike Price."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Maximum Boundary as a percentage of the Strike Price."]

type BoundedVariance:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing variance bounds, which are used to exclude money price values outside of the specified range In a Up Conditional Swap Underlyer price must be equal to or higher than Lower Barrier In a Down Conditional Swap Underlyer price must be equal to or lower than Upper Barrier In a Corridor Conditional Swap Underlyer price must be equal to or higher than Lower Barrier and must be equal to or lower than Upper Barrier."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing variance bounds, which are used to exclude money price values outside of the specified range In a Up Conditional Swap Underlyer price must be equal to or higher than Lower Barrier In a Down Conditional Swap Underlyer price must be equal to or lower than Upper Barrier In a Corridor Conditional Swap Underlyer price must be equal to or higher than Lower Barrier and must be equal to or lower than Upper Barrier."]

    realisedVarianceMethod RealisedVarianceMethodEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The contract specifies whether which price must satisfy the boundary condition."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The contract specifies whether which price must satisfy the boundary condition."]
    daysInRangeAdjustment boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The contract specifies whether the notional should be scaled by the Number of Days in Range divided by the Expected N. The number of Days in Ranges refers to the number of returns that contribute to the realized volatility."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The contract specifies whether the notional should be scaled by the Number of Days in Range divided by the Expected N. The number of Days in Ranges refers to the number of returns that contribute to the realized volatility."]
    upperBarrier NonNegativeDecimal (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "All observations above this price level will be excluded from the variance calculation."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "All observations above this price level will be excluded from the variance calculation."]
    lowerBarrier NonNegativeDecimal (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "All observations below this price level will be excluded from the variance calculation."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "All observations below this price level will be excluded from the variance calculation."]

type CalculatedAmount:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "An abstract base class for all calculated money amounts, which are in the currency of the cash multiplier of the calculation."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An abstract base class for all calculated money amounts, which are in the currency of the cash multiplier of the calculation."]

    calculationDates AdjustableRelativeOrPeriodicDates (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the date on which a calculation or an observation will be performed for the purpose of calculating the amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the date on which a calculation or an observation will be performed for the purpose of calculating the amount."]
    observationStartDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The start of the period over which observations are made which are used in the calculation Used when the observation start date differs from the trade date such as for forward starting swaps. Observation Start Date in accordance with the ISDA 2002 Equity Derivatives Definitions. Observation Period Start Date in accordance with the ISDA 2011 Equity Derivatives Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The start of the period over which observations are made which are used in the calculation Used when the observation start date differs from the trade date such as for forward starting swaps. Observation Start Date in accordance with the ISDA 2002 Equity Derivatives Definitions. Observation Period Start Date in accordance with the ISDA 2011 Equity Derivatives Definitions."]
    optionsExchangeDividends boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If present and true, then options exchange dividends are applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If present and true, then options exchange dividends are applicable."]
    additionalDividends boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If present and true, then additional dividends are applicable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If present and true, then additional dividends are applicable."]
    allDividends boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Represents the European Master Confirmation value of \'All Dividends\' which, when applicable, signifies that, for a given Ex-Date, the daily observed Share Price for that day is adjusted (reduced) by the cash dividend and/or the cash value of any non cash dividend per Share (including Extraordinary Dividends) declared by the Issuer. All Dividends in accordance with the ISDA 2002 Equity Derivatives Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Represents the European Master Confirmation value of \'All Dividends\' which, when applicable, signifies that, for a given Ex-Date, the daily observed Share Price for that day is adjusted (reduced) by the cash dividend and/or the cash value of any non cash dividend per Share (including Extraordinary Dividends) declared by the Issuer. All Dividends in accordance with the ISDA 2002 Equity Derivatives Definitions."]

type CalculationFromObservation:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Abstract base class for all calculation from observed values."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Abstract base class for all calculation from observed values."]

    initialLevel number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Contract will strike off this initial level. Providing just the initialLevel without initialLevelSource, infers that this is AgreedInitialPrice - a specified Initial Index Level."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Contract will strike off this initial level. Providing just the initialLevel without initialLevelSource, infers that this is AgreedInitialPrice - a specified Initial Index Level."]
    initialLevelSource DeterminationMethod (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "In this context, this is AgreedInitialPrice - a specified Initial Index Level. Note: No other values from the DeterminationMethodScheme should not be provided."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "In this context, this is AgreedInitialPrice - a specified Initial Index Level. Note: No other values from the DeterminationMethodScheme should not be provided."]
    closingLevel boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. If true this contract will strike off the closing level of the default exchange traded contract."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "DEPRECATED. If true this contract will strike off the closing level of the default exchange traded contract."]
    expiringLevel boolean (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "DEPRECATED. If true this contract will strike off the expiring level of the default exchange traded contract."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "DEPRECATED. If true this contract will strike off the expiring level of the default exchange traded contract."]
    expectedN int(min: 1) (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Expected number of trading days."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Expected number of trading days."]

    condition Choice:
        if initialLevel exists
        then closingLevel is absent and expiringLevel is absent
        else required choice initialLevelSource, closingLevel, expiringLevel

type Compounding:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Specifies the compounding method and the compounding rate."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Specifies the compounding method and the compounding rate."]

    compoundingMethod CompoundingMethodEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "If more that one calculation period contributes to a single payment amount this element specifies whether compounding is applicable, and if so, what compounding method is to be used. This element must only be included when more that one calculation period contributes to a single payment amount."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "If more that one calculation period contributes to a single payment amount this element specifies whether compounding is applicable, and if so, what compounding method is to be used. This element must only be included when more that one calculation period contributes to a single payment amount."]
    compoundingRate CompoundingRate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines a compounding rate. The compounding interest can either point back to the interest calculation node on the Interest Leg, or be defined specifically."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines a compounding rate. The compounding interest can either point back to the interest calculation node on the Interest Leg, or be defined specifically."]
    compoundingSpread number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the spread to be used for compounding. This field should be used in scenarios where the interest payment is based on a compounding formula that uses a compounding spread in addition to the regular spread."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the spread to be used for compounding. This field should be used in scenarios where the interest payment is based on a compounding formula that uses a compounding spread in addition to the regular spread."]
    compoundingDates AdjustableRelativeOrPeriodicDates2 (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the compounding dates."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the compounding dates."]

type CompoundingRate:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defining a compounding rate. The compounding interest can either point back to the floating rate calculation of interest calculation node on the Interest Leg, or be defined specifically."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defining a compounding rate. The compounding interest can either point back to the floating rate calculation of interest calculation node on the Interest Leg, or be defined specifically."]

    interestLegRate FloatingRateCalculationReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Reference to the floating rate calculation of interest calculation node on the Interest Leg."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Reference to the floating rate calculation of interest calculation node on the Interest Leg."]
    specificRate InterestAccrualsMethod (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines a specific rate."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines a specific rate."]

    condition Choice:
        one-of

type Correlation extends CalculationFromObservation:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing the correlation amount of a correlation swap."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing the correlation amount of a correlation swap."]

    notionalAmount NonNegativeMoney (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Notional amount, which is a cash multiplier."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Notional amount, which is a cash multiplier."]
    correlationStrikePrice CorrelationValue (1..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Correlation Strike Price."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Correlation Strike Price."]
    boundedCorrelation BoundedCorrelation (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Bounded Correlation."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Bounded Correlation."]
    numberOfDataSeries int(min: 1) (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Number of data series, normal market practice is that correlation data sets are drawn from geographic market areas, such as America, Europe and Asia Pacific, each of these geographic areas will have its own data series to avoid contagion."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Number of data series, normal market practice is that correlation data sets are drawn from geographic market areas, such as America, Europe and Asia Pacific, each of these geographic areas will have its own data series to avoid contagion."]

type DirectionalLegUnderlyer extends DirectionalLeg:
