type PendingPayment extends PaymentBase:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A structure representing a pending dividend or coupon payment."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A structure representing a pending dividend or coupon payment."]

    paymentDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date that the dividend or coupon is due."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date that the dividend or coupon is due."]
    amount Money (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The amount of the dividend or coupon payment. Value of dividends or coupon between ex and pay date. Stock: if we are between ex-date and pay-date and the dividend is payable under the swap, then this should be the ex-div amount * # of securities. Bond: regardless of where we are vis-a-vis resets: (coupon % * face of bonds on swap * (bond day count fraction using days last coupon pay date of the bond through today)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The amount of the dividend or coupon payment. Value of dividends or coupon between ex and pay date. Stock: if we are between ex-date and pay-date and the dividend is payable under the swap, then this should be the ex-div amount * # of securities. Bond: regardless of where we are vis-a-vis resets: (coupon % * face of bonds on swap * (bond day count fraction using days last coupon pay date of the bond through today)."]
    accruedInterest Money (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Accrued interest on the dividend or coupon payment. When the TRS is structured to pay a dividend or coupon on reset after payable date, you may earn interest on these amounts. This field indicates the interest accrued on dividend/coupon from pay date to statement date. This will only apply to a handful of agreements where dividendss are held to the next reset AND you receive/pay interest on unpaid amounts."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Accrued interest on the dividend or coupon payment. When the TRS is structured to pay a dividend or coupon on reset after payable date, you may earn interest on these amounts. This field indicates the interest accrued on dividend/coupon from pay date to statement date. This will only apply to a handful of agreements where dividendss are held to the next reset AND you receive/pay interest on unpaid amounts."]

type Price:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing the strike price."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing the strike price."]

    commission Commission (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "This optional component specifies the commission to be charged for executing the hedge transactions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "This optional component specifies the commission to be charged for executing the hedge transactions."]
    determinationMethod DeterminationMethod (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the method according to which an amount or a date is determined."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the method according to which an amount or a date is determined."]
    grossPrice ActualPrice (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the price of the underlyer, before commissions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the price of the underlyer, before commissions."]
    netPrice ActualPrice (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the price of the underlyer, net of commissions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the price of the underlyer, net of commissions."]
    accruedInterestPrice number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the accrued interest that are part of the dirty price in the case of a fixed income security or a convertible bond. Expressed in percentage of the notional."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the accrued interest that are part of the dirty price in the case of a fixed income security or a convertible bond. Expressed in percentage of the notional."]
    fxConversion FxConversion (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the currency conversion rate that applies to an amount. This rate can either be defined elsewhere in the document (case of a quanto swap), or explicitly described through this component."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the currency conversion rate that applies to an amount. This rate can either be defined elsewhere in the document (case of a quanto swap), or explicitly described through this component."]
    amountRelativeTo AmountReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The href attribute value will be a pointer style reference to the element or component elsewhere in the document where the anchor amount is defined."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The href attribute value will be a pointer style reference to the element or component elsewhere in the document where the anchor amount is defined."]
    cleanNetPrice number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The net price excluding accrued interest. The \"Dirty Price\" for bonds is put in the \"netPrice\" element, which includes accrued interest. Thus netPrice - cleanNetPrice = accruedInterest. The currency and price expression for this field are the same as those for the (dirty) netPrice."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The net price excluding accrued interest. The \"Dirty Price\" for bonds is put in the \"netPrice\" element, which includes accrued interest. Thus netPrice - cleanNetPrice = accruedInterest. The currency and price expression for this field are the same as those for the (dirty) netPrice."]
    quotationCharacteristics QuotationCharacteristics (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Allows information about how the price was quoted to be provided."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Allows information about how the price was quoted to be provided."]

    condition Choice:
        amountRelativeTo is absent
            or determinationMethod is absent
                and grossPrice is absent
                and netPrice is absent
                and accruedInterestPrice is absent
                and fxConversion is absent

