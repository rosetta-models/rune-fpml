namespace fpml.consolidated.asset : < "fpml definition" >
version "${project.version}"

import fpml.consolidated.*
import fpml.consolidated.fpmlenum.*
import fpml.consolidated.shared.*

type Basket extends Asset:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing the underlyer features of a basket swap. Each of the basket constituents are described through an embedded component, the basketConstituentsType."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing the underlyer features of a basket swap. Each of the basket constituents are described through an embedded component, the basketConstituentsType."]

    openUnits number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The number of units (index or securities) that constitute the underlyer of the swap. In the case of a basket swap, this element is used to reference both the number of basket units, and the number of each asset components of the basket when these are expressed in absolute terms."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The number of units (index or securities) that constitute the underlyer of the swap. In the case of a basket swap, this element is used to reference both the number of basket units, and the number of each asset components of the basket when these are expressed in absolute terms."]
    basketConstituent BasketConstituent (1..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Describes each of the components of the basket."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Describes each of the components of the basket."]
    basketDivisor number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the basket divisor amount. This value is normally used to adjust the constituent weight for pricing or to adjust for dividends, or other corporate actions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the basket divisor amount. This value is normally used to adjust the constituent weight for pricing or to adjust for dividends, or other corporate actions."]
    basketVersion int(min: 0) (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Basket version, used to record changes in basket composition or weights"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Basket version, used to record changes in basket composition or weights"]
    basketName BasketName (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The name of the basket expressed as a free format string. FpML does not define usage rules for this element."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The name of the basket expressed as a free format string. FpML does not define usage rules for this element."]
    basketId BasketId (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A basket identifier"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A basket identifier"]
    basketCurrency Currency (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the currency for this basket."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the currency for this basket."]

type Bond extends UnderlyingAsset:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "An exchange traded bond."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An exchange traded bond."]

    issuerName NonEmptyToken (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    issuerPartyReference PartyReference (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    seniority CreditSeniority (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The repayment precedence of a debt instrument."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The repayment precedence of a debt instrument."]
    creditQuality CreditQuality (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Credit quality type (e.g. \'INVG\' - Investment grade; \'NIVG\' - Non-investment grade; \'NOTR\' - Non-rated). Classifies the risk of the security. Note: \'NOAP\' - Not applicable value is indicated by the absence of the \'creditQuality\' element."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Credit quality type (e.g. \'INVG\' - Investment grade; \'NIVG\' - Non-investment grade; \'NOTR\' - Non-rated). Classifies the risk of the security. Note: \'NOAP\' - Not applicable value is indicated by the absence of the \'creditQuality\' element."]
    creditRating CreditRating (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The credit rating."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The credit rating."]
    couponType CouponType (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies if the bond has a variable coupon, step-up/down coupon or a zero-coupon."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies if the bond has a variable coupon, step-up/down coupon or a zero-coupon."]
    couponRate number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the coupon rate (expressed in percentage) of a fixed income security or convertible bond."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the coupon rate (expressed in percentage) of a fixed income security or convertible bond."]
    maturity zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date when the principal amount of a security becomes due and payable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date when the principal amount of a security becomes due and payable."]
    parValue number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the nominal amount of a fixed income security or convertible bond."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the nominal amount of a fixed income security or convertible bond."]
    faceAmount number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the total amount of the issue. Corresponds to the par value multiplied by the number of issued security."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the total amount of the issue. Corresponds to the par value multiplied by the number of issued security."]
    paymentFrequency Frequency (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the frequency at which the bond pays, e.g. 6M."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the frequency at which the bond pays, e.g. 6M."]
    dayCountFraction DayCountFraction (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The day count basis for the bond."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The day count basis for the bond."]

    condition Choice:
        optional choice issuerName, issuerPartyReference

type Cash extends Asset:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Identifies a simple underlying asset type that is a cash payment. Used for specifying discounting factors for future cash flows in the pricing and risk model."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Identifies a simple underlying asset type that is a cash payment. Used for specifying discounting factors for future cash flows in the pricing and risk model."]

    instrumentId InstrumentId (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Identification of the underlying asset, using public and/or private identifiers."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Identification of the underlying asset, using public and/or private identifiers."]
    description NonEmptyNormalizedString (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Long name of the underlying asset."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Long name of the underlying asset."]
    currency Currency (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The currency in which an amount is denominated."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The currency in which an amount is denominated."]

type Commodity extends IdentifiedAsset:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing a commodity underlying asset."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing a commodity underlying asset."]

    commodityBase CommodityBase (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A coding scheme value to identify the base type of the commodity being traded. Where possible, this should follow the naming convention used in the 2005 ISDA Commodity Definitions. For example, \'Oil\'."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A coding scheme value to identify the base type of the commodity being traded. Where possible, this should follow the naming convention used in the 2005 ISDA Commodity Definitions. For example, \'Oil\'."]
    commodityDetails CommodityDetails (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A coding scheme value to identify the commodity being traded more specifically. Where possible, this should follow the naming convention used in the 2005 ISDA Commodity Definitions. For example, \'Brent\'."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A coding scheme value to identify the commodity being traded more specifically. Where possible, this should follow the naming convention used in the 2005 ISDA Commodity Definitions. For example, \'Brent\'."]
    commodityClassification CommodityClassification (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the classification of a commodity in the context of an n-layer classification system such as 2005 ISDA Commodity Definitions Sub Annex A or that in Table 4 of the Annex of the Comission Implementing Regulation (EU)laying down implementing technical standards for the application of Regulation (EU) No 648/2012 of the European Parliament and of the Council with regard to the standards, formats, frequency and methods and arrangements for reporting for EMIR Refit."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the classification of a commodity in the context of an n-layer classification system such as 2005 ISDA Commodity Definitions Sub Annex A or that in Table 4 of the Annex of the Comission Implementing Regulation (EU)laying down implementing technical standards for the application of Regulation (EU) No 648/2012 of the European Parliament and of the Council with regard to the standards, formats, frequency and methods and arrangements for reporting for EMIR Refit."]
    unit QuantityUnit (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A coding scheme value to identify the unit of measure (e.g. Therms) in which the undelryer is denominated. Where possible, this should follow the naming convention used in the 2005 ISDA Commodity Definitions."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A coding scheme value to identify the unit of measure (e.g. Therms) in which the undelryer is denominated. Where possible, this should follow the naming convention used in the 2005 ISDA Commodity Definitions."]
    currency Currency (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The currency in which the Commodity Reference Price is published (e.g. GBP)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The currency in which the Commodity Reference Price is published (e.g. GBP)."]
    exchangeId ExchangeId (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "For those commodities being traded with reference to the price of a listed instrument, the exchange where that instrument is listed should be specified in the \'exchange\' element."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "For those commodities being traded with reference to the price of a listed instrument, the exchange where that instrument is listed should be specified in the \'exchange\' element."]
    publication CommodityInformationSource (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "For those commodities being traded with reference to a price distributed by a publication, that publication should be specified in the \'publication\' element."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "For those commodities being traded with reference to a price distributed by a publication, that publication should be specified in the \'publication\' element."]
    specifiedPrice SpecifiedPriceEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The \'specified Price\' describes the nature of the underlying price that is observed. It must be be stated in the underlyer definition as it is not defined in the Commodity Reference Price. Example values of \'specifiedPrice\' are \'Settlement\' (for a futures contract) and \'WeightedAverage\' (for some published prices and indices)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The \'specified Price\' describes the nature of the underlying price that is observed. It must be be stated in the underlyer definition as it is not defined in the Commodity Reference Price. Example values of \'specifiedPrice\' are \'Settlement\' (for a futures contract) and \'WeightedAverage\' (for some published prices and indices)."]
    deliveryDates DeliveryDatesEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Deprecated: The \'deliveryDates\' element is applicable for a Commodity Reference Price that references a listed future contract (e.g. The Delivery Date is a NearbyMonth)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Deprecated: The \'deliveryDates\' element is applicable for a Commodity Reference Price that references a listed future contract (e.g. The Delivery Date is a NearbyMonth)."]
    deliveryNearby DeliveryNearby (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A container for the parametric representation of nearby contracts."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A container for the parametric representation of nearby contracts."]
    deliveryDate AdjustableDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Delivery Date is a fixed, single day."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Delivery Date is a fixed, single day."]
    deliveryDateYearMonth string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The Delivery Date is a fixed, single month."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The Delivery Date is a fixed, single month."]
    deliveryDateRollConvention Offset (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The \'deliveryDateRollConvention\' specifies, for a Commodity Transaction that references a listed future via the \'deliveryDates\' element, the day on which the specified future will roll to the next nearby month prior to the expiration of the referenced future. If the future will not roll at all - i.e. the price will be taken from the expiring contract, 0 should be specified here. If the future will roll to the next nearby on the last trading day - i.e. the price will be taken from the next nearby on the last trading day, then 1 should be specified and so on."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The \'deliveryDateRollConvention\' specifies, for a Commodity Transaction that references a listed future via the \'deliveryDates\' element, the day on which the specified future will roll to the next nearby month prior to the expiration of the referenced future. If the future will not roll at all - i.e. the price will be taken from the expiring contract, 0 should be specified here. If the future will roll to the next nearby on the last trading day - i.e. the price will be taken from the next nearby on the last trading day, then 1 should be specified and so on."]
    deliveryDateExpirationConvention Offset (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The \'deliveryDateExpirationConvention\' specifies, for a Commodity Transaction that references a listed future via the \'deliveryDates\' element, the day on which the specified future will expire ahead of the actual expiration of the referenced future. For example: Z21 Contract expires on 19Nov21, with an adjust of 2D the \"expire\" will be 16Nov21. DeliveryDateRollConvention takes precedence. Example: Pricing on the Z21 Contract with NearbyContractDay and a deliveryDateRoll of 10D, Sampling of the F22 Contract will occur on 8Nov21 through the last Date of the Z21 Contract. With an ExpConvention of 5D, the last sampling date on the F22 contract will be 12Nov21."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The \'deliveryDateExpirationConvention\' specifies, for a Commodity Transaction that references a listed future via the \'deliveryDates\' element, the day on which the specified future will expire ahead of the actual expiration of the referenced future. For example: Z21 Contract expires on 19Nov21, with an adjust of 2D the \"expire\" will be 16Nov21. DeliveryDateRollConvention takes precedence. Example: Pricing on the Z21 Contract with NearbyContractDay and a deliveryDateRoll of 10D, Sampling of the F22 Contract will occur on 8Nov21 through the last Date of the Z21 Contract. With an ExpConvention of 5D, the last sampling date on the F22 contract will be 12Nov21."]
    multiplier PositiveDecimal (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The \'multiplier\' specifies the multiplier associated with the Transaction. The \'multiplier\' element has two uses: (1) for Freight Transactions or any Calculation Period specified for a Freight Transaction, if an amount is specified as the Multiplier then it is captured by this element and (2) if the Transaction is a heat rate option, the heat rate multiplier is represented in this element. If multiplier is not provided, multiplier is assumed to be 1. (i.e. rate source states 1 BBL of Oil as 90 Dollars. Multiplier of 10 will change the value to 900 dollars.)"]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The \'multiplier\' specifies the multiplier associated with the Transaction. The \'multiplier\' element has two uses: (1) for Freight Transactions or any Calculation Period specified for a Freight Transaction, if an amount is specified as the Multiplier then it is captured by this element and (2) if the Transaction is a heat rate option, the heat rate multiplier is represented in this element. If multiplier is not provided, multiplier is assumed to be 1. (i.e. rate source states 1 BBL of Oil as 90 Dollars. Multiplier of 10 will change the value to 900 dollars.)"]

    condition Choice0:
        optional choice exchangeId, publication

    condition Choice1:
        optional choice deliveryDates, deliveryNearby, deliveryDate, deliveryDateYearMonth

    condition Choice2:
        commodityBase is absent and commodityDetails is absent
            or commodityClassification is absent

type ConvertibleBond extends Bond:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Identifies the underlying asset when it is a convertible bond."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Identifies the underlying asset when it is a convertible bond."]

    underlyingEquity EquityAsset (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the equity in which the convertible bond can be converted."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the equity in which the convertible bond can be converted."]
    redemptionDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Earlier date between the convertible bond put dates and its maturity date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Earlier date between the convertible bond put dates and its maturity date."]

type Deposit extends UnderlyingAsset:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Identifies a simple underlying asset that is a term deposit."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Identifies a simple underlying asset that is a term deposit."]

    term Period (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the term of the deposit, e.g. 5Y."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the term of the deposit, e.g. 5Y."]
    paymentFrequency Period (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the frequency at which the deposit pays, e.g. 6M."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the frequency at which the deposit pays, e.g. 6M."]
    dayCountFraction DayCountFraction (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The day count basis for the deposit."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The day count basis for the deposit."]

type Equity extends EquityAsset:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Identifies the underlying asset when it is a listed equity."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Identifies the underlying asset when it is a listed equity."]

type ExchangeTradedFund extends ExchangeTradedCalculatedPrice:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "An exchange traded fund whose price depends on exchange traded constituents."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An exchange traded fund whose price depends on exchange traded constituents."]

    fundManager NonEmptyToken (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the fund manager that is in charge of the fund."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the fund manager that is in charge of the fund."]

type Future extends ExchangeTraded:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "An exchange traded future contract."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "An exchange traded future contract."]

    multiplier PositiveDecimal (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The multiplier is the minimum number of the underlying - index or stock - that a participant has to trade while taking a position in the Future contract. The purpose of the multiplier is to inflate the value of the contract to add leverage to the trade. The multiplier for the Dow is 10, for the Nasdaq it is 100 and it is 250 for the Standard and Poor\'s index."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The multiplier is the minimum number of the underlying - index or stock - that a participant has to trade while taking a position in the Future contract. The purpose of the multiplier is to inflate the value of the contract to add leverage to the trade. The multiplier for the Dow is 10, for the Nasdaq it is 100 and it is 250 for the Standard and Poor\'s index."]
    futureContractReference NonEmptyToken (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Native identifier for the contract on the listing exchange."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Native identifier for the contract on the listing exchange."]
    maturity zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date when the future contract expires."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date when the future contract expires."]
    contractYearMonth string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The contract month of the futures contract. i.e. F13 WTI NYMEX Contract is 2013-01."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The contract month of the futures contract. i.e. F13 WTI NYMEX Contract is 2013-01."]
    underlyer ExchangeTradedContractUnderlyer (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Underlyer of the option e.g. a listed future."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Underlyer of the option e.g. a listed future."]
    settlementType SettlementTypeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Settlement method for the contract (Cash, Physical). This value is used to populate the \"Delivery Type\" field for regulatory reporting (CFTC, ESMA)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Settlement method for the contract (Cash, Physical). This value is used to populate the \"Delivery Type\" field for regulatory reporting (CFTC, ESMA)."]

    condition Choice:
        optional choice maturity, contractYearMonth

type Fx extends FxRateAsset:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "Identifies a simple underlying asset type that is an FX rate. Used for specifying FX rates in the pricing and risk model."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "Identifies a simple underlying asset type that is an FX rate. Used for specifying FX rates in the pricing and risk model."]

type Index extends ExchangeTradedCalculatedPrice:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A published index whose price depends on exchange traded constituents."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A published index whose price depends on exchange traded constituents."]

    futureId FutureId (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A short form unique identifier for the reference future contract in the case of an index underlyer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A short form unique identifier for the reference future contract in the case of an index underlyer."]

type Loan extends UnderlyingAsset:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing a loan underlying asset."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing a loan underlying asset."]

    loanChoice LoanChoice (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    lien Lien (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the seniority level of the lien."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the seniority level of the lien."]
    facilityType FacilityType (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The type of loan facility (letter of credit, revolving, ...)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The type of loan facility (letter of credit, revolving, ...)."]
    maturity zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date when the principal amount of the loan becomes due and payable."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date when the principal amount of the loan becomes due and payable."]
    creditAgreementDate zonedDateTime (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The credit agreement date is the closing date (the date where the agreement has been signed) for the loans in the credit agreement. Funding of the facilities occurs on (or sometimes a little after) the Credit Agreement date. This underlyer attribute is used to help identify which of the company\'s outstanding loans are being referenced by knowing to which credit agreement it belongs. ISDA Standards Terms Supplement term: Date of Original Credit Agreement."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The credit agreement date is the closing date (the date where the agreement has been signed) for the loans in the credit agreement. Funding of the facilities occurs on (or sometimes a little after) the Credit Agreement date. This underlyer attribute is used to help identify which of the company\'s outstanding loans are being referenced by knowing to which credit agreement it belongs. ISDA Standards Terms Supplement term: Date of Original Credit Agreement."]
