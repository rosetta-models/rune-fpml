    contractReference NonEmptyToken (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the contract that can be referenced, besides the undelyer type."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the contract that can be referenced, besides the undelyer type."]
    expirationDate AdjustableOrRelativeDate (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The date when the contract expires."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The date when the contract expires."]

type ExchangeTradedContractUnderlyer:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing a single underlyer"]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing a single underlyer"]

    floatingRateIndex FloatingRateIndex (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The ISDA Floating Rate Option, i.e. the name of the floating rate."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The ISDA Floating Rate Option, i.e. the name of the floating rate."]
    indexTenor Period (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The ISDA Designated Maturity, i.e. the tenor of the floating rate."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The ISDA Designated Maturity, i.e. the tenor of the floating rate."]
    quotedCurrencyPair QuotedCurrencyPair (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines the two currencies for an FX trade and the quotation relationship between the two currencies."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines the two currencies for an FX trade and the quotation relationship between the two currencies."]
    underlyingAsset Asset (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]

    condition Choice:
        if floatingRateIndex exists
        then quotedCurrencyPair is absent and underlyingAsset is absent
        else if quotedCurrencyPair exists
        then floatingRateIndex is absent
                and indexTenor is absent
                and underlyingAsset is absent
        else if underlyingAsset exists
        then floatingRateIndex is absent
                and quotedCurrencyPair is absent
                and indexTenor is absent
        else False

