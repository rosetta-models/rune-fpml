type DeliveryNearby:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type defines nearest Delivery Date of the underlying Commodity of expiration of the futures contract."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type defines nearest Delivery Date of the underlying Commodity of expiration of the futures contract."]

    id string (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"]
        [docReference ISDA FPML version "confirmation-5.13"]
    deliveryNearbyMultiplier int(min: 1) (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "A time multiplier, e.g. 1, 2 or 3 etc. used in defining Delivery Nearby date."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "A time multiplier, e.g. 1, 2 or 3 etc. used in defining Delivery Nearby date."]
    deliveryNearbyType DeliveryNearbyTypeEnum (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Defines a type of the delivery nearby qualifier, expect to be used in conjunction with a delivery nearby multiplier, e.g. 1NearByMonth, 1NearbyWeek, etc. If \'CalculationPeriod\' is used, the delivery nearby multiplier is expected to be \'0\'. To represent \'Spot\', the value of the delivery nearby type should be \'NearbyMonth\' and the delivery period multiplier should be set to \'0\' (zero)."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Defines a type of the delivery nearby qualifier, expect to be used in conjunction with a delivery nearby multiplier, e.g. 1NearByMonth, 1NearbyWeek, etc. If \'CalculationPeriod\' is used, the delivery nearby multiplier is expected to be \'0\'. To represent \'Spot\', the value of the delivery nearby type should be \'NearbyMonth\' and the delivery period multiplier should be set to \'0\' (zero)."]

type DividendPayout:
    [docReference ISDA FPML version "recordkeeping-5.13"
        provision "A type describing the dividend payout ratio associated with an equity underlyer. In certain cases the actual ratio is not known on trade inception, and only general conditions are then specified."]
    [docReference ISDA FPML version "confirmation-5.13"
        provision "A type describing the dividend payout ratio associated with an equity underlyer. In certain cases the actual ratio is not known on trade inception, and only general conditions are then specified."]

    dividendPayoutRatio number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the total actual dividend payout ratio associated with the equity underlyer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the total actual dividend payout ratio associated with the equity underlyer."]
    dividendPayoutRatioCash number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the cash actual dividend payout ratio associated with the equity underlyer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the cash actual dividend payout ratio associated with the equity underlyer."]
    dividendPayoutRatioNonCash number (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the non cash actual dividend payout ratio associated with the equity underlyer."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the non cash actual dividend payout ratio associated with the equity underlyer."]
    dividendPayoutConditions NonEmptyNormalizedString (0..1)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "Specifies the dividend payout conditions that will be applied in the case where the actual ratio is not known, typically because of regulatory or legal uncertainties."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "Specifies the dividend payout conditions that will be applied in the case where the actual ratio is not known, typically because of regulatory or legal uncertainties."]
    dividendPayment PendingPayment (0..*)
        [docReference ISDA FPML version "recordkeeping-5.13"
            provision "The next upcoming dividend payment or payments."]
        [docReference ISDA FPML version "confirmation-5.13"
            provision "The next upcoming dividend payment or payments."]

    condition Choice:
        dividendPayoutConditions is absent
            or dividendPayoutRatio is absent
                and dividendPayoutRatioCash is absent
                and dividendPayoutRatioNonCash is absent

